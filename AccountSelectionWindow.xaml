<Window x:Class="Accounting.AccountSelectionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Pilih Akun"
        Width="860"
        Height="560"
        MinWidth="760"
        MinHeight="460"
        WindowStartupLocation="CenterOwner"
        PreviewKeyDown="Window_OnPreviewKeyDown">
    <Window.Resources>
        <Style x:Key="FieldLabelTextStyle" TargetType="{x:Type TextBlock}">
            <Setter Property="FontSize" Value="{DynamicResource Font.Caption}" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{DynamicResource Brush.TextPrimary}" />
            <Setter Property="Opacity" Value="0.9" />
        </Style>
        <Style x:Key="InputTextBoxStyle" TargetType="{x:Type TextBox}">
            <Setter Property="Height" Value="{DynamicResource Size.InputHeight}" />
            <Setter Property="Padding" Value="12,6" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="BorderBrush" Value="{DynamicResource Brush.BorderStrong}" />
            <Setter Property="Background" Value="{DynamicResource Brush.Surface}" />
            <Setter Property="Foreground" Value="{DynamicResource Brush.TextPrimary}" />
            <Setter Property="CaretBrush" Value="{DynamicResource Brush.PrimaryDark}" />
            <Setter Property="SelectionBrush" Value="{DynamicResource Brush.SelectionBorder}" />
            <Setter Property="SelectionOpacity" Value="0.28" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="BorderBrush" Value="{DynamicResource Brush.Focus}" />
                    <Setter Property="Background" Value="{DynamicResource Brush.SurfaceAlt}" />
                </Trigger>
                <Trigger Property="IsKeyboardFocusWithin" Value="True">
                    <Setter Property="BorderBrush" Value="{DynamicResource Brush.Focus}" />
                    <Setter Property="Background" Value="#FFFFFFFF" />
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="AccountPickerGridCellStyle"
               TargetType="{x:Type DataGridCell}"
               BasedOn="{StaticResource EnterpriseDataGridCellStyle}">
            <Setter Property="Padding" Value="8,2" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{DynamicResource Brush.Selection}" />
                    <Setter Property="BorderBrush" Value="{DynamicResource Brush.SelectionBorder}" />
                    <Setter Property="BorderThickness" Value="1" />
                    <Setter Property="Foreground" Value="{DynamicResource Brush.TextPrimary}" />
                </Trigger>
                <MultiTrigger>
                    <MultiTrigger.Conditions>
                        <Condition Property="IsSelected" Value="True" />
                        <Condition Property="IsKeyboardFocusWithin" Value="True" />
                    </MultiTrigger.Conditions>
                    <Setter Property="Background" Value="{DynamicResource Brush.PrimarySubtle}" />
                    <Setter Property="BorderBrush" Value="{DynamicResource Brush.Focus}" />
                </MultiTrigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="AccountPickerGridStyle"
               TargetType="{x:Type DataGrid}"
               BasedOn="{StaticResource EnterpriseDataGridStyle}">
            <Setter Property="RowHeight" Value="30" />
            <Setter Property="CellStyle" Value="{StaticResource AccountPickerGridCellStyle}" />
            <Setter Property="BorderBrush" Value="{DynamicResource Brush.BorderStrong}" />
            <Setter Property="HorizontalGridLinesBrush" Value="{DynamicResource Brush.BorderSoft}" />
            <Setter Property="VerticalGridLinesBrush" Value="{DynamicResource Brush.BorderSoft}" />
            <Setter Property="AlternatingRowBackground" Value="{DynamicResource Brush.SurfaceAlt}" />
        </Style>
    </Window.Resources>
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <TextBlock Text="Pilih Account"
                       FontFamily="Bahnschrift"
                       FontSize="28"
                       FontWeight="SemiBold"
                       Foreground="{DynamicResource Brush.TextPrimary}"/>
            <TextBlock Margin="0,8,0,0"
                       FontSize="14"
                       Foreground="{DynamicResource Brush.TextSecondary}"
                       Text="Cari berdasarkan kode atau nama akun, lalu pilih untuk mengisi baris jurnal."/>
        </StackPanel>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="120"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0"
                       VerticalAlignment="Center"
                       Style="{StaticResource FieldLabelTextStyle}"
                       Text="Cari"/>
            <TextBox x:Name="SearchTextBox"
                     Grid.Column="1"
                     Margin="8,0,0,0"
                     TextChanged="SearchTextBox_OnTextChanged"
                     Style="{StaticResource InputTextBoxStyle}"/>
        </Grid>

        <DataGrid x:Name="AccountsGrid"
                  Grid.Row="4"
                  Style="{StaticResource AccountPickerGridStyle}"
                  ItemsSource="{Binding FilteredAccounts}"
                  SelectionChanged="AccountsGrid_OnSelectionChanged"
                  MouseDoubleClick="AccountsGrid_OnMouseDoubleClick"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  CanUserAddRows="False">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Kode" Binding="{Binding Code}" Width="160"/>
                <DataGridTextColumn Header="Nama Akun" Binding="{Binding Name}" Width="*"/>
                <DataGridTextColumn Header="Tipe" Binding="{Binding AccountType}" Width="120"/>
            </DataGrid.Columns>
        </DataGrid>

        <Grid Grid.Row="6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0"
                       VerticalAlignment="Center"
                       FontSize="12"
                       Foreground="{DynamicResource Brush.TextSecondary}"
                       Text="{Binding ResultCountText}"/>
            <Button Grid.Column="1"
                    Height="40"
                    MinWidth="110"
                    IsCancel="True"
                    Click="CancelButton_OnClick"
                    Style="{StaticResource SecondaryPillButtonStyle}"
                    Content="Batal"/>
            <Button x:Name="SelectButton"
                    Grid.Column="3"
                    Height="40"
                    MinWidth="130"
                    IsDefault="True"
                    IsEnabled="False"
                    Click="SelectButton_OnClick"
                    Style="{StaticResource PrimaryButtonStyle}"
                    Content="Pilih Akun"/>
        </Grid>
    </Grid>
</Window>

