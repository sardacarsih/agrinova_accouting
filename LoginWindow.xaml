<Window x:Class="Accounting.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:controls="clr-namespace:Accounting.Controls"
        mc:Ignorable="d"
        Title="AgrInova Login"
        Width="1366"
        Height="768"
        MinWidth="1024"
        MinHeight="640"
        WindowState="Maximized"
        WindowStartupLocation="CenterScreen"
        SizeChanged="Window_OnSizeChanged"
        StateChanged="Window_OnStateChanged"
        PreviewKeyDown="Window_OnPreviewKeyDown">
    <Window.InputBindings>
        <KeyBinding Key="Enter" Command="{Binding SignInCommand}"/>
    </Window.InputBindings>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Ellipse Grid.RowSpan="2" Width="560" Height="560" HorizontalAlignment="Left" VerticalAlignment="Top" Fill="#22FFFFFF" Margin="-120,-160,0,0"/>
        <Ellipse Grid.RowSpan="2" Width="680" Height="680" HorizontalAlignment="Right" VerticalAlignment="Bottom" Fill="#12FFFFFF" Margin="0,0,-160,-220"/>

        <Border Grid.Row="0"
                HorizontalAlignment="Right"
                VerticalAlignment="Top"
                Margin="0,14,16,0"
                Padding="6"
                CornerRadius="10"
                Background="#26000000">
            <StackPanel Orientation="Horizontal">
                <Button Margin="0,0,6,0"
                        MinWidth="74"
                        Height="30"
                        Padding="14,4"
                        Style="{StaticResource SecondaryPillButtonStyle}"
                        Click="MinimizeButton_OnClick"
                        ToolTip="Minimize (Ctrl+M)"
                        Content="Minimize"/>
                <Button x:Name="MaximizeRestoreButton"
                        Margin="0,0,6,0"
                        MinWidth="74"
                        Height="30"
                        Padding="14,4"
                        Style="{StaticResource SecondaryPillButtonStyle}"
                        Click="MaximizeRestoreButton_OnClick"
                        ToolTip="Toggle maximize/restore (F11)"
                        Content="Restore"/>
                <Button MinWidth="74"
                        Height="30"
                        Padding="14,4"
                        Style="{StaticResource SecondaryPillButtonStyle}"
                        Click="CloseButton_OnClick"
                        ToolTip="Close (Alt+F4)"
                        Content="Close"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="1"
                x:Name="ShellContainer"
                MaxWidth="{Binding ContainerMaxWidth}"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Margin="{Binding ShellMargin}">
            <Border.RenderTransform>
                <TranslateTransform Y="{Binding ShellVerticalOffset}"/>
            </Border.RenderTransform>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="{Binding BrandingColumnWidth}"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Margin="{Binding BrandingPanelMargin}"
                        CornerRadius="26"
                        Background="{DynamicResource Brush.BrandingGradient}"
                        MinHeight="{Binding BrandingMinHeight}"
                        Visibility="{Binding BrandingVisibility}"
                        Opacity="0"
                        RenderTransformOrigin="0.5,0.5">
                    <Border.RenderTransform>
                        <TranslateTransform Y="18"/>
                    </Border.RenderTransform>
                    <Border.Triggers>
                        <EventTrigger RoutedEvent="FrameworkElement.Loaded">
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                     From="0"
                                                     To="1"
                                                     Duration="0:0:0.38">
                                        <DoubleAnimation.EasingFunction>
                                            <CubicEase EasingMode="EaseOut"/>
                                        </DoubleAnimation.EasingFunction>
                                    </DoubleAnimation>
                                    <DoubleAnimation Storyboard.TargetProperty="RenderTransform.(TranslateTransform.Y)"
                                                     From="18"
                                                     To="0"
                                                     Duration="0:0:0.38">
                                        <DoubleAnimation.EasingFunction>
                                            <CubicEase EasingMode="EaseOut"/>
                                        </DoubleAnimation.EasingFunction>
                                    </DoubleAnimation>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                    </Border.Triggers>

                    <Grid Margin="44">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <StackPanel Orientation="Horizontal" VerticalAlignment="Top">
                            <Border Width="48" Height="48" CornerRadius="24" Background="#33FFFFFF">
                                <Viewbox Margin="12">
                                    <Path Fill="White" Data="M 0 9 L 7 0 L 14 9 L 14 18 L 0 18 Z M 3 11 L 11 11 L 11 15 L 3 15 Z"/>
                                </Viewbox>
                            </Border>
                            <StackPanel Margin="14,2,0,0">
                                <TextBlock Text="AgrInova Suite" Foreground="White" FontFamily="Bahnschrift" FontSize="20" FontWeight="SemiBold"/>
                                <TextBlock Text="Enterprise Operations Platform" Foreground="#CCE9F8" FontSize="12"/>
                            </StackPanel>
                        </StackPanel>

                        <StackPanel Grid.Row="1" VerticalAlignment="Center" MaxWidth="520">
                            <TextBlock Text="Secure access to your enterprise workspace"
                                       Foreground="White"
                                       FontFamily="Bahnschrift"
                                       FontSize="{Binding BrandingHeadlineFontSize}"
                                       FontWeight="SemiBold"
                                       TextWrapping="Wrap"/>
                            <TextBlock Margin="0,16,0,0"
                                       Foreground="#D6E9F8"
                                       FontSize="16"
                                       TextWrapping="Wrap"
                                       Text="Manage ERP, accounting, manufacturing, and plantation workflows in one trusted desktop environment."/>
                        </StackPanel>

                        <Border Grid.Row="2" Padding="14,10" CornerRadius="12" Background="#1FFFFFFF" HorizontalAlignment="Left">
                            <TextBlock Foreground="#EAF6FF" FontSize="12" Text="Role-based access · Audited sessions · Enterprise encryption"/>
                        </Border>
                    </Grid>
                </Border>

                <Border Grid.Column="1"
                        Background="{DynamicResource Brush.Surface}"
                        CornerRadius="{StaticResource Radius.Card}"
                        MaxWidth="{Binding CardMaxWidth}"
                        MinWidth="{Binding CardMinWidth}"
                        Padding="{Binding CardPadding}"
                        Opacity="0"
                        RenderTransformOrigin="0.5,0.5">
                    <Border.RenderTransform>
                        <TransformGroup>
                            <ScaleTransform ScaleX="0.985" ScaleY="0.985"/>
                            <TranslateTransform Y="22"/>
                        </TransformGroup>
                    </Border.RenderTransform>
                    <Border.Triggers>
                        <EventTrigger RoutedEvent="FrameworkElement.Loaded">
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                     BeginTime="0:0:0.06"
                                                     From="0"
                                                     To="1"
                                                     Duration="0:0:0.42">
                                        <DoubleAnimation.EasingFunction>
                                            <CubicEase EasingMode="EaseOut"/>
                                        </DoubleAnimation.EasingFunction>
                                    </DoubleAnimation>
                                    <DoubleAnimation Storyboard.TargetProperty="RenderTransform.Children[0].(ScaleTransform.ScaleX)"
                                                     BeginTime="0:0:0.06"
                                                     From="0.985"
                                                     To="1"
                                                     Duration="0:0:0.42">
                                        <DoubleAnimation.EasingFunction>
                                            <CubicEase EasingMode="EaseOut"/>
                                        </DoubleAnimation.EasingFunction>
                                    </DoubleAnimation>
                                    <DoubleAnimation Storyboard.TargetProperty="RenderTransform.Children[0].(ScaleTransform.ScaleY)"
                                                     BeginTime="0:0:0.06"
                                                     From="0.985"
                                                     To="1"
                                                     Duration="0:0:0.42">
                                        <DoubleAnimation.EasingFunction>
                                            <CubicEase EasingMode="EaseOut"/>
                                        </DoubleAnimation.EasingFunction>
                                    </DoubleAnimation>
                                    <DoubleAnimation Storyboard.TargetProperty="RenderTransform.Children[1].(TranslateTransform.Y)"
                                                     BeginTime="0:0:0.06"
                                                     From="22"
                                                     To="0"
                                                     Duration="0:0:0.42">
                                        <DoubleAnimation.EasingFunction>
                                            <CubicEase EasingMode="EaseOut"/>
                                        </DoubleAnimation.EasingFunction>
                                    </DoubleAnimation>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                    </Border.Triggers>
                    <Border.Effect>
                        <DropShadowEffect Color="#330D2038" BlurRadius="42" ShadowDepth="8" Opacity="0.32"/>
                    </Border.Effect>

                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <StackPanel>
                            <Border Width="56" Height="56" CornerRadius="14" Background="{DynamicResource Brush.SurfaceMuted}" BorderBrush="{DynamicResource Brush.Border}" BorderThickness="1">
                                <Viewbox Margin="14">
                                    <Path Fill="{DynamicResource Brush.Primary}" Data="M 0 9 L 7 0 L 14 9 L 14 18 L 0 18 Z M 3 11 L 11 11 L 11 15 L 3 15 Z"/>
                                </Viewbox>
                            </Border>

                            <TextBlock Margin="0,20,0,0"
                                       FontFamily="Bahnschrift"
                                       FontSize="{Binding TitleFontSize}"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource Brush.TextPrimary}"
                                       Text="Welcome back"/>
                            <TextBlock Margin="0,8,0,0"
                                       FontSize="{Binding SubtitleFontSize}"
                                       Foreground="{DynamicResource Brush.TextMuted}"
                                       Text="Sign in to continue to the AgrInova enterprise desktop."/>
                            <Border Margin="0,12,0,0"
                                    Background="{DynamicResource Brush.SurfaceMuted}"
                                    BorderBrush="{DynamicResource Brush.Border}"
                                    BorderThickness="1"
                                    CornerRadius="10"
                                    Padding="2">
                                <UniformGrid Columns="3">
                                    <RadioButton GroupName="ThemeMode"
                                                 Style="{StaticResource ThemeIconRadioButtonStyle}"
                                                 ToolTip="Light theme"
                                                 IsChecked="{Binding SelectedThemeMode, Mode=TwoWay, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter=Light}">
                                        <Viewbox Width="14" Height="14">
                                            <Grid>
                                                <Ellipse Width="6" Height="6" Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}"/>
                                                <Rectangle Width="1.4" Height="3" Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}" VerticalAlignment="Top"/>
                                                <Rectangle Width="1.4" Height="3" Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}" VerticalAlignment="Bottom"/>
                                                <Rectangle Width="3" Height="1.4" Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}" HorizontalAlignment="Left"/>
                                                <Rectangle Width="3" Height="1.4" Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}" HorizontalAlignment="Right"/>
                                            </Grid>
                                        </Viewbox>
                                    </RadioButton>
                                    <RadioButton GroupName="ThemeMode"
                                                 Style="{StaticResource ThemeIconRadioButtonStyle}"
                                                 ToolTip="Dark theme"
                                                 IsChecked="{Binding SelectedThemeMode, Mode=TwoWay, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter=Dark}">
                                        <Viewbox Width="14" Height="14">
                                            <Path Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}"
                                                  Data="M10,1 A6,6 0 1 0 10,13 A4.5,4.5 0 1 1 10,1 Z"/>
                                        </Viewbox>
                                    </RadioButton>
                                    <RadioButton GroupName="ThemeMode"
                                                 Style="{StaticResource ThemeIconRadioButtonStyle}"
                                                 ToolTip="Follow system theme"
                                                 IsChecked="{Binding SelectedThemeMode, Mode=TwoWay, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter=System}">
                                        <Viewbox Width="14" Height="14">
                                            <Grid>
                                                <Rectangle Width="12" Height="8" Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}" StrokeThickness="1.2" RadiusX="1.2" RadiusY="1.2"/>
                                                <Rectangle Width="6" Height="1.3" Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}" VerticalAlignment="Bottom" Margin="0,0,0,-2"/>
                                            </Grid>
                                        </Viewbox>
                                    </RadioButton>
                                </UniformGrid>
                            </Border>
                            <CheckBox Margin="0,10,0,0"
                                      HorizontalAlignment="Left"
                                      Style="{StaticResource CompactCheckBoxStyle}"
                                      FontSize="12"
                                      Content="High contrast mode"
                                      IsChecked="{Binding IsHighContrast, Mode=TwoWay}"
                                      ToolTip="Increase contrast for improved readability"/>

                            <Border Margin="0,18,0,0"
                                    Padding="12,10"
                                    CornerRadius="10"
                                    BorderThickness="1"
                                    Background="#FFFEF3F2"
                                    BorderBrush="{DynamicResource Brush.Error}"
                                    Visibility="{Binding HasFormError, Converter={StaticResource BoolToVisibilityConverter}}">
                                <TextBlock Text="{Binding FormErrorMessage}" Foreground="{DynamicResource Brush.Error}" FontSize="13" TextWrapping="Wrap"/>
                            </Border>

                            <StackPanel Margin="0,20,0,0">
                                <TextBlock Text="Username" Style="{StaticResource FieldLabelTextStyle}"/>
                                <TextBox x:Name="UsernameInput"
                                         Margin="0,8,0,0"
                                         Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"
                                         PreviewKeyDown="UsernameInput_OnPreviewKeyDown"
                                         LostFocus="UsernameInput_OnLostFocus">
                                    <TextBox.Style>
                                        <Style TargetType="TextBox" BasedOn="{StaticResource InputTextBoxStyle}">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding HasUsernameError}" Value="True">
                                                    <Setter Property="BorderBrush" Value="{DynamicResource Brush.Error}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBox.Style>
                                </TextBox>
                                <TextBlock Margin="2,6,0,0"
                                           FontSize="12"
                                           Foreground="{DynamicResource Brush.Error}"
                                           Visibility="{Binding HasUsernameError, Converter={StaticResource BoolToVisibilityConverter}}"
                                           Text="{Binding UsernameError}"/>
                            </StackPanel>

                            <StackPanel Margin="0,16,0,0">
                                <TextBlock Text="Password" Style="{StaticResource FieldLabelTextStyle}"/>
                                <Grid Margin="0,8,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <PasswordBox x:Name="PasswordMaskedInput"
                                                 Grid.Column="0"
                                                 controls:BindablePasswordBox.BindPassword="True"
                                                 controls:BindablePasswordBox.BoundPassword="{Binding Password, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                 LostFocus="PasswordInput_OnLostFocus"
                                                 Visibility="{Binding IsPasswordVisible, Converter={StaticResource InverseBoolToVisibilityConverter}}">
                                        <PasswordBox.Style>
                                            <Style TargetType="PasswordBox" BasedOn="{StaticResource InputPasswordBoxStyle}">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding HasPasswordError}" Value="True">
                                                        <Setter Property="BorderBrush" Value="{DynamicResource Brush.Error}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </PasswordBox.Style>
                                    </PasswordBox>

                                    <TextBox x:Name="PasswordVisibleInput"
                                             Grid.Column="0"
                                             Text="{Binding Password, UpdateSourceTrigger=PropertyChanged}"
                                             LostFocus="PasswordInput_OnLostFocus"
                                             Visibility="{Binding IsPasswordVisible, Converter={StaticResource BoolToVisibilityConverter}}">
                                        <TextBox.Style>
                                            <Style TargetType="TextBox" BasedOn="{StaticResource InputTextBoxStyle}">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding HasPasswordError}" Value="True">
                                                        <Setter Property="BorderBrush" Value="{DynamicResource Brush.Error}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBox.Style>
                                    </TextBox>

                                    <Button Grid.Column="1"
                                            Margin="8,0,0,0"
                                            Command="{Binding TogglePasswordVisibilityCommand}"
                                            Style="{StaticResource SecondaryPillButtonStyle}"
                                            ToolTip="Show or hide password">
                                        <Button.Content>
                                            <TextBlock>
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Text" Value="Show"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsPasswordVisible}" Value="True">
                                                                <Setter Property="Text" Value="Hide"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Button.Content>
                                    </Button>
                                </Grid>

                                <TextBlock Margin="2,6,0,0"
                                           FontSize="12"
                                           Foreground="{DynamicResource Brush.Error}"
                                           Visibility="{Binding HasPasswordError, Converter={StaticResource BoolToVisibilityConverter}}"
                                           Text="{Binding PasswordError}"/>
                            </StackPanel>

                            <Grid Margin="0,16,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <CheckBox Grid.Column="0"
                                          IsChecked="{Binding RememberMe}"
                                          Style="{StaticResource CompactCheckBoxStyle}"
                                          Content="Remember me"/>
                                <Button Grid.Column="1"
                                        Style="{StaticResource TextLinkButtonStyle}"
                                        VerticalAlignment="Center"
                                        Command="{Binding ForgotPasswordCommand}"
                                        Content="Forgot password?"/>
                            </Grid>

                            <Button Margin="0,22,0,0"
                                    IsDefault="True"
                                    Command="{Binding SignInCommand}"
                                    IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBooleanConverter}}"
                                    Style="{StaticResource PrimaryButtonStyle}">
                                <TextBlock Text="{Binding SignInButtonText}"/>
                            </Button>

                            <ProgressBar Margin="0,10,0,0"
                                         Height="4"
                                         IsIndeterminate="True"
                                         Foreground="{DynamicResource Brush.Primary}"
                                         Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibilityConverter}}"/>
                        </StackPanel>

                        <Grid Grid.Row="2" Margin="0,24,0,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0"
                                       Style="{StaticResource MetaCaptionTextStyle}"
                                       Text="{Binding AppVersionText}"/>
                            <StackPanel Grid.Row="1" Margin="0,4,0,0" Orientation="Horizontal">
                                <TextBlock Style="{StaticResource MetaCaptionTextStyle}" Text="{Binding CopyrightText}"/>
                                <TextBlock Style="{StaticResource MetaCaptionTextStyle}" Text="  •  "/>
                                <Button Style="{StaticResource TextLinkButtonStyle}" FontSize="{StaticResource Font.Caption}" Command="{Binding SupportCommand}" Content="Support"/>
                            </StackPanel>
                        </Grid>
                    </Grid>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Window>

