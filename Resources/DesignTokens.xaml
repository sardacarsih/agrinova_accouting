<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:sys="clr-namespace:System;assembly=mscorlib">
    <!-- Core colors -->
    <Color x:Key="Color.Background">#FFF1F4F8</Color>
    <Color x:Key="Color.Surface">#FFFFFFFF</Color>
    <Color x:Key="Color.SurfaceMuted">#FFF7FAFC</Color>
    <Color x:Key="Color.SurfaceAlt">#FFF3F7FB</Color>
    <Color x:Key="Color.Primary">#FF0E596A</Color>
    <Color x:Key="Color.PrimaryDark">#FF0A4654</Color>
    <Color x:Key="Color.PrimaryLight">#FF1A7387</Color>
    <Color x:Key="Color.TextPrimary">#FF1F2937</Color>
    <Color x:Key="Color.TextSecondary">#FF6B7280</Color>
    <Color x:Key="Color.TextMuted">#FF8A94A3</Color>
    <Color x:Key="Color.Border">#FFD7DEE5</Color>
    <Color x:Key="Color.BorderSoft">#FFE2E8EF</Color>
    <Color x:Key="Color.BorderStrong">#FFC5CFD8</Color>
    <Color x:Key="Color.Focus">#FF1C7A93</Color>
    <Color x:Key="Color.Error">#FFB91C1C</Color>
    <Color x:Key="Color.ErrorSubtle">#FFFDEDEE</Color>
    <Color x:Key="Color.Success">#FF15803D</Color>
    <Color x:Key="Color.Warning">#FFB45309</Color>
    <Color x:Key="Color.Info">#FF1D4ED8</Color>
    <Color x:Key="Color.DisabledBackground">#FFF1F4F6</Color>
    <Color x:Key="Color.DisabledForeground">#FF9AA4B2</Color>
    <Color x:Key="Color.Selection">#FFDCECF2</Color>
    <Color x:Key="Color.SelectionBorder">#FF83ABB8</Color>
    <Color x:Key="Color.PrimarySubtle">#FFE3F0F4</Color>
    <Color x:Key="Color.InfoSubtle">#FFE9EEFF</Color>
    <Color x:Key="Color.Overlay">#660F172A</Color>
    <Color x:Key="Color.CardShadow">#220F172A</Color>
    <!-- Brushes -->
    <SolidColorBrush x:Key="Brush.Background" Color="{StaticResource Color.Background}" />
    <SolidColorBrush x:Key="Brush.Surface" Color="{StaticResource Color.Surface}" />
    <SolidColorBrush x:Key="Brush.SurfaceMuted" Color="{StaticResource Color.SurfaceMuted}" />
    <SolidColorBrush x:Key="Brush.SurfaceAlt" Color="{StaticResource Color.SurfaceAlt}" />
    <SolidColorBrush x:Key="Brush.Primary" Color="{StaticResource Color.Primary}" />
    <SolidColorBrush x:Key="Brush.PrimaryDark" Color="{StaticResource Color.PrimaryDark}" />
    <SolidColorBrush x:Key="Brush.PrimaryLight" Color="{StaticResource Color.PrimaryLight}" />
    <SolidColorBrush x:Key="Brush.PrimarySubtle" Color="{StaticResource Color.PrimarySubtle}" />
    <SolidColorBrush x:Key="Brush.TextPrimary" Color="{StaticResource Color.TextPrimary}" />
    <SolidColorBrush x:Key="Brush.TextSecondary" Color="{StaticResource Color.TextSecondary}" />
    <SolidColorBrush x:Key="Brush.TextMuted" Color="{StaticResource Color.TextMuted}" />
    <SolidColorBrush x:Key="Brush.Border" Color="{StaticResource Color.Border}" />
    <SolidColorBrush x:Key="Brush.BorderSoft" Color="{StaticResource Color.BorderSoft}" />
    <SolidColorBrush x:Key="Brush.BorderStrong" Color="{StaticResource Color.BorderStrong}" />
    <SolidColorBrush x:Key="Brush.Focus" Color="{StaticResource Color.Focus}" />
    <SolidColorBrush x:Key="Brush.Error" Color="{StaticResource Color.Error}" />
    <SolidColorBrush x:Key="Brush.ErrorSubtle" Color="{StaticResource Color.ErrorSubtle}" />
    <SolidColorBrush x:Key="Brush.Success" Color="{StaticResource Color.Success}" />
    <SolidColorBrush x:Key="Brush.Warning" Color="{StaticResource Color.Warning}" />
    <SolidColorBrush x:Key="Brush.Info" Color="{StaticResource Color.Info}" />
    <SolidColorBrush x:Key="Brush.InfoSubtle" Color="{StaticResource Color.InfoSubtle}" />
    <SolidColorBrush x:Key="Brush.DisabledBackground" Color="{StaticResource Color.DisabledBackground}" />
    <SolidColorBrush x:Key="Brush.DisabledForeground" Color="{StaticResource Color.DisabledForeground}" />
    <SolidColorBrush x:Key="Brush.Selection" Color="{StaticResource Color.Selection}" />
    <SolidColorBrush x:Key="Brush.SelectionBorder" Color="{StaticResource Color.SelectionBorder}" />
    <SolidColorBrush x:Key="Brush.Overlay" Color="{StaticResource Color.Overlay}" />
    <!-- Kept for runtime compatibility with ThemeService/Login branding -->
    <LinearGradientBrush x:Key="Brush.WindowGradient" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#FFF6F8FA" Offset="0" />
        <GradientStop Color="#FFF3F5F7" Offset="0.5" />
        <GradientStop Color="#FFF0F3F6" Offset="1" />
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="Brush.BrandingGradient" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#FF0F5F63" Offset="0" />
        <GradientStop Color="#FF0D555A" Offset="0.6" />
        <GradientStop Color="#FF0B4B4E" Offset="1" />
    </LinearGradientBrush>
    <!-- Spacing -->
    <sys:Double x:Key="Space.Unit">8</sys:Double>
    <sys:Double x:Key="Space.Small">8</sys:Double>
    <sys:Double x:Key="Space.Medium">16</sys:Double>
    <sys:Double x:Key="Space.Large">24</sys:Double>
    <Thickness x:Key="Space.PaddingSm">8</Thickness>
    <Thickness x:Key="Space.PaddingMd">16</Thickness>
    <Thickness x:Key="Space.PaddingLg">24</Thickness>
    <!-- Legacy keys kept for existing layouts -->
    <Thickness x:Key="Space.Outer">24</Thickness>
    <Thickness x:Key="Space.CardPadding">24</Thickness>
    <Thickness x:Key="Space.CardPaddingCompact">16</Thickness>
    <!-- Radius -->
    <CornerRadius x:Key="Radius.Small">10</CornerRadius>
    <CornerRadius x:Key="Radius.Control">10</CornerRadius>
    <CornerRadius x:Key="Radius.Medium">12</CornerRadius>
    <CornerRadius x:Key="Radius.Card">14</CornerRadius>
    <!-- Typography -->
    <FontFamily x:Key="FontFamily.Primary">Segoe UI Variable Text, Segoe UI</FontFamily>
    <sys:Double x:Key="Font.Title">22</sys:Double>
    <sys:Double x:Key="Font.Section">16</sys:Double>
    <sys:Double x:Key="Font.Body">14</sys:Double>
    <sys:Double x:Key="Font.Caption">12</sys:Double>
    <!-- Legacy keys kept for existing references -->
    <sys:Double x:Key="Font.Display">24</sys:Double>
    <sys:Double x:Key="Font.Heading">16</sys:Double>
    <sys:Double x:Key="Font.Subtitle">14</sys:Double>
    <!-- Sizing -->
    <sys:Double x:Key="Size.InputHeight">40</sys:Double>
    <sys:Double x:Key="Size.ButtonHeight">38</sys:Double>
    <sys:Double x:Key="Size.DataGridRowHeight">36</sys:Double>
    <sys:Double x:Key="Size.CardMaxWidth">520</sys:Double>
    <sys:Double x:Key="Size.ContainerMaxWidth">1720</sys:Double>
</ResourceDictionary>
