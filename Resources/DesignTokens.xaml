<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:sys="clr-namespace:System;assembly=mscorlib">
    <!-- Spacing -->
    <sys:Double x:Key="Space.Unit">8</sys:Double>
    <sys:Double x:Key="Space.Small">8</sys:Double>
    <sys:Double x:Key="Space.Medium">16</sys:Double>
    <sys:Double x:Key="Space.Large">24</sys:Double>
    <Thickness x:Key="Space.PaddingSm">8</Thickness>
    <Thickness x:Key="Space.PaddingMd">16</Thickness>
    <Thickness x:Key="Space.PaddingLg">24</Thickness>

    <!-- Legacy keys kept for existing layouts -->
    <Thickness x:Key="Space.Outer">24</Thickness>
    <Thickness x:Key="Space.CardPadding">24</Thickness>
    <Thickness x:Key="Space.CardPaddingCompact">16</Thickness>

    <!-- Radius -->
    <CornerRadius x:Key="Radius.Small">10</CornerRadius>
    <CornerRadius x:Key="Radius.Control">10</CornerRadius>
    <CornerRadius x:Key="Radius.Medium">12</CornerRadius>
    <CornerRadius x:Key="Radius.Card">14</CornerRadius>

    <!-- Typography -->
    <FontFamily x:Key="FontFamily.Primary">Segoe UI Variable Text, Segoe UI</FontFamily>
    <sys:Double x:Key="Font.Title">22</sys:Double>
    <sys:Double x:Key="Font.Section">16</sys:Double>
    <sys:Double x:Key="Font.Body">14</sys:Double>
    <sys:Double x:Key="Font.Caption">12</sys:Double>

    <!-- Legacy keys kept for existing references -->
    <sys:Double x:Key="Font.Display">24</sys:Double>
    <sys:Double x:Key="Font.Heading">16</sys:Double>
    <sys:Double x:Key="Font.Subtitle">14</sys:Double>

    <!-- Sizing -->
    <sys:Double x:Key="Size.InputHeight">40</sys:Double>
    <sys:Double x:Key="Size.ButtonHeight">38</sys:Double>
    <sys:Double x:Key="Size.DataGridRowHeight">36</sys:Double>
    <sys:Double x:Key="Size.CardMaxWidth">520</sys:Double>
    <sys:Double x:Key="Size.ContainerMaxWidth">1720</sys:Double>
</ResourceDictionary>
