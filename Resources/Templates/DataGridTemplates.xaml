<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Style x:Key="EnterpriseDataGridColumnHeaderStyle" TargetType="{x:Type DataGridColumnHeader}">
        <Setter Property="Background" Value="{DynamicResource Brush.SurfaceMuted}" />
        <Setter Property="Foreground" Value="{DynamicResource Brush.TextSecondary}" />
        <Setter Property="FontSize" Value="{DynamicResource Font.Caption}" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border}" />
        <Setter Property="BorderThickness" Value="0,0,0,1" />
        <Setter Property="Padding" Value="8,6" />
    </Style>
    <Style x:Key="EnterpriseDataGridCellStyle" TargetType="{x:Type DataGridCell}">
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="8,6" />
        <Setter Property="Foreground" Value="{DynamicResource Brush.TextPrimary}" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
    </Style>
    <Style x:Key="EnterpriseNumericCellTextStyle" TargetType="{x:Type TextBlock}">
        <Setter Property="HorizontalAlignment" Value="Stretch" />
        <Setter Property="TextAlignment" Value="Right" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>
    <Style x:Key="JournalLikeDataGridCellStyle"
           TargetType="{x:Type DataGridCell}"
           BasedOn="{StaticResource EnterpriseDataGridCellStyle}">
        <Setter Property="Padding" Value="8,2" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Style.Triggers>
            <Trigger Property="IsSelected" Value="True">
                <Setter Property="Background" Value="{DynamicResource Brush.Selection}" />
                <Setter Property="BorderBrush" Value="{DynamicResource Brush.SelectionBorder}" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="Foreground" Value="{DynamicResource Brush.TextPrimary}" />
            </Trigger>
            <MultiTrigger>
                <MultiTrigger.Conditions>
                    <Condition Property="IsSelected" Value="True" />
                    <Condition Property="IsKeyboardFocusWithin" Value="True" />
                </MultiTrigger.Conditions>
                <Setter Property="Background" Value="{DynamicResource Brush.PrimarySubtle}" />
                <Setter Property="BorderBrush" Value="{DynamicResource Brush.Focus}" />
                <Setter Property="Foreground" Value="{DynamicResource Brush.PrimaryDark}" />
            </MultiTrigger>
        </Style.Triggers>
    </Style>
    <Style x:Key="JournalLikeDataGridEditingTextBoxStyle"
           TargetType="{x:Type TextBox}"
           BasedOn="{StaticResource InputTextBoxStyle}">
        <Setter Property="Height" Value="24" />
        <Setter Property="Padding" Value="6,2" />
        <Setter Property="BorderBrush" Value="{DynamicResource Brush.Focus}" />
        <Setter Property="Background" Value="#FFFFFFFF" />
        <Setter Property="Foreground" Value="{DynamicResource Brush.PrimaryDark}" />
        <Setter Property="CaretBrush" Value="{DynamicResource Brush.PrimaryDark}" />
        <Setter Property="SelectionBrush" Value="{DynamicResource Brush.SelectionBorder}" />
        <Setter Property="SelectionOpacity" Value="0.28" />
    </Style>
    <Style x:Key="JournalLikeDataGridNumericTextStyle"
           TargetType="{x:Type TextBlock}"
           BasedOn="{StaticResource EnterpriseNumericCellTextStyle}" />
    <Style x:Key="JournalLikeDataGridNumericEditingTextBoxStyle"
           TargetType="{x:Type TextBox}"
           BasedOn="{StaticResource JournalLikeDataGridEditingTextBoxStyle}">
        <Setter Property="HorizontalContentAlignment" Value="Right" />
        <Setter Property="TextAlignment" Value="Right" />
    </Style>
    <Style x:Key="EnterpriseDataGridStyle" TargetType="{x:Type DataGrid}">
        <Setter Property="Background" Value="{DynamicResource Brush.Surface}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="GridLinesVisibility" Value="Horizontal" />
        <Setter Property="HorizontalGridLinesBrush" Value="{DynamicResource Brush.Border}" />
        <Setter Property="VerticalGridLinesBrush" Value="{DynamicResource Brush.Border}" />
        <Setter Property="AlternatingRowBackground" Value="{DynamicResource Brush.SurfaceMuted}" />
        <Setter Property="RowHeight" Value="{DynamicResource Size.DataGridRowHeight}" />
        <Setter Property="ColumnHeaderStyle" Value="{StaticResource EnterpriseDataGridColumnHeaderStyle}" />
        <Setter Property="CellStyle" Value="{StaticResource EnterpriseDataGridCellStyle}" />
    </Style>
    <Style x:Key="JournalLikeDataGridStyle"
           TargetType="{x:Type DataGrid}"
           BasedOn="{StaticResource EnterpriseDataGridStyle}">
        <Setter Property="RowHeight" Value="30" />
        <Setter Property="CellStyle" Value="{StaticResource JournalLikeDataGridCellStyle}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Brush.BorderStrong}" />
        <Setter Property="HorizontalGridLinesBrush" Value="{DynamicResource Brush.BorderSoft}" />
        <Setter Property="VerticalGridLinesBrush" Value="{DynamicResource Brush.BorderSoft}" />
        <Setter Property="AlternatingRowBackground" Value="{DynamicResource Brush.SurfaceAlt}" />
    </Style>
    <Style x:Key="InventoryLookupPopupBorderStyle" TargetType="{x:Type Border}">
        <Setter Property="Background" Value="{DynamicResource Brush.Surface}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Brush.BorderStrong}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="Padding" Value="4" />
        <Setter Property="Effect">
            <Setter.Value>
                <DropShadowEffect BlurRadius="12" ShadowDepth="0" Opacity="0.18" Color="{DynamicResource Color.CardShadow}" />
            </Setter.Value>
        </Setter>
    </Style>
    <Style x:Key="InventoryLookupListBoxStyle" TargetType="{x:Type ListBox}">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled" />
        <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto" />
    </Style>
    <Style x:Key="InventoryLookupListBoxItemStyle" TargetType="{x:Type ListBoxItem}">
        <Setter Property="Padding" Value="8,6" />
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        <Setter Property="Foreground" Value="{DynamicResource Brush.TextPrimary}" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{DynamicResource Brush.SurfaceAlt}" />
            </Trigger>
            <Trigger Property="IsSelected" Value="True">
                <Setter Property="Background" Value="{DynamicResource Brush.PrimarySubtle}" />
            </Trigger>
        </Style.Triggers>
    </Style>
    <DataTemplate x:Key="StatusBadgeTemplate">
        <Border Padding="8,2" CornerRadius="8" Background="{DynamicResource Brush.InfoSubtle}" BorderBrush="{DynamicResource Brush.Info}" BorderThickness="1">
            <TextBlock Text="{Binding}" Foreground="{DynamicResource Brush.Info}" FontWeight="SemiBold" FontSize="12" />
        </Border>
    </DataTemplate>
    <DataTemplate x:Key="InventoryImportErrorPanelTemplate">
        <Border Style="{StaticResource AdminToolbarCardStyle}"
                BorderBrush="{DynamicResource Brush.Warning}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Row="0" Grid.Column="0">
                    <TextBlock Text="{Binding Title}"
                               FontSize="14"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource Brush.Warning}" />
                    <TextBlock Margin="0,4,0,0"
                               Foreground="{DynamicResource Brush.TextSecondary}"
                               Text="{Binding Summary}"
                               TextWrapping="Wrap" />
                </StackPanel>
                <Border Grid.Row="0"
                        Grid.Column="1"
                        Style="{StaticResource InlineMetricBadgeStyle}"
                        Background="{DynamicResource Brush.SurfaceAlt}"
                        BorderBrush="{DynamicResource Brush.Warning}">
                    <TextBlock Foreground="{DynamicResource Brush.Warning}"
                               Text="{Binding ErrorCountText}" />
                </Border>
                <DataGrid Grid.Row="1"
                          Grid.ColumnSpan="2"
                          Margin="0,10,0,0"
                          Style="{StaticResource EnterpriseDataGridStyle}"
                          ItemsSource="{Binding Errors}"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          MaxHeight="220"
                          MinHeight="120">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Sheet" Binding="{Binding SheetName}" Width="120" />
                        <DataGridTextColumn Header="Baris" Binding="{Binding RowNumber}" Width="70" />
                        <DataGridTextColumn Header="Pesan" Binding="{Binding Message}" Width="*" />
                    </DataGrid.Columns>
                </DataGrid>
                <WrapPanel Grid.Row="2" Grid.ColumnSpan="2" Margin="0,10,0,0">
                    <Button Command="{Binding CloseCommand}"
                            Style="{StaticResource SecondaryPillButtonStyle}"
                            Content="Tutup Panel Error" />
                </WrapPanel>
            </Grid>
        </Border>
    </DataTemplate>
</ResourceDictionary>
