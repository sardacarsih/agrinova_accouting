<UserControl x:Class="Accounting.Views.Components.Dashboard.DashboardAlertView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             UseLayoutRounding="True"
             SnapsToDevicePixels="True">
    <Border Style="{StaticResource DashboardSectionCardStyle}">
        <StackPanel>
            <TextBlock Style="{StaticResource DashboardSectionTitleTextStyle}" Text="Alerts &amp; Notification" />
            <TextBlock Style="{StaticResource DashboardSectionSubtitleTextStyle}" Text="Alert operasional yang perlu ditindaklanjuti." />

            <ItemsControl Margin="0,14,0,0" ItemsSource="{Binding Alerts.Items}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border>
                            <Border.Style>
                                <Style TargetType="Border" BasedOn="{StaticResource DashboardAlertCardStyle}">
                                    <Setter Property="Background" Value="{DynamicResource Brush.InfoSubtle}" />
                                    <Setter Property="BorderBrush" Value="{DynamicResource Brush.Info}" />
                                    <Setter Property="BorderThickness" Value="1" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsWarning}" Value="True">
                                            <Setter Property="Background" Value="#FFFDF7E8" />
                                            <Setter Property="BorderBrush" Value="{DynamicResource Brush.Warning}" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding IsCritical}" Value="True">
                                            <Setter Property="Background" Value="{DynamicResource Brush.ErrorSubtle}" />
                                            <Setter Property="BorderBrush" Value="{DynamicResource Brush.Error}" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock FontFamily="Segoe MDL2 Assets"
                                           FontSize="20"
                                           Margin="0,0,12,0"
                                           Text="{Binding IconGlyph}" />
                                <StackPanel Grid.Column="1">
                                    <WrapPanel>
                                        <TextBlock FontWeight="SemiBold" Text="{Binding Source.Title}" />
                                        <Border Margin="8,0,0,0"
                                                Padding="8,2"
                                                CornerRadius="8"
                                                Background="{DynamicResource Brush.Surface}"
                                                BorderBrush="{DynamicResource Brush.Border}"
                                                BorderThickness="1"
                                                Visibility="{Binding HasCount, Converter={StaticResource BoolToVisibilityConverter}}">
                                            <TextBlock Style="{StaticResource MetaCaptionTextStyle}"
                                                       Text="{Binding CountText, StringFormat={}{0} item}" />
                                        </Border>
                                    </WrapPanel>
                                    <TextBlock Margin="0,4,0,0" Style="{StaticResource MetaCaptionTextStyle}" Text="{Binding Source.Message}" />
                                </StackPanel>
                                <Button Grid.Column="2"
                                        Margin="12,0,0,0"
                                        Padding="10,6"
                                        Click="AlertAction_Click"
                                        Content="{Binding ActionLabel}"
                                        IsEnabled="{Binding CanExecuteAction}"
                                        Tag="{Binding}">
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource SecondaryPillButtonStyle}">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding HasActionLabel}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <Border Margin="0,12,0,0"
                    Padding="14"
                    CornerRadius="12"
                    Background="{DynamicResource Brush.SurfaceAlt}"
                    BorderBrush="{DynamicResource Brush.Border}"
                    BorderThickness="1">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding Alerts.Items.Count}" Value="0">
                                <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <TextBlock Foreground="{DynamicResource Brush.TextSecondary}"
                           Text="Tidak ada alert operasional untuk periode aktif." />
            </Border>
        </StackPanel>
    </Border>
</UserControl>
