<UserControl x:Class="Accounting.Views.Components.Dashboard.DashboardChartView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             UseLayoutRounding="True"
             SnapsToDevicePixels="True">
    <UserControl.Resources>
        <Style x:Key="DashboardChartMarkerButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="12" />
            <Setter Property="Height" Value="12" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Background" Value="{DynamicResource Brush.Primary}" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Ellipse Fill="{TemplateBinding Background}"
                                 Stroke="{DynamicResource Brush.Surface}"
                                 StrokeThickness="2" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DashboardChartAxisLabelStyle" TargetType="ContentPresenter">
            <Setter Property="Canvas.Left" Value="{Binding Left}" />
            <Setter Property="Canvas.Top" Value="{Binding Top}" />
        </Style>
    </UserControl.Resources>

    <StackPanel>
        <Border Style="{StaticResource DashboardSectionCardStyle}">
            <StackPanel>
                <DockPanel>
                    <StackPanel DockPanel.Dock="Left">
                        <TextBlock Style="{StaticResource DashboardSectionTitleTextStyle}" Text="Revenue vs Expense" />
                        <TextBlock Style="{StaticResource DashboardSectionSubtitleTextStyle}" Text="Trend 12 bulan terakhir untuk pendapatan dan beban." />
                    </StackPanel>
                    <StackPanel DockPanel.Dock="Right"
                                Orientation="Horizontal"
                                VerticalAlignment="Center">
                        <Border Margin="0,0,10,0"
                                Padding="10,5"
                                CornerRadius="10"
                                Background="{DynamicResource Brush.PrimarySubtle}">
                            <StackPanel Orientation="Horizontal">
                                <Ellipse Width="10" Height="10" Margin="0,0,6,0" Fill="{DynamicResource Brush.Primary}" />
                                <TextBlock VerticalAlignment="Center" Text="Revenue" />
                            </StackPanel>
                        </Border>
                        <Border Margin="0,0,10,0"
                                Padding="10,5"
                                CornerRadius="10"
                                Background="{DynamicResource Brush.ErrorSubtle}">
                            <StackPanel Orientation="Horizontal">
                                <Ellipse Width="10" Height="10" Margin="0,0,6,0" Fill="{DynamicResource Brush.Error}" />
                                <TextBlock VerticalAlignment="Center" Text="Expense" />
                            </StackPanel>
                        </Border>
                        <Button Click="TrendDetail_Click"
                                IsEnabled="{Binding CanDrillToReports}"
                                Style="{StaticResource SecondaryPillButtonStyle}"
                                Content="Open P&amp;L" />
                    </StackPanel>
                </DockPanel>

                <Grid Margin="0,16,0,0">
                    <Grid Visibility="{Binding Charts.HasTrendData, Converter={StaticResource BoolToVisibilityConverter}}">
                        <Viewbox Stretch="Fill" Height="260">
                            <Grid Width="720"
                                  Height="232">
                                <Canvas Width="720"
                                        Height="232">
                                    <Line X1="18" X2="702" Y1="16" Y2="16" Stroke="{DynamicResource Brush.BorderSoft}" StrokeThickness="1" />
                                    <Line X1="18" X2="702" Y1="76" Y2="76" Stroke="{DynamicResource Brush.BorderSoft}" StrokeThickness="1" />
                                    <Line X1="18" X2="702" Y1="136" Y2="136" Stroke="{DynamicResource Brush.BorderSoft}" StrokeThickness="1" />
                                    <Line X1="18" X2="702" Y1="198" Y2="198" Stroke="{DynamicResource Brush.Border}" StrokeThickness="1" />

                                    <Path Data="{Binding Charts.RevenueLineGeometry}"
                                          Stroke="{DynamicResource Brush.Primary}"
                                          StrokeThickness="3"
                                          StrokeStartLineCap="Round"
                                          StrokeEndLineCap="Round"
                                          StrokeLineJoin="Round" />
                                    <Path Data="{Binding Charts.ExpenseLineGeometry}"
                                          Stroke="{DynamicResource Brush.Error}"
                                          StrokeThickness="3"
                                          StrokeStartLineCap="Round"
                                          StrokeEndLineCap="Round"
                                          StrokeLineJoin="Round" />
                                </Canvas>

                                <ItemsControl ItemsSource="{Binding Charts.TrendAxisLabels}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <Canvas Width="720"
                                                    Height="232" />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemContainerStyle>
                                        <Style TargetType="ContentPresenter" BasedOn="{StaticResource DashboardChartAxisLabelStyle}" />
                                    </ItemsControl.ItemContainerStyle>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock FontSize="11"
                                                       Foreground="{DynamicResource Brush.TextSecondary}"
                                                       Text="{Binding Label}" />
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <ItemsControl ItemsSource="{Binding Charts.RevenueMarkers}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <Canvas Width="720"
                                                    Height="232" />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemContainerStyle>
                                        <Style TargetType="ContentPresenter">
                                            <Setter Property="Canvas.Left" Value="{Binding Left}" />
                                            <Setter Property="Canvas.Top" Value="{Binding Top}" />
                                        </Style>
                                    </ItemsControl.ItemContainerStyle>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Button Background="{Binding FillHex}"
                                                    Click="TrendPoint_Click"
                                                    IsEnabled="{Binding DataContext.CanDrillToReports, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    Style="{StaticResource DashboardChartMarkerButtonStyle}"
                                                    Tag="{Binding}"
                                                    ToolTip="{Binding ToolTipText}" />
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <ItemsControl ItemsSource="{Binding Charts.ExpenseMarkers}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <Canvas Width="720"
                                                    Height="232" />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemContainerStyle>
                                        <Style TargetType="ContentPresenter">
                                            <Setter Property="Canvas.Left" Value="{Binding Left}" />
                                            <Setter Property="Canvas.Top" Value="{Binding Top}" />
                                        </Style>
                                    </ItemsControl.ItemContainerStyle>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Button Background="{Binding FillHex}"
                                                    Click="TrendPoint_Click"
                                                    IsEnabled="{Binding DataContext.CanDrillToReports, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    Style="{StaticResource DashboardChartMarkerButtonStyle}"
                                                    Tag="{Binding}"
                                                    ToolTip="{Binding ToolTipText}" />
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </Grid>
                        </Viewbox>
                    </Grid>

                    <Border Padding="18"
                            CornerRadius="12"
                            Background="{DynamicResource Brush.SurfaceAlt}"
                            BorderBrush="{DynamicResource Brush.Border}"
                            BorderThickness="1"
                            Visibility="{Binding Charts.HasTrendData, Converter={StaticResource InverseBoolToVisibilityConverter}}">
                        <TextBlock Foreground="{DynamicResource Brush.TextSecondary}"
                                   Text="Belum ada data trend untuk periode ini." />
                    </Border>
                </Grid>
            </StackPanel>
        </Border>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="14" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource DashboardSectionCardStyle}">
                <StackPanel>
                    <TextBlock Style="{StaticResource DashboardSectionTitleTextStyle}" Text="Top Expense Accounts" />
                    <TextBlock Style="{StaticResource DashboardSectionSubtitleTextStyle}" Text="Akun biaya terbesar pada periode aktif." />

                    <ScrollViewer Margin="0,16,0,0"
                                  HorizontalScrollBarVisibility="Auto"
                                  VerticalScrollBarVisibility="Disabled">
                        <ItemsControl ItemsSource="{Binding Charts.ExpenseBars}"
                                      Visibility="{Binding Charts.HasExpenseData, Converter={StaticResource BoolToVisibilityConverter}}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Width="74" Margin="0,0,12,0">
                                        <Grid Height="{Binding DataContext.Charts.BarChartHeight, RelativeSource={RelativeSource AncestorType=UserControl}}">
                                            <Button VerticalAlignment="Bottom"
                                                    Background="Transparent"
                                                    BorderThickness="0"
                                                    Click="ExpenseItem_Click"
                                                    Cursor="Hand"
                                                    IsEnabled="{Binding DataContext.CanDrillToReports, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    Padding="0"
                                                    Tag="{Binding Source}"
                                                    ToolTip="{Binding ToolTipText}">
                                                <Border Height="{Binding Height}"
                                                        CornerRadius="10,10,0,0"
                                                        Background="{DynamicResource Brush.Info}" />
                                            </Button>
                                        </Grid>
                                        <TextBlock Margin="0,8,0,0"
                                                   FontWeight="SemiBold"
                                                   HorizontalAlignment="Center"
                                                   Text="{Binding Label}" />
                                        <TextBlock FontSize="11"
                                                   Foreground="{DynamicResource Brush.TextSecondary}"
                                                   HorizontalAlignment="Center"
                                                   Text="{Binding ValueText}" />
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                    <Border Margin="0,12,0,0"
                            Padding="14"
                            CornerRadius="12"
                            Background="{DynamicResource Brush.SurfaceAlt}"
                            BorderBrush="{DynamicResource Brush.Border}"
                            BorderThickness="1"
                            Visibility="{Binding Charts.HasExpenseData, Converter={StaticResource InverseBoolToVisibilityConverter}}">
                        <TextBlock Foreground="{DynamicResource Brush.TextSecondary}"
                                   Text="Belum ada akun biaya dominan untuk periode ini." />
                    </Border>

                    <ItemsControl Margin="0,12,0,0"
                                  ItemsSource="{Binding Charts.TopExpenseAccounts}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button Margin="0,0,0,6"
                                        Padding="10,8"
                                        Background="{DynamicResource Brush.SurfaceAlt}"
                                        BorderBrush="{DynamicResource Brush.Border}"
                                        BorderThickness="1"
                                        Click="ExpenseItem_Click"
                                        IsEnabled="{Binding DataContext.CanDrillToReports, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        Tag="{Binding}">
                                    <DockPanel>
                                        <TextBlock DockPanel.Dock="Right" Text="{Binding Amount, StringFormat=N0}" />
                                        <TextBlock Text="{Binding AccountCode, StringFormat={}{0} - }" />
                                        <TextBlock Text="{Binding AccountName}" />
                                    </DockPanel>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <Border Grid.Column="2" Style="{StaticResource DashboardSectionCardStyle}">
                <StackPanel>
                    <DockPanel>
                        <StackPanel DockPanel.Dock="Left">
                            <TextBlock Style="{StaticResource DashboardSectionTitleTextStyle}" Text="Asset Composition" />
                            <TextBlock Style="{StaticResource DashboardSectionSubtitleTextStyle}" Text="Perbandingan aset lancar dan aset tetap." />
                        </StackPanel>
                        <Button DockPanel.Dock="Right"
                                Click="AssetDetail_Click"
                                IsEnabled="{Binding CanDrillToReports}"
                                Style="{StaticResource SecondaryPillButtonStyle}"
                                Content="Open Balance Sheet" />
                    </DockPanel>

                    <Grid Margin="0,16,0,0"
                          Visibility="{Binding Charts.HasAssetData, Converter={StaticResource BoolToVisibilityConverter}}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Grid Width="{Binding Charts.DonutSize}"
                              Height="{Binding Charts.DonutSize}"
                              HorizontalAlignment="Center">
                            <ItemsControl ItemsSource="{Binding Charts.DonutSlices}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <Grid />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Path Data="{Binding GeometryData}"
                                              Fill="{Binding FillHex}"
                                              MouseLeftButtonUp="AssetSlice_Click"
                                              Stretch="None"
                                              Stroke="{DynamicResource Brush.Surface}"
                                              StrokeThickness="2"
                                              ToolTip="{Binding ToolTipText}" />
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <Border Width="92"
                                    Height="92"
                                    CornerRadius="46"
                                    Background="{DynamicResource Brush.Surface}"
                                    BorderBrush="{DynamicResource Brush.Border}"
                                    BorderThickness="1"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center">
                                <StackPanel VerticalAlignment="Center"
                                            HorizontalAlignment="Center">
                                    <TextBlock HorizontalAlignment="Center"
                                               Foreground="{DynamicResource Brush.TextSecondary}"
                                               Text="Assets" />
                                    <TextBlock HorizontalAlignment="Center"
                                               FontSize="16"
                                               FontWeight="SemiBold"
                                               Text="{Binding Charts.DonutCenterValueText}" />
                                </StackPanel>
                            </Border>
                        </Grid>

                        <ItemsControl Grid.Row="1"
                                      Margin="0,18,0,0"
                                      ItemsSource="{Binding Charts.DonutSlices}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0,0,0,8"
                                            Padding="10"
                                            CornerRadius="10"
                                            Background="{DynamicResource Brush.SurfaceAlt}"
                                            BorderBrush="{DynamicResource Brush.Border}"
                                            BorderThickness="1">
                                        <DockPanel>
                                            <TextBlock DockPanel.Dock="Right"
                                                       FontWeight="SemiBold"
                                                       Text="{Binding ValueText}" />
                                            <StackPanel Orientation="Horizontal">
                                                <Ellipse Width="10"
                                                         Height="10"
                                                         Margin="0,0,8,0"
                                                         Fill="{Binding FillHex}" />
                                                <TextBlock Text="{Binding Label}" />
                                            </StackPanel>
                                        </DockPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Grid>

                    <Border Padding="14"
                            CornerRadius="12"
                            Background="{DynamicResource Brush.SurfaceAlt}"
                            BorderBrush="{DynamicResource Brush.Border}"
                            BorderThickness="1"
                            Visibility="{Binding Charts.HasAssetData, Converter={StaticResource InverseBoolToVisibilityConverter}}">
                        <TextBlock Foreground="{DynamicResource Brush.TextSecondary}"
                                   Text="Belum ada komposisi aset pada periode ini." />
                    </Border>
                </StackPanel>
            </Border>
        </Grid>
    </StackPanel>
</UserControl>
