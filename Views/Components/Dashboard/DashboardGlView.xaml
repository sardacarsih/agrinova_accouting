<UserControl x:Class="Accounting.Views.Components.Dashboard.DashboardGlView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             UseLayoutRounding="True"
             SnapsToDevicePixels="True">
    <Border Style="{StaticResource DashboardSectionCardStyle}">
        <StackPanel>
            <TextBlock Style="{StaticResource DashboardSectionTitleTextStyle}" Text="General Ledger Snapshot" />
            <TextBlock Style="{StaticResource DashboardSectionSubtitleTextStyle}" Text="Status jurnal dan transaksi terbaru." />

            <WrapPanel Margin="0,14,0,0">
                <Border Style="{StaticResource SummaryCardStyle}" Width="150" Margin="0,0,10,10">
                    <StackPanel>
                        <TextBlock Style="{StaticResource MetaCaptionTextStyle}" Text="Draft" />
                        <TextBlock Style="{StaticResource DashboardMiniValueTextStyle}" Text="{Binding Gl.DraftCount}" />
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource SummaryCardStyle}" Width="150" Margin="0,0,10,10">
                    <StackPanel>
                        <TextBlock Style="{StaticResource MetaCaptionTextStyle}" Text="Posted" />
                        <TextBlock Style="{StaticResource DashboardMiniValueTextStyle}" Text="{Binding Gl.PostedCount}" />
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource SummaryCardStyle}" Width="170" Margin="0,0,0,10">
                    <StackPanel>
                        <TextBlock Style="{StaticResource MetaCaptionTextStyle}" Text="Pending Posting" />
                        <TextBlock Style="{StaticResource DashboardMiniValueTextStyle}" Text="{Binding Gl.PendingCount}" />
                    </StackPanel>
                </Border>
            </WrapPanel>

            <Border Margin="0,0,0,12"
                    Padding="12"
                    Background="{DynamicResource Brush.WarningSubtle}"
                    BorderBrush="{DynamicResource Brush.Warning}"
                    BorderThickness="1"
                    CornerRadius="10"
                    Visibility="{Binding Gl.HasPendingCount, Converter={StaticResource BoolToVisibilityConverter}}">
                <TextBlock Foreground="{DynamicResource Brush.Warning}"
                           FontWeight="SemiBold"
                           Text="{Binding Gl.PendingCount, StringFormat=Perhatian: {0} jurnal masih menunggu posting.}" />
            </Border>

            <TextBlock Margin="0,8,0,8"
                       Style="{StaticResource FieldLabelTextStyle}"
                       Text="10 transaksi terakhir" />
            <ItemsControl ItemsSource="{Binding Gl.RecentTransactions}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Button Margin="0,0,0,8"
                                Padding="12"
                                Background="{DynamicResource Brush.SurfaceAlt}"
                                BorderBrush="{DynamicResource Brush.Border}"
                                BorderThickness="1"
                                Click="JournalItem_Click"
                                IsEnabled="{Binding DataContext.CanDrillToTransactions, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                Tag="{Binding}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock FontWeight="SemiBold" Text="{Binding JournalNo}" />
                                    <TextBlock Style="{StaticResource MetaCaptionTextStyle}" Text="{Binding Description}" />
                                    <TextBlock Style="{StaticResource MetaCaptionTextStyle}" Text="{Binding JournalDate, StringFormat=dd MMM yyyy}" />
                                </StackPanel>
                                <StackPanel Grid.Column="1" HorizontalAlignment="Right">
                                    <TextBlock Text="{Binding TotalAmount, StringFormat=N0}" />
                                    <TextBlock Style="{StaticResource MetaCaptionTextStyle}" Text="{Binding Status}" />
                                </StackPanel>
                            </Grid>
                        </Button>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <Border Margin="0,8,0,0"
                    Padding="14"
                    CornerRadius="12"
                    Background="{DynamicResource Brush.SurfaceAlt}"
                    BorderBrush="{DynamicResource Brush.Border}"
                    BorderThickness="1">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding Gl.RecentTransactions.Count}" Value="0">
                                <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <TextBlock Foreground="{DynamicResource Brush.TextSecondary}"
                           Text="Belum ada transaksi jurnal yang dapat ditampilkan." />
            </Border>
        </StackPanel>
    </Border>
</UserControl>
