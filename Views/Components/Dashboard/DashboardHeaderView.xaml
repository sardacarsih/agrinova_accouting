<UserControl x:Class="Accounting.Views.Components.Dashboard.DashboardHeaderView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             UseLayoutRounding="True"
             SnapsToDevicePixels="True">
    <UserControl.Resources>
        <DataTemplate x:Key="DashboardCompanyOptionTemplate">
            <TextBlock Text="{Binding}" />
        </DataTemplate>

        <DataTemplate x:Key="DashboardLocationOptionTemplate">
            <TextBlock Text="{Binding DisplayName}" />
        </DataTemplate>

        <DataTemplate x:Key="DashboardGranularityOptionTemplate">
            <TextBlock Text="{Binding Label}" />
        </DataTemplate>

    </UserControl.Resources>

    <Border Style="{StaticResource DashboardSectionCardStyle}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Row="0"
                        Grid.Column="0">
                <TextBlock Style="{StaticResource DashboardSectionTitleTextStyle}"
                           Text="Accounting Dashboard" />
                <TextBlock Style="{StaticResource DashboardSectionSubtitleTextStyle}"
                           Text="Monitoring keuangan dan operasional harian dengan fokus pada insight dan kontrol." />
                <WrapPanel Margin="0,10,0,0">
                    <Border Style="{StaticResource InlineMetricBadgeStyle}">
                        <TextBlock Text="{Binding Header.CompanyDisplayName}" />
                    </Border>
                    <Border Style="{StaticResource InlineMetricBadgeStyle}">
                        <TextBlock Text="{Binding Header.LocationDisplayName}" />
                    </Border>
                    <Border Style="{StaticResource InlineMetricBadgeStyle}">
                        <TextBlock Text="{Binding Header.CurrencyCode, StringFormat=Currency {0}}" />
                    </Border>
                </WrapPanel>
            </StackPanel>

            <StackPanel Grid.Row="0"
                        Grid.Column="1"
                        HorizontalAlignment="Right">
                <TextBlock HorizontalAlignment="Right"
                           Style="{StaticResource MetaCaptionTextStyle}"
                           Text="{Binding Header.UserDisplayName, StringFormat=User: {0}}" />
                <TextBlock HorizontalAlignment="Right"
                           Margin="0,4,0,0"
                           Style="{StaticResource MetaCaptionTextStyle}"
                           Text="{Binding Header.RoleDisplayName, StringFormat=Role: {0}}" />
                <TextBlock HorizontalAlignment="Right"
                           Margin="0,4,0,0"
                           Style="{StaticResource MetaCaptionTextStyle}"
                           Text="{Binding Header.LastUpdatedText, StringFormat=Updated: {0}}" />
            </StackPanel>

            <WrapPanel Grid.Row="1"
                       Grid.ColumnSpan="2"
                       Margin="0,18,0,0"
                       VerticalAlignment="Center">
                <StackPanel Width="280"
                            Margin="0,0,12,12">
                    <TextBlock Style="{StaticResource FieldLabelTextStyle}" Text="Company" />
                    <ComboBox ItemsSource="{Binding CompanyOptions}"
                              ItemTemplate="{StaticResource DashboardCompanyOptionTemplate}"
                              SelectedItem="{Binding SelectedCompany, Mode=TwoWay}"
                              Style="{StaticResource InputComboBoxStyle}" />
                </StackPanel>
                <StackPanel Width="280"
                            Margin="0,0,12,12">
                    <TextBlock Style="{StaticResource FieldLabelTextStyle}" Text="Location" />
                    <ComboBox ItemsSource="{Binding LocationOptions}"
                              ItemTemplate="{StaticResource DashboardLocationOptionTemplate}"
                              SelectedItem="{Binding SelectedLocation, Mode=TwoWay}"
                              Style="{StaticResource InputComboBoxStyle}" />
                </StackPanel>
                <StackPanel Width="180"
                            Margin="0,0,12,12">
                    <TextBlock Style="{StaticResource FieldLabelTextStyle}" Text="Period Type" />
                    <ComboBox ItemsSource="{Binding GranularityOptions}"
                              ItemTemplate="{StaticResource DashboardGranularityOptionTemplate}"
                              SelectedItem="{Binding SelectedGranularity, Mode=TwoWay}"
                              Style="{StaticResource InputComboBoxStyle}" />
                </StackPanel>
                <StackPanel Width="180"
                            Margin="0,0,12,12">
                    <TextBlock Style="{StaticResource FieldLabelTextStyle}" Text="Period" />
                    <DatePicker SelectedDate="{Binding SelectedPeriod, Mode=TwoWay}" />
                </StackPanel>
                <Button Margin="0,20,12,0"
                        Command="{Binding ApplyFilterCommand}"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Content="Apply Filter" />
                <Button Margin="0,20,12,0"
                        Command="{Binding RefreshCommand}"
                        Style="{StaticResource SecondaryPillButtonStyle}"
                        Content="Refresh" />
                <Button Margin="0,20,0,0"
                        Command="{Binding ExportCommand}"
                        IsEnabled="{Binding CanExport}"
                        Style="{StaticResource SecondaryPillButtonStyle}"
                        Content="Export Excel" />
            </WrapPanel>

            <Border Grid.Row="2"
                    Grid.ColumnSpan="2"
                    Margin="0,14,0,0"
                    Padding="12,10"
                    CornerRadius="10"
                    Background="{DynamicResource Brush.SurfaceAlt}"
                    BorderBrush="{DynamicResource Brush.Border}"
                    BorderThickness="1">
                <DockPanel>
                    <StackPanel DockPanel.Dock="Left"
                                Orientation="Horizontal"
                                VerticalAlignment="Center">
                        <TextBlock FontFamily="Segoe MDL2 Assets"
                                   Margin="0,0,8,0"
                                   Foreground="{DynamicResource Brush.Info}"
                                   Text="&#xE946;" />
                        <TextBlock VerticalAlignment="Center"
                                   Foreground="{DynamicResource Brush.TextSecondary}"
                                   Text="{Binding StatusMessage}" />
                    </StackPanel>
                    <TextBlock DockPanel.Dock="Right"
                               VerticalAlignment="Center"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource Brush.Primary}"
                               Text="Loading..."
                               Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibilityConverter}}" />
                </DockPanel>
            </Border>
        </Grid>
    </Border>
</UserControl>
