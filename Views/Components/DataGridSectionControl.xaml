<UserControl x:Class="Accounting.Views.Components.DataGridSectionControl" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Border Style="{StaticResource CardBorderStyle}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <ContentPresenter Grid.Row="0" Content="{Binding ToolbarContent, RelativeSource={RelativeSource AncestorType=UserControl}}" />
            <ContentPresenter Grid.Row="1" Margin="0,10,0,0" Content="{Binding GridContent, RelativeSource={RelativeSource AncestorType=UserControl}}" />
        </Grid>
    </Border>
</UserControl>