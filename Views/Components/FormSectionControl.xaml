<UserControl x:Class="Accounting.Views.Components.FormSectionControl" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Border Style="{StaticResource CardBorderStyle}" Padding="{DynamicResource Space.CardPaddingCompact}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <TextBlock Grid.Row="0" Style="{StaticResource SectionHeaderTextStyle}" Text="{Binding Title, RelativeSource={RelativeSource AncestorType=UserControl}}" />
            <ContentPresenter Grid.Row="1" Margin="0,12,0,0" Content="{Binding SectionContent, RelativeSource={RelativeSource AncestorType=UserControl}}" />
        </Grid>
    </Border>
</UserControl>