<UserControl x:Class="Accounting.Views.Components.HeaderBarControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:comp="clr-namespace:Accounting.Views.Components"
             UseLayoutRounding="True"
             SnapsToDevicePixels="True">
    <Grid>
        <Border Style="{StaticResource HeaderShellCardStyle}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="{Binding AppDisplayName}" Style="{StaticResource HeaderTitleTextStyle}" />
                        <Border Margin="10,0,0,0" Style="{StaticResource EnvironmentBadgeBorderStyle}">
                            <TextBlock Text="{Binding EnvironmentName}" Style="{StaticResource EnvironmentBadgeTextStyle}" />
                        </Border>
                        <TextBlock Text="{Binding CurrentScopeTitle}" Style="{StaticResource HeaderScopeTextStyle}" />
                    </StackPanel>
                    <TextBlock Margin="2,4,0,0"
                               FontSize="11"
                               Opacity="0.82"
                               Text="{Binding ActiveAccessSummary}"
                               TextTrimming="CharacterEllipsis" />
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Button Margin="0,0,10,0"
                                Command="{Binding OpenWorkContextSelectorCommand}"
                                ToolTip="{Binding WorkContextButtonTooltip}"
                                Style="{StaticResource SecondaryPillButtonStyle}"
                                Content="{Binding WorkContextButtonLabel}" />
                        <Grid Margin="0,0,10,0">
                        <Button x:Name="HeaderThemeSelectorButton"
                                Width="38"
                                Height="34"
                                Padding="0"
                                Style="{StaticResource SecondaryPillButtonStyle}"
                                Click="HeaderThemeSelectorButton_OnClick"
                                ToolTip="Skin">
                            <TextBlock Text="&#xE790;"
                                       FontFamily="Segoe MDL2 Assets"
                                       FontSize="13"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center" />
                        </Button>
                        <Popup x:Name="HeaderThemeSelectorPopup"
                               PlacementTarget="{Binding ElementName=HeaderThemeSelectorButton}"
                               Placement="Bottom"
                               HorizontalOffset="0"
                               VerticalOffset="8"
                               AllowsTransparency="True"
                               PopupAnimation="Fade"
                               StaysOpen="False"
                               Closed="HeaderThemeSelectorPopup_OnClosed">
                            <Border Width="320"
                                    Background="{DynamicResource Brush.Surface}"
                                    BorderBrush="{DynamicResource Brush.Border}"
                                    BorderThickness="1"
                                    CornerRadius="14"
                                    Padding="12">
                                <comp:ThemeSkinsSelectorControl ThemeModeChanged="ThemeSkinsSelectorControl_OnThemeModeChanged" />
                            </Border>
                        </Popup>
                        </Grid>
                        <Button Command="{Binding SignOutCommand}" Style="{StaticResource HeaderUserButtonStyle}" Content="{Binding CurrentUserDisplayName}" />
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>
