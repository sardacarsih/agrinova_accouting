<UserControl x:Class="Accounting.Views.Components.InventoryCategoriesTabControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             UseLayoutRounding="True"
             SnapsToDevicePixels="True">
    <Grid Margin="10" x:Name="CategoryResponsiveGrid">
        <Grid.Resources>
            <Style x:Key="CategoryListPaneStyle" TargetType="DockPanel">
                <Setter Property="Grid.Row" Value="0" />
                <Setter Property="Grid.Column" Value="0" />
                <Setter Property="Grid.RowSpan" Value="3" />
                <Setter Property="Grid.ColumnSpan" Value="1" />
                <Style.Triggers>
                    <DataTrigger Binding="{Binding ElementName=CategoryResponsiveGrid, Path=ActualWidth, Converter={StaticResource WidthLessThanConverter}, ConverterParameter=1120}"
                                 Value="True">
                        <Setter Property="Grid.Row" Value="0" />
                        <Setter Property="Grid.Column" Value="0" />
                        <Setter Property="Grid.RowSpan" Value="1" />
                        <Setter Property="Grid.ColumnSpan" Value="3" />
                    </DataTrigger>
                </Style.Triggers>
            </Style>
            <Style x:Key="CategoryEditorPaneStyle" TargetType="StackPanel">
                <Setter Property="Grid.Row" Value="0" />
                <Setter Property="Grid.Column" Value="2" />
                <Setter Property="Grid.RowSpan" Value="3" />
                <Setter Property="Grid.ColumnSpan" Value="1" />
                <Setter Property="Margin" Value="0" />
                <Style.Triggers>
                    <DataTrigger Binding="{Binding ElementName=CategoryResponsiveGrid, Path=ActualWidth, Converter={StaticResource WidthLessThanConverter}, ConverterParameter=1120}"
                                 Value="True">
                        <Setter Property="Grid.Row" Value="2" />
                        <Setter Property="Grid.Column" Value="0" />
                        <Setter Property="Grid.RowSpan" Value="1" />
                        <Setter Property="Grid.ColumnSpan" Value="3" />
                        <Setter Property="Margin" Value="0,10,0,0" />
                    </DataTrigger>
                </Style.Triggers>
            </Style>
        </Grid.Resources>

        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="10" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1.2*" />
            <ColumnDefinition Width="10" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <DockPanel Style="{StaticResource CategoryListPaneStyle}">
            <Border DockPanel.Dock="Top" Style="{StaticResource AdminWorkspaceHeaderCardStyle}">
                <StackPanel>
                    <TextBlock Text="Master Kategori" Style="{StaticResource SettingsSectionTitleTextStyle}" />
                    <TextBlock Text="Kelola kategori item dan pemetaan akun persediaan."
                               Style="{StaticResource SettingsSectionSubtitleTextStyle}" />
                </StackPanel>
            </Border>
            <WrapPanel DockPanel.Dock="Top" Margin="0,8,0,0">
                <Button Command="{Binding NewCategoryCommand}"
                        IsEnabled="{Binding CanCreateCategory}"
                        ToolTip="{Binding NewCategoryTooltip}"
                        Style="{StaticResource SecondaryPillButtonStyle}"
                        Content="Kategori Baru" />
                <Button Margin="8,0,0,0"
                        Command="{Binding ImportInventoryMasterDataCommand}"
                        IsEnabled="{Binding CanImportInventoryMasterData}"
                        ToolTip="{Binding ImportInventoryMasterDataTooltip}"
                        Style="{StaticResource SecondaryPillButtonStyle}"
                        Content="Import" />
                <Button Margin="8,0,0,0"
                        Command="{Binding DownloadInventoryImportTemplateCommand}"
                        IsEnabled="{Binding CanDownloadInventoryImportTemplate}"
                        ToolTip="{Binding DownloadInventoryImportTemplateTooltip}"
                        Style="{StaticResource SecondaryPillButtonStyle}"
                        Content="Template" />
                <Button Margin="8,0,0,0"
                        Command="{Binding SyncFromMasterCommand}"
                        IsEnabled="{Binding CanSyncFromMaster}"
                        ToolTip="{Binding SyncActionTooltip}"
                        Style="{StaticResource SecondaryPillButtonStyle}"
                        Content="{Binding SyncActionLabel}" />
                <Button Margin="8,0,0,0" Command="{Binding RefreshCommand}" Style="{StaticResource SecondaryPillButtonStyle}" Content="Muat Ulang" />
            </WrapPanel>
            <ContentControl DockPanel.Dock="Top"
                            Margin="0,8,0,0"
                            Content="{Binding MasterImportErrorPanel}"
                            ContentTemplate="{StaticResource InventoryImportErrorPanelTemplate}"
                            Visibility="{Binding MasterImportErrorPanel.HasErrors, Converter={StaticResource BoolToVisibilityConverter}}" />
            <DataGrid Style="{StaticResource EnterpriseDataGridStyle}"
                      Margin="0,8,0,0"
                      ItemsSource="{Binding Categories}"
                      SelectedItem="{Binding SelectedCategory, Mode=TwoWay}"
                      AutoGenerateColumns="False"
                      MinHeight="220"
                      IsReadOnly="True">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Kode" Binding="{Binding Code}" Width="120" />
                    <DataGridTextColumn Header="Nama Kategori" Binding="{Binding Name}" Width="*" />
                    <DataGridTextColumn Header="Kode Akun" Binding="{Binding AccountCode}" Width="140" />
                    <DataGridCheckBoxColumn Header="Aktif" Binding="{Binding IsActive}" Width="70" />
                </DataGrid.Columns>
            </DataGrid>
        </DockPanel>

        <StackPanel Style="{StaticResource CategoryEditorPaneStyle}">
            <TextBlock Text="Editor Kategori" FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource Brush.TextPrimary}" />
            <Border Margin="0,8,0,0"
                    Padding="8"
                    Background="{DynamicResource Brush.SurfaceAlt}"
                    BorderBrush="{DynamicResource Brush.BorderSoft}"
                    BorderThickness="1"
                    CornerRadius="6"
                    Visibility="{Binding IsInventoryReadOnlyByMasterPolicy, Converter={StaticResource BoolToVisibilityConverter}}">
                <TextBlock Foreground="{DynamicResource Brush.TextMuted}">
                    <Run Text="Read-only. Master company: " />
                    <Run Text="{Binding MasterCompanyLabel, Mode=OneWay}" />
                </TextBlock>
            </Border>
            <TextBlock Margin="0,10,0,0" Style="{StaticResource FieldLabelTextStyle}" Text="Kode Kategori" />
            <TextBox Margin="0,6,0,0"
                     IsEnabled="{Binding CanSaveCategory}"
                     ToolTip="{Binding SaveCategoryTooltip}"
                     Text="{Binding SelectedCategory.Code, UpdateSourceTrigger=PropertyChanged}"
                     Style="{StaticResource InputTextBoxStyle}" />
            <TextBlock Margin="0,10,0,0" Style="{StaticResource FieldLabelTextStyle}" Text="Nama Kategori" />
            <TextBox Margin="0,6,0,0"
                     IsEnabled="{Binding CanSaveCategory}"
                     ToolTip="{Binding SaveCategoryTooltip}"
                     Text="{Binding SelectedCategory.Name, UpdateSourceTrigger=PropertyChanged}"
                     Style="{StaticResource InputTextBoxStyle}" />
            <TextBlock Margin="0,10,0,0" Style="{StaticResource FieldLabelTextStyle}" Text="Kode Akun (COA)" />
            <ComboBox Margin="0,6,0,0"
                      Style="{StaticResource InputComboBoxStyle}"
                      IsEnabled="{Binding CanSaveCategory}"
                      ToolTip="{Binding SaveCategoryTooltip}"
                      ItemsSource="{Binding Accounts}"
                      SelectedValuePath="Code"
                      SelectedValue="{Binding SelectedCategory.AccountCode, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                      IsEditable="True"
                      IsTextSearchEnabled="True"
                      TextSearch.TextPath="Code">
                <ComboBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock>
                            <Run Text="{Binding Code, Mode=OneWay}" />
                            <Run Text=" — " />
                            <Run Text="{Binding Name, Mode=OneWay}" />
                        </TextBlock>
                    </DataTemplate>
                </ComboBox.ItemTemplate>
            </ComboBox>
            <CheckBox Margin="0,8,0,0"
                      IsEnabled="{Binding CanSaveCategory}"
                      ToolTip="{Binding SaveCategoryTooltip}"
                      IsChecked="{Binding SelectedCategory.IsActive}"
                      Style="{StaticResource CompactCheckBoxStyle}"
                      Content="Aktif" />
            <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                <Button Command="{Binding SaveCategoryCommand}"
                        IsEnabled="{Binding CanSaveCategory}"
                        ToolTip="{Binding SaveCategoryTooltip}"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Content="Simpan Kategori" />
                <Button Margin="8,0,0,0"
                        Command="{Binding DeactivateCategoryCommand}"
                        IsEnabled="{Binding CanDeactivateCategory}"
                        ToolTip="{Binding DeactivateCategoryTooltip}"
                        Style="{StaticResource SecondaryPillButtonStyle}"
                        Content="Nonaktifkan" />
            </StackPanel>
        </StackPanel>
    </Grid>
</UserControl>
