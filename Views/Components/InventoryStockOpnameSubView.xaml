<UserControl x:Class="Accounting.Views.Components.InventoryStockOpnameSubView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             UseLayoutRounding="True"
             SnapsToDevicePixels="True">
    <Grid Margin="10" x:Name="StockOpnameResponsiveGrid">
        <Grid.Resources>
            <Style x:Key="StockOpnameListPaneStyle" TargetType="DockPanel">
                <Setter Property="Grid.Row" Value="0" />
                <Setter Property="Grid.Column" Value="0" />
                <Setter Property="Grid.RowSpan" Value="3" />
                <Setter Property="Grid.ColumnSpan" Value="1" />
                <Style.Triggers>
                    <DataTrigger Binding="{Binding ElementName=StockOpnameResponsiveGrid, Path=ActualWidth, Converter={StaticResource WidthLessThanConverter}, ConverterParameter=1220}"
                                 Value="True">
                        <Setter Property="Grid.Row" Value="0" />
                        <Setter Property="Grid.Column" Value="0" />
                        <Setter Property="Grid.RowSpan" Value="1" />
                        <Setter Property="Grid.ColumnSpan" Value="3" />
                    </DataTrigger>
                </Style.Triggers>
            </Style>
            <Style x:Key="StockOpnameEditorPaneStyle" TargetType="Grid">
                <Setter Property="Grid.Row" Value="0" />
                <Setter Property="Grid.Column" Value="2" />
                <Setter Property="Grid.RowSpan" Value="3" />
                <Setter Property="Grid.ColumnSpan" Value="1" />
                <Setter Property="Margin" Value="0" />
                <Style.Triggers>
                    <DataTrigger Binding="{Binding ElementName=StockOpnameResponsiveGrid, Path=ActualWidth, Converter={StaticResource WidthLessThanConverter}, ConverterParameter=1220}"
                                 Value="True">
                        <Setter Property="Grid.Row" Value="2" />
                        <Setter Property="Grid.Column" Value="0" />
                        <Setter Property="Grid.RowSpan" Value="1" />
                        <Setter Property="Grid.ColumnSpan" Value="3" />
                        <Setter Property="Margin" Value="0,10,0,0" />
                    </DataTrigger>
                </Style.Triggers>
            </Style>
        </Grid.Resources>

        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="10" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1.1*" />
            <ColumnDefinition Width="10" />
            <ColumnDefinition Width="1.5*" />
        </Grid.ColumnDefinitions>

        <DockPanel Style="{StaticResource StockOpnameListPaneStyle}">
            <Border DockPanel.Dock="Top" Style="{StaticResource AdminWorkspaceHeaderCardStyle}">
                <StackPanel>
                    <TextBlock Text="Stock Opname" Style="{StaticResource SettingsSectionTitleTextStyle}" />
                    <TextBlock Text="Bandingkan stok sistem dan aktual untuk membuat penyesuaian."
                               Style="{StaticResource SettingsSectionSubtitleTextStyle}" />
                </StackPanel>
            </Border>
            <Border DockPanel.Dock="Top" Margin="0,8,0,0" Style="{StaticResource AdminToolbarCardStyle}">
                <WrapPanel>
                    <Button Command="{Binding NewStockOpnameCommand}"
                            IsEnabled="{Binding CanCreateStockOpname}"
                            ToolTip="{Binding NewStockOpnameTooltip}"
                            Style="{StaticResource SecondaryPillButtonStyle}"
                            Content="Opname Baru" />
                </WrapPanel>
            </Border>
            <Border DockPanel.Dock="Top" Margin="0,8,0,0" Style="{StaticResource AdminToolbarCardStyle}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="8" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0"
                             Text="{Binding StockOpnameSearchKeyword, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource InputTextBoxStyle}" />
                    <Button Grid.Column="2"
                            Command="{Binding SearchStockOpnameCommand}"
                            Style="{StaticResource SecondaryPillButtonStyle}"
                            Content="Cari" />
                </Grid>
            </Border>
            <DataGrid Style="{StaticResource EnterpriseDataGridStyle}"
                      Margin="0,8,0,0"
                      ItemsSource="{Binding StockOpnameList}"
                      AutoGenerateColumns="False"
                      MinHeight="220"
                      IsReadOnly="True">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="No." Binding="{Binding OpnameNo}" Width="120" />
                    <DataGridTextColumn Header="Tanggal" Binding="{Binding OpnameDate, StringFormat=dd/MM/yyyy}" Width="100" />
                    <DataGridTextColumn Header="Gudang" Binding="{Binding WarehouseName}" Width="120" />
                    <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="90" />
                    <DataGridTemplateColumn Header="Aksi" Width="90">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Button Command="{Binding DataContext.LoadStockOpnameCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        CommandParameter="{Binding}"
                                        Style="{StaticResource SecondaryPillButtonStyle}"
                                        Content="Muat" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </DockPanel>

        <Grid Style="{StaticResource StockOpnameEditorPaneStyle}"
              IsEnabled="{Binding CanOperateCurrentPeriodTransactions}"
              ToolTip="{Binding InventoryPeriodActionTooltip}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Style="{StaticResource AdminToolbarCardStyle}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="Editor Opname"
                                   FontSize="15"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource Brush.TextPrimary}" />
                        <TextBlock Margin="0,4,0,0"
                                   Foreground="{DynamicResource Brush.TextMuted}"
                                   Text="Generate baris lalu isi Qty Aktual per item." />
                    </StackPanel>
                    <Border Grid.Column="1" Style="{StaticResource InlineMetricBadgeStyle}">
                        <TextBlock Foreground="{DynamicResource Brush.TextSecondary}"
                                   Text="{Binding StockOpnameHeader.Status}" />
                    </Border>
                </Grid>
            </Border>

            <Grid Grid.Row="1" Margin="0,8,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="10" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Style="{StaticResource FieldLabelTextStyle}" Text="No. Opname" />
                    <TextBox Margin="0,6,0,0" Text="{Binding StockOpnameHeader.OpnameNo, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource InputTextBoxStyle}" />
                    <TextBlock Margin="0,8,0,0" Style="{StaticResource FieldLabelTextStyle}" Text="Tanggal" />
                    <DatePicker Margin="0,6,0,0" SelectedDate="{Binding StockOpnameHeader.OpnameDate, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Height="38" />
                    <TextBlock Margin="0,8,0,0" Style="{StaticResource FieldLabelTextStyle}" Text="Gudang" />
                    <ComboBox Margin="0,6,0,0"
                              Style="{StaticResource InputComboBoxStyle}"
                              ItemsSource="{Binding Warehouses}"
                              SelectedValuePath="Id"
                              DisplayMemberPath="Name"
                              SelectedValue="{Binding StockOpnameHeader.WarehouseId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                </StackPanel>
                <StackPanel Grid.Column="2">
                    <TextBlock Style="{StaticResource FieldLabelTextStyle}" Text="Keterangan" />
                    <TextBox Margin="0,6,0,0" Text="{Binding StockOpnameHeader.Description, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource InputTextBoxStyle}" />
                    <TextBlock Margin="0,8,0,0" Style="{StaticResource FieldLabelTextStyle}" Text="Status" />
                    <TextBox Margin="0,6,0,0" Text="{Binding StockOpnameHeader.Status}" IsReadOnly="True" Style="{StaticResource InputTextBoxStyle}" />
                </StackPanel>
            </Grid>

            <DataGrid Grid.Row="2"
                      Style="{StaticResource EnterpriseDataGridStyle}"
                      Margin="0,8,0,0"
                      ItemsSource="{Binding StockOpnameLines}"
                      AutoGenerateColumns="False"
                      MinHeight="220"
                      CanUserAddRows="False">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="No" Binding="{Binding LineNo}" Width="50" IsReadOnly="True" />
                    <DataGridTextColumn Header="Kode" Binding="{Binding ItemCode}" Width="110" IsReadOnly="True" />
                    <DataGridTextColumn Header="Item" Binding="{Binding ItemName}" Width="*" IsReadOnly="True" />
                    <DataGridTextColumn Header="UoM" Binding="{Binding Uom}" Width="70" IsReadOnly="True" />
                    <DataGridTextColumn Header="Qty Sistem" Binding="{Binding SystemQty, StringFormat=N2}" Width="90" IsReadOnly="True" />
                    <DataGridTextColumn Header="Qty Aktual" Binding="{Binding ActualQty, UpdateSourceTrigger=PropertyChanged, StringFormat=N2}" Width="90" />
                    <DataGridTextColumn Header="Selisih" Binding="{Binding DifferenceQty, StringFormat=N2}" Width="90" IsReadOnly="True" />
                    <DataGridTextColumn Header="Catatan" Binding="{Binding Notes, UpdateSourceTrigger=PropertyChanged}" Width="140" />
                </DataGrid.Columns>
            </DataGrid>

            <Border Grid.Row="3" Margin="0,10,0,0" Style="{StaticResource StickyActionBarStyle}">
                <WrapPanel>
                    <Button Command="{Binding GenerateOpnameLinesCommand}" IsEnabled="{Binding CanGenerateStockOpnameLines}" ToolTip="{Binding GenerateStockOpnameLinesTooltip}" Style="{StaticResource SecondaryPillButtonStyle}" Content="Generate Baris" />
                    <Button Margin="8,0,0,0" Command="{Binding SaveStockOpnameDraftCommand}" IsEnabled="{Binding CanSaveStockOpnameDraft}" ToolTip="{Binding SaveStockOpnameDraftTooltip}" Style="{StaticResource PrimaryButtonStyle}" Content="Simpan Draft" />
                    <Button Margin="8,0,0,0" Command="{Binding SubmitStockOpnameCommand}" IsEnabled="{Binding CanSubmitStockOpname}" ToolTip="{Binding SubmitStockOpnameTooltip}" Style="{StaticResource SecondaryPillButtonStyle}" Content="Ajukan" />
                    <Button Margin="8,0,0,0" Command="{Binding ApproveStockOpnameCommand}" IsEnabled="{Binding CanApproveStockOpname}" ToolTip="{Binding ApproveStockOpnameTooltip}" Style="{StaticResource SecondaryPillButtonStyle}" Content="Setujui" />
                    <Button Margin="8,0,0,0" Command="{Binding PostStockOpnameCommand}" IsEnabled="{Binding CanPostStockOpname}" ToolTip="{Binding PostStockOpnameTooltip}" Style="{StaticResource SecondaryPillButtonStyle}" Content="Posting" />
                </WrapPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
