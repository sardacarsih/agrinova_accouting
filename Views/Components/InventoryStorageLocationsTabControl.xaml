<UserControl x:Class="Accounting.Views.Components.InventoryStorageLocationsTabControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             UseLayoutRounding="True"
             SnapsToDevicePixels="True">
    <Grid Margin="10" x:Name="StorageLocationResponsiveGrid">
        <Grid.Resources>
            <Style x:Key="StorageLocationListPaneStyle" TargetType="DockPanel">
                <Setter Property="Grid.Row" Value="0" />
                <Setter Property="Grid.Column" Value="0" />
                <Setter Property="Grid.RowSpan" Value="3" />
                <Setter Property="Grid.ColumnSpan" Value="1" />
                <Style.Triggers>
                    <DataTrigger Binding="{Binding ElementName=StorageLocationResponsiveGrid, Path=ActualWidth, Converter={StaticResource WidthLessThanConverter}, ConverterParameter=1120}"
                                 Value="True">
                        <Setter Property="Grid.Row" Value="0" />
                        <Setter Property="Grid.Column" Value="0" />
                        <Setter Property="Grid.RowSpan" Value="1" />
                        <Setter Property="Grid.ColumnSpan" Value="3" />
                    </DataTrigger>
                </Style.Triggers>
            </Style>
            <Style x:Key="StorageLocationEditorPaneStyle" TargetType="StackPanel">
                <Setter Property="Grid.Row" Value="0" />
                <Setter Property="Grid.Column" Value="2" />
                <Setter Property="Grid.RowSpan" Value="3" />
                <Setter Property="Grid.ColumnSpan" Value="1" />
                <Setter Property="Margin" Value="0" />
                <Style.Triggers>
                    <DataTrigger Binding="{Binding ElementName=StorageLocationResponsiveGrid, Path=ActualWidth, Converter={StaticResource WidthLessThanConverter}, ConverterParameter=1120}"
                                 Value="True">
                        <Setter Property="Grid.Row" Value="2" />
                        <Setter Property="Grid.Column" Value="0" />
                        <Setter Property="Grid.RowSpan" Value="1" />
                        <Setter Property="Grid.ColumnSpan" Value="3" />
                        <Setter Property="Margin" Value="0,10,0,0" />
                    </DataTrigger>
                </Style.Triggers>
            </Style>
        </Grid.Resources>

        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="10" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1.2*" />
            <ColumnDefinition Width="10" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <DockPanel Style="{StaticResource StorageLocationListPaneStyle}">
            <Border DockPanel.Dock="Top" Style="{StaticResource AdminWorkspaceHeaderCardStyle}">
                <StackPanel>
                    <TextBlock Text="Lokasi Penyimpanan" Style="{StaticResource SettingsSectionTitleTextStyle}" />
                    <TextBlock Text="Kelola slot penyimpanan internal per gudang untuk kebutuhan operasional dan pelaporan."
                               Style="{StaticResource SettingsSectionSubtitleTextStyle}" />
                </StackPanel>
            </Border>
            <Border DockPanel.Dock="Top" Margin="0,8,0,0" Style="{StaticResource AdminToolbarCardStyle}">
                <StackPanel Orientation="Horizontal">
                    <Button Command="{Binding NewStorageLocationCommand}"
                            IsEnabled="{Binding CanCreateStorageLocation}"
                            ToolTip="{Binding NewStorageLocationTooltip}"
                            Style="{StaticResource SecondaryPillButtonStyle}"
                            Content="Lokasi Baru" />
                    <Button Margin="8,0,0,0"
                            Command="{Binding RefreshCommand}"
                            Style="{StaticResource SecondaryPillButtonStyle}"
                            Content="Muat Ulang" />
                </StackPanel>
            </Border>
            <DataGrid Style="{StaticResource EnterpriseDataGridStyle}"
                      Margin="0,8,0,0"
                      ItemsSource="{Binding StorageLocations}"
                      SelectedItem="{Binding SelectedStorageLocation, Mode=TwoWay}"
                      AutoGenerateColumns="False"
                      MinHeight="220"
                      IsReadOnly="True">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Gudang" Binding="{Binding WarehouseName}" Width="170" />
                    <DataGridTextColumn Header="Kode" Binding="{Binding Code}" Width="110" />
                    <DataGridTextColumn Header="Nama Lokasi" Binding="{Binding Name}" Width="*" />
                    <DataGridTextColumn Header="Lokasi" Binding="{Binding LocationName}" Width="150" />
                    <DataGridCheckBoxColumn Header="Aktif" Binding="{Binding IsActive}" Width="70" />
                </DataGrid.Columns>
            </DataGrid>
        </DockPanel>

        <StackPanel Style="{StaticResource StorageLocationEditorPaneStyle}">
            <Border Style="{StaticResource AdminToolbarCardStyle}">
                <StackPanel>
                    <TextBlock Text="Editor Lokasi Penyimpanan"
                               FontSize="15"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource Brush.TextPrimary}" />
                    <TextBlock Margin="0,4,0,0"
                               Foreground="{DynamicResource Brush.TextMuted}"
                               Text="Pilih gudang induk lebih dulu, lalu isi kode dan nama lokasi penyimpanan." />
                </StackPanel>
            </Border>
            <TextBlock Margin="0,10,0,0" Style="{StaticResource FieldLabelTextStyle}" Text="Gudang" />
            <ComboBox Margin="0,6,0,0"
                      IsEnabled="{Binding CanSaveStorageLocation}"
                      ToolTip="{Binding SaveStorageLocationTooltip}"
                      Style="{StaticResource InputComboBoxStyle}"
                      ItemsSource="{Binding Warehouses}"
                      SelectedValue="{Binding SelectedStorageLocation.WarehouseId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                      SelectedValuePath="Id"
                      DisplayMemberPath="Name" />
            <TextBlock Margin="0,10,0,0" Style="{StaticResource FieldLabelTextStyle}" Text="Kode Lokasi" />
            <TextBox Margin="0,6,0,0"
                     IsEnabled="{Binding CanSaveStorageLocation}"
                     ToolTip="{Binding SaveStorageLocationTooltip}"
                     Text="{Binding SelectedStorageLocation.Code, UpdateSourceTrigger=PropertyChanged}"
                     Style="{StaticResource InputTextBoxStyle}" />
            <TextBlock Margin="0,10,0,0" Style="{StaticResource FieldLabelTextStyle}" Text="Nama Lokasi" />
            <TextBox Margin="0,6,0,0"
                     IsEnabled="{Binding CanSaveStorageLocation}"
                     ToolTip="{Binding SaveStorageLocationTooltip}"
                     Text="{Binding SelectedStorageLocation.Name, UpdateSourceTrigger=PropertyChanged}"
                     Style="{StaticResource InputTextBoxStyle}" />
            <CheckBox Margin="0,8,0,0"
                      IsEnabled="{Binding CanSaveStorageLocation}"
                      ToolTip="{Binding SaveStorageLocationTooltip}"
                      IsChecked="{Binding SelectedStorageLocation.IsActive}"
                      Style="{StaticResource CompactCheckBoxStyle}"
                      Content="Aktif" />
            <Border Margin="0,12,0,0" Style="{StaticResource StickyActionBarStyle}">
                <WrapPanel>
                    <Button Command="{Binding SaveStorageLocationCommand}"
                            IsEnabled="{Binding CanSaveStorageLocation}"
                            ToolTip="{Binding SaveStorageLocationTooltip}"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Content="Simpan Lokasi" />
                    <Button Margin="8,0,0,0"
                            Command="{Binding DeactivateStorageLocationCommand}"
                            IsEnabled="{Binding CanDeactivateStorageLocation}"
                            ToolTip="{Binding DeactivateStorageLocationTooltip}"
                            Style="{StaticResource SecondaryPillButtonStyle}"
                            Content="Nonaktifkan" />
                </WrapPanel>
            </Border>
        </StackPanel>
    </Grid>
</UserControl>
