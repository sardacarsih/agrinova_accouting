<UserControl x:Class="Accounting.Views.Components.InventoryTransferSubView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             UseLayoutRounding="True"
             SnapsToDevicePixels="True">
    <Grid Margin="10">
        <TabControl SelectedIndex="{Binding SelectedTransferTabIndex, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
            <TabItem Header="Daftar">
                <DockPanel Margin="0,8,0,0">
            <Border DockPanel.Dock="Top" Style="{StaticResource AdminWorkspaceHeaderCardStyle}">
                <StackPanel>
                    <TextBlock Text="Transfer Antar Gudang" Style="{StaticResource SettingsSectionTitleTextStyle}" />
                    <TextBlock Text="Pindahkan stok dari gudang asal ke gudang tujuan."
                               Style="{StaticResource SettingsSectionSubtitleTextStyle}" />
                </StackPanel>
            </Border>
            <Border DockPanel.Dock="Top" Margin="0,8,0,0" Style="{StaticResource AdminToolbarCardStyle}">
                <WrapPanel>
                    <Button Command="{Binding NewTransferCommand}"
                            IsEnabled="{Binding CanCreateTransfer}"
                            ToolTip="{Binding NewTransferTooltip}"
                            Style="{StaticResource SecondaryPillButtonStyle}"
                            Content="Transaksi Baru" />
                </WrapPanel>
            </Border>
            <Border DockPanel.Dock="Top" Margin="0,8,0,0" Style="{StaticResource AdminToolbarCardStyle}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="8" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0"
                             Text="{Binding TransferSearchKeyword, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource InputTextBoxStyle}" />
                    <Button Grid.Column="2"
                            Command="{Binding SearchTransferCommand}"
                            Style="{StaticResource SecondaryPillButtonStyle}"
                            Content="Cari" />
                </Grid>
            </Border>
            <DataGrid Style="{StaticResource EnterpriseDataGridStyle}"
                      Margin="0,8,0,0"
                      ItemsSource="{Binding TransferTransactionList}"
                      AutoGenerateColumns="False"
                      MinHeight="220"
                      IsReadOnly="True">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="No." Binding="{Binding TransactionNo}" Width="120" />
                    <DataGridTextColumn Header="Tanggal" Binding="{Binding TransactionDate, StringFormat=dd/MM/yyyy}" Width="100" />
                    <DataGridTextColumn Header="Gudang" Binding="{Binding WarehouseName}" Width="150" />
                    <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="90" />
                    <DataGridTextColumn Header="Qty" Binding="{Binding TotalQty, StringFormat=N2}" Width="90" />
                    <DataGridTemplateColumn Header="Aksi" Width="90">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Button Command="{Binding DataContext.LoadTransferCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        CommandParameter="{Binding}"
                                        Style="{StaticResource SecondaryPillButtonStyle}"
                                        Content="Muat" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
                </DockPanel>
            </TabItem>

            <TabItem Header="Input">
                <Grid Margin="0,8,0,0"
                      IsEnabled="{Binding CanOperateCurrentPeriodTransactions}"
                      ToolTip="{Binding InventoryPeriodActionTooltip}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Style="{StaticResource AdminToolbarCardStyle}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="Editor Transfer"
                                   FontSize="15"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource Brush.TextPrimary}" />
                        <TextBlock Margin="0,4,0,0"
                                   Foreground="{DynamicResource Brush.TextMuted}"
                                   Text="Pilih gudang asal dan gudang tujuan yang berbeda." />
                    </StackPanel>
                    <Border Grid.Column="1" Style="{StaticResource InlineMetricBadgeStyle}">
                        <TextBlock Foreground="{DynamicResource Brush.TextSecondary}"
                                   Text="{Binding TransferHeader.Status}" />
                    </Border>
                </Grid>
            </Border>

            <Grid Grid.Row="1" Margin="0,8,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="10" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid Grid.Column="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="10" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Style="{StaticResource FieldLabelTextStyle}" Text="No. Transaksi" />
                        <TextBox Margin="0,6,0,0" Text="{Binding TransferHeader.TransactionNo, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource InputTextBoxStyle}" />
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Style="{StaticResource FieldLabelTextStyle}" Text="Tanggal" />
                        <DatePicker Margin="0,6,0,0" SelectedDate="{Binding TransferHeader.TransactionDate, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Height="38" />
                    </StackPanel>
                </Grid>
            </Grid>

            <Grid Grid.Row="2" Margin="0,8,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="10" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Style="{StaticResource FieldLabelTextStyle}" Text="Referensi" />
                    <TextBox Margin="0,6,0,0" Text="{Binding TransferHeader.ReferenceNo, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource InputTextBoxStyle}" />
                </StackPanel>
                <StackPanel Grid.Column="2">
                    <TextBlock Style="{StaticResource FieldLabelTextStyle}" Text="Keterangan" />
                    <TextBox Margin="0,6,0,0" Text="{Binding TransferHeader.Description, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource InputTextBoxStyle}" />
                </StackPanel>
            </Grid>

            <DataGrid Grid.Row="3"
                      Style="{StaticResource JournalLikeDataGridStyle}"
                      Margin="0,8,0,0"
                      ItemsSource="{Binding TransferLines}"
                      AutoGenerateColumns="False"
                      MinHeight="220"
                      CanUserAddRows="False">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="No" Binding="{Binding LineNo}" Width="50" IsReadOnly="True" />
                    <DataGridTemplateColumn Header="Kode Item" Width="160">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Grid>
                                    <TextBox x:Name="ItemLookupTextBox"
                                             Text="{Binding ItemLookupText, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource JournalLikeDataGridEditingTextBoxStyle}"
                                             VerticalAlignment="Center"
                                             PreviewKeyDown="LookupTextBox_OnPreviewKeyDown"
                                             PreviewLostKeyboardFocus="LookupTextBox_OnPreviewLostKeyboardFocus"
                                             Tag="ItemLookup" />
                                    <Popup IsOpen="{Binding IsItemLookupPopupOpen, Mode=TwoWay}"
                                           Placement="Bottom"
                                           PlacementTarget="{Binding ElementName=ItemLookupTextBox}"
                                           AllowsTransparency="True"
                                           StaysOpen="False"
                                           PopupAnimation="Fade">
                                        <Border Style="{StaticResource InventoryLookupPopupBorderStyle}"
                                                MinWidth="{Binding ElementName=ItemLookupTextBox, Path=ActualWidth}"
                                                MaxWidth="360"
                                                MaxHeight="240">
                                            <ListBox ItemsSource="{Binding ItemLookupSuggestions}"
                                                     SelectedItem="{Binding SelectedItemLookupSuggestion, Mode=TwoWay}"
                                                     Style="{StaticResource InventoryLookupListBoxStyle}"
                                                     ItemContainerStyle="{StaticResource InventoryLookupListBoxItemStyle}"
                                                     PreviewKeyDown="LookupListBox_OnPreviewKeyDown"
                                                     MouseLeftButtonUp="LookupListBox_OnMouseLeftButtonUp"
                                                     MouseDoubleClick="LookupListBox_OnMouseDoubleClick"
                                                     Tag="ItemLookup">
                                                <ListBox.ItemTemplate>
                                                    <DataTemplate>
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="120" />
                                                                <ColumnDefinition Width="8" />
                                                                <ColumnDefinition Width="*" />
                                                            </Grid.ColumnDefinitions>
                                                            <TextBlock Grid.Column="0"
                                                                       FontWeight="SemiBold"
                                                                       Foreground="{DynamicResource Brush.TextPrimary}"
                                                                       Text="{Binding Code}" />
                                                            <TextBlock Grid.Column="2"
                                                                       Foreground="{DynamicResource Brush.TextSecondary}"
                                                                       Text="{Binding Name}" />
                                                        </Grid>
                                                    </DataTemplate>
                                                </ListBox.ItemTemplate>
                                            </ListBox>
                                        </Border>
                                    </Popup>
                                </Grid>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn Header="Nama Item" Binding="{Binding ItemName}" Width="220" IsReadOnly="True" />
                    <DataGridTemplateColumn Header="Gudang Asal" Width="180">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Grid>
                                    <TextBox x:Name="WarehouseLookupTextBox"
                                             Text="{Binding WarehouseLookupText, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource JournalLikeDataGridEditingTextBoxStyle}"
                                             VerticalAlignment="Center"
                                             PreviewKeyDown="LookupTextBox_OnPreviewKeyDown"
                                             PreviewLostKeyboardFocus="LookupTextBox_OnPreviewLostKeyboardFocus"
                                             Tag="WarehouseLookup" />
                                    <Popup IsOpen="{Binding IsWarehouseLookupPopupOpen, Mode=TwoWay}"
                                           Placement="Bottom"
                                           PlacementTarget="{Binding ElementName=WarehouseLookupTextBox}"
                                           AllowsTransparency="True"
                                           StaysOpen="False"
                                           PopupAnimation="Fade">
                                        <Border Style="{StaticResource InventoryLookupPopupBorderStyle}"
                                                MinWidth="{Binding ElementName=WarehouseLookupTextBox, Path=ActualWidth}"
                                                MaxWidth="360"
                                                MaxHeight="240">
                                            <ListBox ItemsSource="{Binding WarehouseLookupSuggestions}"
                                                     SelectedItem="{Binding SelectedWarehouseLookupSuggestion, Mode=TwoWay}"
                                                     Style="{StaticResource InventoryLookupListBoxStyle}"
                                                     ItemContainerStyle="{StaticResource InventoryLookupListBoxItemStyle}"
                                                     PreviewKeyDown="LookupListBox_OnPreviewKeyDown"
                                                     MouseLeftButtonUp="LookupListBox_OnMouseLeftButtonUp"
                                                     MouseDoubleClick="LookupListBox_OnMouseDoubleClick"
                                                     Tag="WarehouseLookup">
                                                <ListBox.ItemTemplate>
                                                    <DataTemplate>
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="120" />
                                                                <ColumnDefinition Width="8" />
                                                                <ColumnDefinition Width="*" />
                                                            </Grid.ColumnDefinitions>
                                                            <TextBlock Grid.Column="0"
                                                                       FontWeight="SemiBold"
                                                                       Foreground="{DynamicResource Brush.TextPrimary}"
                                                                       Text="{Binding Code}" />
                                                            <TextBlock Grid.Column="2"
                                                                       Foreground="{DynamicResource Brush.TextSecondary}"
                                                                       Text="{Binding Name}" />
                                                        </Grid>
                                                    </DataTemplate>
                                                </ListBox.ItemTemplate>
                                            </ListBox>
                                        </Border>
                                    </Popup>
                                </Grid>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTemplateColumn Header="Gudang Tujuan" Width="180">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Grid>
                                    <TextBox x:Name="DestinationWarehouseLookupTextBox"
                                             Text="{Binding DestinationWarehouseLookupText, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource JournalLikeDataGridEditingTextBoxStyle}"
                                             VerticalAlignment="Center"
                                             PreviewKeyDown="LookupTextBox_OnPreviewKeyDown"
                                             PreviewLostKeyboardFocus="LookupTextBox_OnPreviewLostKeyboardFocus"
                                             Tag="DestinationWarehouseLookup" />
                                    <Popup IsOpen="{Binding IsDestinationWarehouseLookupPopupOpen, Mode=TwoWay}"
                                           Placement="Bottom"
                                           PlacementTarget="{Binding ElementName=DestinationWarehouseLookupTextBox}"
                                           AllowsTransparency="True"
                                           StaysOpen="False"
                                           PopupAnimation="Fade">
                                        <Border Style="{StaticResource InventoryLookupPopupBorderStyle}"
                                                MinWidth="{Binding ElementName=DestinationWarehouseLookupTextBox, Path=ActualWidth}"
                                                MaxWidth="360"
                                                MaxHeight="240">
                                            <ListBox ItemsSource="{Binding DestinationWarehouseLookupSuggestions}"
                                                     SelectedItem="{Binding SelectedDestinationWarehouseLookupSuggestion, Mode=TwoWay}"
                                                     Style="{StaticResource InventoryLookupListBoxStyle}"
                                                     ItemContainerStyle="{StaticResource InventoryLookupListBoxItemStyle}"
                                                     PreviewKeyDown="LookupListBox_OnPreviewKeyDown"
                                                     MouseLeftButtonUp="LookupListBox_OnMouseLeftButtonUp"
                                                     MouseDoubleClick="LookupListBox_OnMouseDoubleClick"
                                                     Tag="DestinationWarehouseLookup">
                                                <ListBox.ItemTemplate>
                                                    <DataTemplate>
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="120" />
                                                                <ColumnDefinition Width="8" />
                                                                <ColumnDefinition Width="*" />
                                                            </Grid.ColumnDefinitions>
                                                            <TextBlock Grid.Column="0"
                                                                       FontWeight="SemiBold"
                                                                       Foreground="{DynamicResource Brush.TextPrimary}"
                                                                       Text="{Binding Code}" />
                                                            <TextBlock Grid.Column="2"
                                                                       Foreground="{DynamicResource Brush.TextSecondary}"
                                                                       Text="{Binding Name}" />
                                                        </Grid>
                                                    </DataTemplate>
                                                </ListBox.ItemTemplate>
                                            </ListBox>
                                        </Border>
                                    </Popup>
                                </Grid>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn Header="Qty"
                                        Binding="{Binding Qty, UpdateSourceTrigger=PropertyChanged, StringFormat=N2}"
                                        Width="90"
                                        ElementStyle="{StaticResource JournalLikeDataGridNumericTextStyle}"
                                        EditingElementStyle="{StaticResource JournalLikeDataGridNumericEditingTextBoxStyle}" />
                    <DataGridTextColumn Header="Harga"
                                        Binding="{Binding UnitCost, UpdateSourceTrigger=PropertyChanged, StringFormat=N2}"
                                        Width="100"
                                        IsReadOnly="True"
                                        ElementStyle="{StaticResource JournalLikeDataGridNumericTextStyle}"
                                        EditingElementStyle="{StaticResource JournalLikeDataGridNumericEditingTextBoxStyle}" />
                    <DataGridTextColumn Header="Catatan"
                                        Binding="{Binding Notes, UpdateSourceTrigger=PropertyChanged}"
                                        Width="*"
                                        EditingElementStyle="{StaticResource JournalLikeDataGridEditingTextBoxStyle}" />
                    <DataGridTemplateColumn Header="Aksi" Width="80">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Button Command="{Binding DataContext.RemoveTransferLineCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        CommandParameter="{Binding}"
                                        Style="{StaticResource SecondaryPillButtonStyle}"
                                        Content="Hapus" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>

            <Border Grid.Row="4" Margin="0,10,0,0" Style="{StaticResource StickyActionBarStyle}">
                <WrapPanel>
                    <Button Command="{Binding AddTransferLineCommand}" Style="{StaticResource SecondaryPillButtonStyle}" Content="Tambah Baris" />
                    <Button Margin="8,0,0,0" Command="{Binding SaveTransferDraftCommand}" IsEnabled="{Binding CanSaveTransferDraft}" ToolTip="{Binding SaveTransferDraftTooltip}" Style="{StaticResource PrimaryButtonStyle}" Content="Simpan Draft" />
                    <Button Margin="8,0,0,0" Command="{Binding SubmitTransferCommand}" IsEnabled="{Binding CanSubmitTransfer}" ToolTip="{Binding SubmitTransferTooltip}" Style="{StaticResource SecondaryPillButtonStyle}" Content="Ajukan" />
                    <Button Margin="8,0,0,0" Command="{Binding ApproveTransferCommand}" IsEnabled="{Binding CanApproveTransfer}" ToolTip="{Binding ApproveTransferTooltip}" Style="{StaticResource SecondaryPillButtonStyle}" Content="Setujui" />
                    <Button Margin="8,0,0,0" Command="{Binding PostTransferCommand}" IsEnabled="{Binding CanPostTransfer}" ToolTip="{Binding PostTransferTooltip}" Style="{StaticResource SecondaryPillButtonStyle}" Content="Posting" />
                </WrapPanel>
            </Border>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</UserControl>
