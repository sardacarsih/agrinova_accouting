<UserControl x:Class="Accounting.Views.Components.InventoryWorkspaceControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:comp="clr-namespace:Accounting.Views.Components"
             UseLayoutRounding="True"
             SnapsToDevicePixels="True">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Style="{StaticResource AdminWorkspaceHeaderCardStyle}" Margin="0,0,0,6">
            <StackPanel>
                <TextBlock Text="Inventori" Style="{StaticResource SettingsSectionTitleTextStyle}" />
                <TextBlock Text="Kelola master barang, transaksi stok, sinkronisasi, dan laporan."
                           Style="{StaticResource SettingsSectionSubtitleTextStyle}" />
            </StackPanel>
        </Border>

        <Grid Grid.Row="1" Margin="10,8,10,0">
            <comp:InventoryDashboardSubView Visibility="{Binding IsInventoryDashboardSelected, Converter={StaticResource BoolToVisibilityConverter}}" />
            <comp:InventoryItemsTabControl Visibility="{Binding IsInventoryItemSelected, Converter={StaticResource BoolToVisibilityConverter}}" />
            <comp:InventoryCategoriesTabControl Visibility="{Binding IsInventoryCategorySelected, Converter={StaticResource BoolToVisibilityConverter}}" />
            <comp:InventoryUnitsTabControl Visibility="{Binding IsInventoryUnitSelected, Converter={StaticResource BoolToVisibilityConverter}}" />
            <comp:InventoryWarehousesTabControl Visibility="{Binding IsInventoryWarehouseSelected, Converter={StaticResource BoolToVisibilityConverter}}" />
            <comp:InventoryStockInSubView Visibility="{Binding IsInventoryStockInSelected, Converter={StaticResource BoolToVisibilityConverter}}" />
            <comp:InventoryStockOutSubView Visibility="{Binding IsInventoryStockOutSelected, Converter={StaticResource BoolToVisibilityConverter}}" />
            <comp:InventoryTransferSubView Visibility="{Binding IsInventoryTransferSelected, Converter={StaticResource BoolToVisibilityConverter}}" />
            <comp:InventoryStockOpnameSubView Visibility="{Binding IsInventoryStockOpnameSelected, Converter={StaticResource BoolToVisibilityConverter}}" />
            <comp:InventoryStockTabControl Visibility="{Binding IsInventoryStockPositionSelected, Converter={StaticResource BoolToVisibilityConverter}}" />
            <comp:InventoryReportsSubView Visibility="{Binding IsInventoryReportsSelected, Converter={StaticResource BoolToVisibilityConverter}}" />
            <Border Padding="14"
                    CornerRadius="{DynamicResource Radius.Card}"
                    BorderThickness="1"
                    Background="{DynamicResource Brush.SurfaceMuted}"
                    BorderBrush="{DynamicResource Brush.Border}"
                    Visibility="{Binding IsInventoryPlaceholderSelected, Converter={StaticResource BoolToVisibilityConverter}}">
                <StackPanel>
                    <TextBlock Text="{Binding InventoryPlaceholderTitle}"
                               Style="{StaticResource SettingsSectionTitleTextStyle}" />
                    <TextBlock Margin="0,8,0,0"
                               TextWrapping="Wrap"
                               Foreground="{DynamicResource Brush.TextSecondary}"
                               Text="{Binding InventoryPlaceholderDescription}" />
                </StackPanel>
            </Border>
        </Grid>

        <ContentControl Grid.Row="2"
                        Content="{Binding}"
                        ContentTemplate="{StaticResource WorkspaceStatusMessageTemplate}" />
    </Grid>
</UserControl>
