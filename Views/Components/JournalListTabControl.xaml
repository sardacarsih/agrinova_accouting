<UserControl x:Class="Accounting.Views.Components.JournalListTabControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors"
             xmlns:dxg="http://schemas.devexpress.com/winfx/2008/xaml/grid"
             UseLayoutRounding="True"
             SnapsToDevicePixels="True">
    <UserControl.InputBindings>
        <KeyBinding Key="Escape" Command="{Binding ResetBrowseFiltersCommand}" />
    </UserControl.InputBindings>
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="170" />
                <ColumnDefinition Width="8" />
                <ColumnDefinition Width="130" />
                <ColumnDefinition Width="8" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="8" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0">
                <TextBlock Style="{StaticResource FieldLabelTextStyle}" Text="Bulan" />
                <ComboBox Margin="0,6,0,0"
                          Height="40"
                          Style="{StaticResource InputComboBoxStyle}"
                          ItemsSource="{Binding ExportMonthOptions}"
                          DisplayMemberPath="Value"
                          SelectedValuePath="Key"
                          SelectedValue="{Binding SearchPeriodMonthNumber, Mode=TwoWay}" />
            </StackPanel>

            <StackPanel Grid.Column="2">
                <TextBlock Style="{StaticResource FieldLabelTextStyle}" Text="Tahun" />
                <ComboBox Margin="0,6,0,0"
                          Height="40"
                          Style="{StaticResource InputComboBoxStyle}"
                          ItemsSource="{Binding ExportYearOptions}"
                          SelectedItem="{Binding SearchPeriodYear, Mode=TwoWay}" />
            </StackPanel>

            <Button Grid.Column="4"
                    VerticalAlignment="Bottom"
                    Command="{Binding PreviousSearchPeriodCommand}"
                    IsEnabled="{Binding CanMoveToPreviousSearchPeriod}"
                    Style="{StaticResource SecondaryPillButtonStyle}"
                    Content="Prev" />
            <Button Grid.Column="6"
                    VerticalAlignment="Bottom"
                    Command="{Binding NextSearchPeriodCommand}"
                    IsEnabled="{Binding CanMoveToNextSearchPeriod}"
                    Style="{StaticResource SecondaryPillButtonStyle}"
                    Content="Next" />

            <StackPanel Grid.Column="8"
                        VerticalAlignment="Bottom"
                        Margin="0,0,0,8">
                <TextBlock Style="{StaticResource FieldLabelTextStyle}" Text="Periode Akuntansi" />
                <TextBlock Margin="0,6,0,0"
                           Foreground="{DynamicResource Brush.TextSecondary}"
                           Text="{Binding SearchAccountingPeriodDisplayText}" />
            </StackPanel>
        </Grid>

        <StackPanel Grid.Row="1" Margin="0,8,0,0" Orientation="Horizontal">
            <Button Command="{Binding OpenSelectedJournalCommand}"
                    IsEnabled="{Binding CanOpenSelectedJournal}"
                    Style="{StaticResource PrimaryButtonStyle}"
                    Content="Buka Editor" />
            <Button Margin="8,0,0,0"
                    Command="{Binding ExportSelectedCommand}"
                    CommandParameter="{Binding ElementName=JournalListGrid, Path=SelectedItems}"
                    IsEnabled="{Binding CanExportAnyJournal}"
                    ToolTip="{Binding ExportSelectedTooltip}"
                    Style="{StaticResource SecondaryPillButtonStyle}"
                    Content="Export Terpilih" />
        </StackPanel>

        <TextBlock Grid.Row="2"
                   Margin="0,8,0,0"
                   Foreground="{DynamicResource Brush.TextSecondary}"
                   Text="{Binding BrowseResultSummary}" />

        <Grid Grid.Row="3" Margin="0,8,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0"
                  HorizontalAlignment="Left">
                <dxg:GridControl x:Name="JournalListGrid"
                                 AutoGenerateColumns="None"
                                 ItemsSource="{Binding BrowseJournalRows}"
                                 MouseDoubleClick="JournalListGrid_OnMouseDoubleClick"
                                 SelectionMode="Row"
                                 SelectionChanged="JournalListGrid_OnSelectionChanged">
                    <dxg:GridControl.Style>
                        <Style TargetType="dxg:GridControl">
                            <Setter Property="Visibility" Value="Visible" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding HasNoBrowseResults}" Value="True">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </dxg:GridControl.Style>
                    <dxg:GridControl.Columns>
                        <dxg:GridColumn FieldName="JournalNo" Header="No Jurnal" Width="165" />
                        <dxg:GridColumn FieldName="JournalDate" Header="Tanggal" Width="120">
                            <dxg:GridColumn.EditSettings>
                                <dxe:TextEditSettings Mask="yyyy-MM-dd" MaskType="DateTime" MaskUseAsDisplayFormat="True" />
                            </dxg:GridColumn.EditSettings>
                        </dxg:GridColumn>
                        <dxg:GridColumn FieldName="Status" Header="Status" Width="90" />
                        <dxg:GridColumn FieldName="CreatedBy" Header="User ID" Width="160" />
                    </dxg:GridControl.Columns>
                    <dxg:GridControl.View>
                        <dxg:TableView x:Name="JournalListView"
                                       AllowEditing="False"
                                       AutoWidth="True"
                                       NavigationStyle="Row"
                                       ShowGroupPanel="False"
                                       ShowIndicator="False" />
                    </dxg:GridControl.View>
                </dxg:GridControl>

                <Border Padding="18"
                        CornerRadius="{DynamicResource Radius.Card}"
                        BorderThickness="1"
                        Background="{DynamicResource Brush.SurfaceMuted}"
                        BorderBrush="{DynamicResource Brush.Border}"
                        Visibility="{Binding HasNoBrowseResults, Converter={StaticResource BoolToVisibilityConverter}}">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock Text="{Binding BrowseEmptyStateTitle}"
                                   HorizontalAlignment="Center"
                                   Style="{StaticResource SettingsSectionTitleTextStyle}" />
                        <TextBlock Margin="0,8,0,0"
                                   MaxWidth="460"
                                   TextAlignment="Center"
                                   TextWrapping="Wrap"
                                   Foreground="{DynamicResource Brush.TextSecondary}"
                                   Text="{Binding BrowseEmptyStateDescription}" />
                    </StackPanel>
                </Border>
            </Grid>

            <Border Grid.Column="2"
                    Padding="12"
                    CornerRadius="{DynamicResource Radius.Card}"
                    BorderThickness="1"
                    Background="{DynamicResource Brush.SurfaceMuted}"
                    BorderBrush="{DynamicResource Brush.Border}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0">
                        <TextBlock Text="Detail Transaksi"
                                   Style="{StaticResource SettingsSectionTitleTextStyle}" />
                        <TextBlock Margin="0,4,0,0"
                                   Foreground="{DynamicResource Brush.TextSecondary}"
                                   TextWrapping="Wrap"
                                   Text="Menampilkan baris transaksi dari jurnal yang sedang aktif di grid master." />
                    </StackPanel>

                    <TextBlock Grid.Row="1"
                               Margin="0,10,0,0"
                               Foreground="{DynamicResource Brush.TextSecondary}"
                               Text="Memuat detail transaksi..."
                               Visibility="{Binding IsActiveBrowseJournalDetailLoading, Converter={StaticResource BoolToVisibilityConverter}}" />

                    <TextBlock Grid.Row="2"
                               Margin="0,10,0,0"
                               Foreground="{DynamicResource Brush.Error}"
                               Text="{Binding ActiveBrowseJournalDetailErrorMessage}">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock" BasedOn="{StaticResource BodyTextStyle}">
                                <Setter Property="Visibility" Value="Visible" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ActiveBrowseJournalDetailErrorMessage}" Value="">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>

                    <Grid Grid.Row="3" Margin="0,12,0,0">
                        <dxg:GridControl AutoGenerateColumns="None"
                                         ItemsSource="{Binding ActiveBrowseJournalLines}">
                            <dxg:GridControl.Style>
                                <Style TargetType="dxg:GridControl">
                                    <Setter Property="Visibility" Value="Visible" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding HasActiveBrowseJournalDetail}" Value="False">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding IsActiveBrowseJournalDetailLoading}" Value="True">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </dxg:GridControl.Style>
                            <dxg:GridControl.Columns>
                                <dxg:GridColumn FieldName="LineNo" Header="No" Width="70" />
                                <dxg:GridColumn FieldName="AccountCode" Header="Kode Akun" Width="110" />
                                <dxg:GridColumn FieldName="AccountName" Header="Nama Akun" Width="180" />
                                <dxg:GridColumn FieldName="Description" Header="Keterangan" Width="220" />
                                <dxg:GridColumn FieldName="DepartmentCode" Header="Departemen" Width="110" />
                                <dxg:GridColumn FieldName="ProjectCode" Header="Proyek" Width="100" />
                                <dxg:GridColumn FieldName="CostCenterCode" Header="Cost Center" Width="110" />
                                <dxg:GridColumn FieldName="Debit" Header="Debit" Width="100">
                                    <dxg:GridColumn.EditSettings>
                                        <dxe:TextEditSettings Mask="n2" MaskUseAsDisplayFormat="True" />
                                    </dxg:GridColumn.EditSettings>
                                </dxg:GridColumn>
                                <dxg:GridColumn FieldName="Credit" Header="Kredit" Width="100">
                                    <dxg:GridColumn.EditSettings>
                                        <dxe:TextEditSettings Mask="n2" MaskUseAsDisplayFormat="True" />
                                    </dxg:GridColumn.EditSettings>
                                </dxg:GridColumn>
                            </dxg:GridControl.Columns>
                            <dxg:GridControl.View>
                                <dxg:TableView AllowEditing="False"
                                               AutoWidth="True"
                                               NavigationStyle="Row"
                                               ShowGroupPanel="False"
                                               ShowIndicator="False" />
                            </dxg:GridControl.View>
                        </dxg:GridControl>

                        <Border Padding="16"
                                CornerRadius="{DynamicResource Radius.Card}"
                                BorderThickness="1"
                                Background="{DynamicResource Brush.Surface}"
                                BorderBrush="{DynamicResource Brush.Border}">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Visibility" Value="Visible" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding HasActiveBrowseJournalDetail}" Value="True">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding IsActiveBrowseJournalDetailLoading}" Value="True">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding HasActiveBrowseJournalDetailError}" Value="True">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                <TextBlock Text="{Binding BrowseDetailEmptyTitle}"
                                           HorizontalAlignment="Center"
                                           Style="{StaticResource SettingsSectionTitleTextStyle}" />
                                <TextBlock Margin="0,8,0,0"
                                           MaxWidth="320"
                                           TextAlignment="Center"
                                           TextWrapping="Wrap"
                                           Foreground="{DynamicResource Brush.TextSecondary}"
                                           Text="{Binding BrowseDetailEmptyDescription}" />
                            </StackPanel>
                        </Border>
                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>

