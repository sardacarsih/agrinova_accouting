<UserControl x:Class="Accounting.Views.Components.JournalListTabControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             UseLayoutRounding="True"
             SnapsToDevicePixels="True">
    <UserControl.InputBindings>
        <KeyBinding Key="Escape" Command="{Binding ResetBrowseFiltersCommand}" />
    </UserControl.InputBindings>
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Style="{StaticResource AdminWorkspaceHeaderCardStyle}" Margin="0,0,0,6">
            <StackPanel>
                <TextBlock Text="Daftar Jurnal" Style="{StaticResource SettingsSectionTitleTextStyle}" />
                <TextBlock Text="Pantau, filter, dan buka jurnal ke editor dari satu layar browse."
                           Style="{StaticResource SettingsSectionSubtitleTextStyle}" />
            </StackPanel>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="170" />
                <ColumnDefinition Width="8" />
                <ColumnDefinition Width="130" />
                <ColumnDefinition Width="8" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="8" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0">
                <TextBlock Style="{StaticResource FieldLabelTextStyle}" Text="Bulan" />
                <ComboBox Margin="0,6,0,0"
                          Height="40"
                          Style="{StaticResource InputComboBoxStyle}"
                          ItemsSource="{Binding ExportMonthOptions}"
                          DisplayMemberPath="Value"
                          SelectedValuePath="Key"
                          SelectedValue="{Binding SearchPeriodMonthNumber, Mode=TwoWay}" />
            </StackPanel>

            <StackPanel Grid.Column="2">
                <TextBlock Style="{StaticResource FieldLabelTextStyle}" Text="Tahun" />
                <ComboBox Margin="0,6,0,0"
                          Height="40"
                          Style="{StaticResource InputComboBoxStyle}"
                          ItemsSource="{Binding ExportYearOptions}"
                          SelectedItem="{Binding SearchPeriodYear, Mode=TwoWay}" />
            </StackPanel>

            <Button Grid.Column="4"
                    VerticalAlignment="Bottom"
                    Command="{Binding PreviousSearchPeriodCommand}"
                    IsEnabled="{Binding CanMoveToPreviousSearchPeriod}"
                    Style="{StaticResource SecondaryPillButtonStyle}"
                    Content="Prev" />
            <Button Grid.Column="6"
                    VerticalAlignment="Bottom"
                    Command="{Binding NextSearchPeriodCommand}"
                    IsEnabled="{Binding CanMoveToNextSearchPeriod}"
                    Style="{StaticResource SecondaryPillButtonStyle}"
                    Content="Next" />

            <StackPanel Grid.Column="8"
                        VerticalAlignment="Bottom"
                        Margin="0,0,0,8">
                <TextBlock Style="{StaticResource FieldLabelTextStyle}" Text="Periode Akuntansi" />
                <TextBlock Margin="0,6,0,0"
                           Foreground="{DynamicResource Brush.TextSecondary}"
                           Text="{Binding SearchAccountingPeriodDisplayText}" />
            </StackPanel>
        </Grid>

        <StackPanel Grid.Row="2" Margin="0,8,0,0" Orientation="Horizontal">
            <Button Command="{Binding OpenSelectedJournalCommand}"
                    IsEnabled="{Binding CanOpenSelectedJournal}"
                    Style="{StaticResource PrimaryButtonStyle}"
                    Content="Buka Editor" />
            <Button Margin="8,0,0,0"
                    Command="{Binding ExportSelectedCommand}"
                    CommandParameter="{Binding ElementName=JournalListGrid, Path=SelectedItems}"
                    IsEnabled="{Binding CanExportAnyJournal}"
                    ToolTip="{Binding ExportSelectedTooltip}"
                    Style="{StaticResource SecondaryPillButtonStyle}"
                    Content="Export Terpilih" />
        </StackPanel>

        <TextBlock Grid.Row="3"
                   Margin="0,8,0,0"
                   Foreground="{DynamicResource Brush.TextSecondary}"
                   Text="{Binding BrowseResultSummary}" />

        <Grid Grid.Row="4">
            <DataGrid x:Name="JournalListGrid"
                      Margin="0,8,0,0"
                      SelectionMode="Extended"
                      SelectionUnit="FullRow"
                      ItemsSource="{Binding BrowseJournals}"
                      SelectedItem="{Binding SelectedBrowseJournal, Mode=TwoWay}"
                      AutoGenerateColumns="False"
                      IsReadOnly="True">
                <DataGrid.InputBindings>
                    <MouseBinding MouseAction="LeftDoubleClick" Command="{Binding OpenSelectedJournalCommand}" />
                </DataGrid.InputBindings>
                <DataGrid.Style>
                    <Style TargetType="DataGrid" BasedOn="{StaticResource EnterpriseDataGridStyle}">
                        <Setter Property="Visibility" Value="Visible" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding HasNoBrowseResults}" Value="True">
                                <Setter Property="Visibility" Value="Collapsed" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </DataGrid.Style>
                <DataGrid.Columns>
                    <DataGridTextColumn Header="No Jurnal" Binding="{Binding JournalNo}" Width="150" />
                    <DataGridTextColumn Header="Tanggal" Binding="{Binding JournalDate, StringFormat=yyyy-MM-dd}" Width="120" />
                    <DataGridTextColumn Header="Referensi" Binding="{Binding ReferenceNo}" Width="130" />
                    <DataGridTextColumn Header="Keterangan" Binding="{Binding Description}" Width="*" />
                    <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="90" />
                    <DataGridTextColumn Header="Debit" Binding="{Binding TotalDebit, StringFormat=N2}" Width="120" ElementStyle="{StaticResource EnterpriseNumericCellTextStyle}" />
                    <DataGridTextColumn Header="Kredit" Binding="{Binding TotalCredit, StringFormat=N2}" Width="120" ElementStyle="{StaticResource EnterpriseNumericCellTextStyle}" />
                </DataGrid.Columns>
            </DataGrid>

            <Border Margin="0,8,0,0"
                    Padding="18"
                    CornerRadius="{DynamicResource Radius.Card}"
                    BorderThickness="1"
                    Background="{DynamicResource Brush.SurfaceMuted}"
                    BorderBrush="{DynamicResource Brush.Border}"
                    Visibility="{Binding HasNoBrowseResults, Converter={StaticResource BoolToVisibilityConverter}}">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock Text="{Binding BrowseEmptyStateTitle}"
                               HorizontalAlignment="Center"
                               Style="{StaticResource SettingsSectionTitleTextStyle}" />
                    <TextBlock Margin="0,8,0,0"
                               MaxWidth="460"
                               TextAlignment="Center"
                               TextWrapping="Wrap"
                               Foreground="{DynamicResource Brush.TextSecondary}"
                               Text="{Binding BrowseEmptyStateDescription}" />
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>

