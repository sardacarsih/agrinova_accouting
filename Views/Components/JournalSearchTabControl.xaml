<UserControl x:Class="Accounting.Views.Components.JournalSearchTabControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             UseLayoutRounding="True"
             SnapsToDevicePixels="True">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Style="{StaticResource AdminWorkspaceHeaderCardStyle}" Margin="0,0,0,6">
            <StackPanel>
                <TextBlock Text="Pencarian Jurnal" Style="{StaticResource SettingsSectionTitleTextStyle}" />
                <TextBlock Text="Filter jurnal berdasarkan rentang tanggal, status, dan kata kunci."
                           Style="{StaticResource SettingsSectionSubtitleTextStyle}" />
            </StackPanel>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="180" />
                <ColumnDefinition Width="8" />
                <ColumnDefinition Width="180" />
                <ColumnDefinition Width="8" />
                <ColumnDefinition Width="110" />
                <ColumnDefinition Width="8" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="8" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <DatePicker Grid.Column="0"
                        SelectedDate="{Binding SearchDateFrom, Mode=TwoWay}"
                        SelectedDateFormat="Short"
                        Language="en-GB"
                        MinWidth="180"
                        Height="40" />
            <DatePicker Grid.Column="2"
                        SelectedDate="{Binding SearchDateTo, Mode=TwoWay}"
                        SelectedDateFormat="Short"
                        Language="en-GB"
                        MinWidth="180"
                        Height="40" />
            <ComboBox Grid.Column="4"
                      Height="40"
                      Style="{StaticResource InputComboBoxStyle}"
                      ItemsSource="{Binding StatusFilterOptions}"
                      SelectedItem="{Binding SearchStatus, Mode=TwoWay}" />
            <TextBox Grid.Column="6" Text="{Binding SearchKeyword, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource InputTextBoxStyle}" />
            <Button Grid.Column="8" Command="{Binding SearchCommand}" Style="{StaticResource PrimaryButtonStyle}" Content="Cari" />
        </Grid>

        <DataGrid Style="{StaticResource EnterpriseDataGridStyle}"
                  Grid.Row="2"
                  Margin="0,8,0,0"
                  ItemsSource="{Binding SearchResults}"
                  SelectedItem="{Binding SelectedSearchJournal, Mode=TwoWay}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True">
            <DataGrid.Columns>
                <DataGridTextColumn Header="No Jurnal" Binding="{Binding JournalNo}" Width="150" />
                <DataGridTextColumn Header="Tanggal" Binding="{Binding JournalDate, StringFormat=yyyy-MM-dd}" Width="120" />
                <DataGridTextColumn Header="Referensi" Binding="{Binding ReferenceNo}" Width="130" />
                <DataGridTextColumn Header="Keterangan" Binding="{Binding Description}" Width="*" />
                <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="90" />
                <DataGridTextColumn Header="Debit" Binding="{Binding TotalDebit, StringFormat=N2}" Width="120" />
                <DataGridTextColumn Header="Kredit" Binding="{Binding TotalCredit, StringFormat=N2}" Width="120" />
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>
