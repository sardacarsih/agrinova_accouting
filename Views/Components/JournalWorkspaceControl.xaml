<UserControl x:Class="Accounting.Views.Components.JournalWorkspaceControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:comp="clr-namespace:Accounting.Views.Components"
             UseLayoutRounding="True"
             SnapsToDevicePixels="True">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Style="{StaticResource AdminWorkspaceHeaderCardStyle}" Margin="0,0,0,6">
            <StackPanel>
                <TextBlock Text="{Binding JournalWorkspaceTitle}" Style="{StaticResource SettingsSectionTitleTextStyle}" />
                <TextBlock Text="{Binding JournalWorkspaceSubtitle}"
                           Style="{StaticResource SettingsSectionSubtitleTextStyle}" />
            </StackPanel>
        </Border>

        <Grid Grid.Row="1">
            <TabControl SelectedIndex="{Binding SelectedJournalTabIndex, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                <TabItem Header="Editor">
                    <comp:JournalInputTabControl />
                </TabItem>
                <TabItem Header="Daftar">
                    <comp:JournalListTabControl />
                </TabItem>
                <TabItem Header="Proses Batch">
                    <TabControl Margin="10,10,10,0"
                                SelectedIndex="{Binding SelectedBatchTabIndex, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                        <TabItem Header="Import">
                            <comp:JournalImportTabControl />
                        </TabItem>
                        <TabItem Header="Export">
                            <comp:JournalExportTabControl />
                        </TabItem>
                    </TabControl>
                </TabItem>
            </TabControl>

            <Border Margin="12"
                    Padding="14"
                    CornerRadius="{DynamicResource Radius.Card}"
                    BorderThickness="1"
                    Background="{DynamicResource Brush.SurfaceMuted}"
                    BorderBrush="{DynamicResource Brush.Border}"
                    VerticalAlignment="Top"
                    Visibility="{Binding IsJournalPlaceholderSelected, Converter={StaticResource BoolToVisibilityConverter}}">
                <StackPanel>
                    <TextBlock Text="{Binding JournalPlaceholderTitle}"
                               Style="{StaticResource SettingsSectionTitleTextStyle}" />
                    <TextBlock Margin="0,6,0,0"
                               TextWrapping="Wrap"
                               Foreground="{DynamicResource Brush.TextSecondary}"
                               Text="{Binding JournalPlaceholderDescription}" />
                </StackPanel>
            </Border>
        </Grid>

        <ContentControl Grid.Row="2"
                        Content="{Binding}"
                        ContentTemplate="{StaticResource WorkspaceStatusMessageTemplate}" />
    </Grid>
</UserControl>
