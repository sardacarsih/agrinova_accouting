<UserControl x:Class="Accounting.Views.Components.MasterDataWorkspaceControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:comp="clr-namespace:Accounting.Views.Components"
             UseLayoutRounding="True"
             SnapsToDevicePixels="True">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Style="{StaticResource AdminWorkspaceHeaderCardStyle}" Margin="0,0,0,6">
            <StackPanel>
                <TextBlock Text="Master Data" Style="{StaticResource SettingsSectionTitleTextStyle}" />
                <TextBlock Text="Kelola data dasar akuntansi sesuai company dan lokasi aktif."
                           Style="{StaticResource SettingsSectionSubtitleTextStyle}" />
            </StackPanel>
        </Border>

        <Grid Grid.Row="1" Margin="10,8,10,0">
            <comp:MasterDataAccountsTabControl Visibility="{Binding IsMasterAccountListSelected, Converter={StaticResource BoolToVisibilityConverter}}" />
            <comp:MasterDataPeriodsTabControl Visibility="{Binding IsMasterPeriodSelected, Converter={StaticResource BoolToVisibilityConverter}}" />
            <Border Padding="14"
                    CornerRadius="{DynamicResource Radius.Card}"
                    BorderThickness="1"
                    Background="{DynamicResource Brush.SurfaceMuted}"
                    BorderBrush="{DynamicResource Brush.Border}"
                    Visibility="{Binding IsMasterPlaceholderSelected, Converter={StaticResource BoolToVisibilityConverter}}">
                <StackPanel>
                    <TextBlock Text="{Binding MasterPlaceholderTitle}"
                               Style="{StaticResource SettingsSectionTitleTextStyle}" />
                    <TextBlock Margin="0,8,0,0"
                               TextWrapping="Wrap"
                               Foreground="{DynamicResource Brush.TextSecondary}"
                               Text="{Binding MasterPlaceholderDescription}" />
                </StackPanel>
            </Border>
        </Grid>

        <ContentControl Grid.Row="2"
                        Content="{Binding}"
                        ContentTemplate="{StaticResource WorkspaceStatusMessageTemplate}" />
    </Grid>
</UserControl>
