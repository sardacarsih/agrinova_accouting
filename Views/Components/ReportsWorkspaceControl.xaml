<UserControl x:Class="Accounting.Views.Components.ReportsWorkspaceControl" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" UseLayoutRounding="True" SnapsToDevicePixels="True">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Border Grid.Row="0" Style="{StaticResource AdminWorkspaceHeaderCardStyle}" Margin="0,0,0,6">
            <StackPanel>
                <TextBlock Text="Laporan" Style="{StaticResource SettingsSectionTitleTextStyle}" />
                <TextBlock Text="Analisis laporan keuangan operasional dan ekspor data."
                           Style="{StaticResource SettingsSectionSubtitleTextStyle}" />
            </StackPanel>
        </Border>
        <Border Grid.Row="1" Margin="10,10,10,0" Padding="12,8" CornerRadius="10" Background="{DynamicResource Brush.SurfaceMuted}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="8" />
                    <ColumnDefinition Width="160" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="8" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" VerticalAlignment="Center" Style="{StaticResource FieldLabelTextStyle}" Text="Periode Laporan" />
                <DatePicker SelectedDate="{Binding PeriodMonth, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Height="42" />
                <Button Grid.Column="4" Command="{Binding PreviousMonthCommand}" Style="{StaticResource SecondaryPillButtonStyle}" Content="&lt; Bulan Lalu" />
                <Button Grid.Column="6" Command="{Binding NextMonthCommand}" Style="{StaticResource SecondaryPillButtonStyle}" Content="Bulan Berikut &gt;" />
                <StackPanel Grid.Column="7" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Command="{Binding RefreshCommand}" Style="{StaticResource PrimaryButtonStyle}" Content="Muat Ulang" />
                    <Button Margin="8,0,0,0" Command="{Binding ExportCommand}" IsEnabled="{Binding CanExportReports}" ToolTip="{Binding ExportTooltip}" Style="{StaticResource SecondaryPillButtonStyle}" Content="Export XLSX" />
                </StackPanel>

                <Grid Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="8" Margin="0,8,0,0">
                    <Grid.Style>
                        <Style TargetType="Grid">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsInquiryFilterMode}" Value="True">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Grid.Style>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="130" />
                        <ColumnDefinition Width="220" />
                        <ColumnDefinition Width="10" />
                        <ColumnDefinition Width="90" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="10" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0"
                               VerticalAlignment="Center"
                               Style="{StaticResource FieldLabelTextStyle}"
                               Text="Filter Akun" />
                    <ComboBox Grid.Column="1"
                              Style="{StaticResource InputComboBoxStyle}"
                              ItemsSource="{Binding GeneralLedgerAccountOptions}"
                              SelectedValuePath="Code"
                              SelectedValue="{Binding SelectedGeneralLedgerAccountCode, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                    <TextBlock Grid.Column="3"
                               VerticalAlignment="Center"
                               Style="{StaticResource FieldLabelTextStyle}"
                               Text="Keyword" />
                    <TextBox Grid.Column="4"
                             Style="{StaticResource InputTextBoxStyle}"
                             Text="{Binding GeneralLedgerKeyword, UpdateSourceTrigger=PropertyChanged}" />
                    <Button Grid.Column="6"
                            Command="{Binding ApplyGeneralLedgerFilterCommand}"
                            Style="{StaticResource SecondaryPillButtonStyle}"
                            Content="Terapkan" />
                </Grid>
            </Grid>
        </Border>
        <Grid Grid.Row="2" Margin="10,8,10,0">
            <TabControl SelectedIndex="{Binding SelectedReportTabIndex, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                <TabItem Header="Neraca Saldo / Buku Besar / Sub Ledger / Mutasi Akun">
                    <Grid Margin="10">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0">
                            <Grid.Style>
                                <Style TargetType="Grid">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsTrialBalanceMode}" Value="True">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Grid.Style>
                            <DataGrid Style="{StaticResource EnterpriseDataGridStyle}" ItemsSource="{Binding TrialBalanceRows}" AutoGenerateColumns="False" IsReadOnly="True">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Kode Akun" Binding="{Binding AccountCode}" Width="120" />
                                    <DataGridTextColumn Header="Nama Akun" Binding="{Binding AccountName}" Width="*" />
                                    <DataGridTextColumn Header="Debit" Binding="{Binding TotalDebit, StringFormat=N2}" Width="140" />
                                    <DataGridTextColumn Header="Kredit" Binding="{Binding TotalCredit, StringFormat=N2}" Width="140" />
                                    <DataGridTextColumn Header="Saldo Bersih" Binding="{Binding NetBalance, StringFormat=N2}" Width="140" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>

                        <Grid Grid.Row="0">
                            <Grid.Style>
                                <Style TargetType="Grid">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsSubLedgerMode}" Value="True">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Grid.Style>
                            <DataGrid Style="{StaticResource EnterpriseDataGridStyle}" ItemsSource="{Binding SubLedgerRows}" AutoGenerateColumns="False" IsReadOnly="True">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Tanggal" Binding="{Binding JournalDate, StringFormat=yyyy-MM-dd}" Width="110" />
                                    <DataGridTextColumn Header="No Jurnal" Binding="{Binding JournalNo}" Width="120" />
                                    <DataGridTextColumn Header="Referensi" Binding="{Binding ReferenceNo}" Width="120" />
                                    <DataGridTextColumn Header="Kode Akun" Binding="{Binding AccountCode}" Width="100" />
                                    <DataGridTextColumn Header="Nama Akun" Binding="{Binding AccountName}" Width="170" />
                                    <DataGridTextColumn Header="Departemen" Binding="{Binding DepartmentCode}" Width="110" />
                                    <DataGridTextColumn Header="Project" Binding="{Binding ProjectCode}" Width="110" />
                                    <DataGridTextColumn Header="Cost Center" Binding="{Binding CostCenterCode}" Width="110" />
                                    <DataGridTextColumn Header="Keterangan Baris" Binding="{Binding LineDescription}" Width="220" />
                                    <DataGridTextColumn Header="Debit" Binding="{Binding Debit, StringFormat=N2}" Width="110" />
                                    <DataGridTextColumn Header="Kredit" Binding="{Binding Credit, StringFormat=N2}" Width="110" />
                                    <DataGridTextColumn Header="Saldo Berjalan" Binding="{Binding RunningBalance, StringFormat=N2}" Width="130" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>

                        <Grid Grid.Row="0">
                            <Grid.Style>
                                <Style TargetType="Grid">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsGeneralLedgerMode}" Value="True">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Grid.Style>
                            <DataGrid Style="{StaticResource EnterpriseDataGridStyle}" ItemsSource="{Binding GeneralLedgerRows}" AutoGenerateColumns="False" IsReadOnly="True">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Tanggal" Binding="{Binding JournalDate, StringFormat=yyyy-MM-dd}" Width="110" />
                                    <DataGridTextColumn Header="No Jurnal" Binding="{Binding JournalNo}" Width="140" />
                                    <DataGridTextColumn Header="Referensi" Binding="{Binding ReferenceNo}" Width="120" />
                                    <DataGridTextColumn Header="Keterangan Jurnal" Binding="{Binding JournalDescription}" Width="220" />
                                    <DataGridTextColumn Header="Kode Akun" Binding="{Binding AccountCode}" Width="110" />
                                    <DataGridTextColumn Header="Nama Akun" Binding="{Binding AccountName}" Width="180" />
                                    <DataGridTextColumn Header="Keterangan Baris" Binding="{Binding LineDescription}" Width="220" />
                                    <DataGridTextColumn Header="Debit" Binding="{Binding Debit, StringFormat=N2}" Width="110" />
                                    <DataGridTextColumn Header="Kredit" Binding="{Binding Credit, StringFormat=N2}" Width="110" />
                                    <DataGridTextColumn Header="Saldo Berjalan" Binding="{Binding RunningBalance, StringFormat=N2}" Width="140" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>

                        <Grid Grid.Row="0">
                            <Grid.Style>
                                <Style TargetType="Grid">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsAccountMutationMode}" Value="True">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Grid.Style>
                            <DataGrid Style="{StaticResource EnterpriseDataGridStyle}" ItemsSource="{Binding AccountMutationRows}" AutoGenerateColumns="False" IsReadOnly="True">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Kode Akun" Binding="{Binding AccountCode}" Width="120" />
                                    <DataGridTextColumn Header="Nama Akun" Binding="{Binding AccountName}" Width="*" />
                                    <DataGridTextColumn Header="Saldo Awal" Binding="{Binding OpeningBalance, StringFormat=N2}" Width="140" />
                                    <DataGridTextColumn Header="Debit Mutasi" Binding="{Binding MutationDebit, StringFormat=N2}" Width="140" />
                                    <DataGridTextColumn Header="Kredit Mutasi" Binding="{Binding MutationCredit, StringFormat=N2}" Width="140" />
                                    <DataGridTextColumn Header="Saldo Akhir" Binding="{Binding EndingBalance, StringFormat=N2}" Width="140" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>

                        <Border Grid.Row="1" Margin="0,8,0,0" Padding="10,6" CornerRadius="8" Background="{DynamicResource Brush.SurfaceMuted}">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsTrialBalanceMode}" Value="True">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Style="{StaticResource FieldLabelTextStyle}" Text="Total Debit:" />
                                <TextBlock Margin="8,0,16,0" FontWeight="SemiBold" Foreground="{DynamicResource Brush.TextPrimary}" Text="{Binding TotalDebit, StringFormat=N2}" />
                                <TextBlock Style="{StaticResource FieldLabelTextStyle}" Text="Total Kredit:" />
                                <TextBlock Margin="8,0,16,0" FontWeight="SemiBold" Foreground="{DynamicResource Brush.TextPrimary}" Text="{Binding TotalCredit, StringFormat=N2}" />
                                <TextBlock Style="{StaticResource FieldLabelTextStyle}" Text="Selisih:" />
                                <TextBlock Margin="8,0,0,0" FontWeight="SemiBold" Foreground="{DynamicResource Brush.Error}" Text="{Binding DifferenceAmount, StringFormat=N2}" />
                            </StackPanel>
                        </Border>

                        <Border Grid.Row="1" Margin="0,8,0,0" Padding="10,6" CornerRadius="8" Background="{DynamicResource Brush.SurfaceMuted}">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsGeneralLedgerMode}" Value="True">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Style="{StaticResource FieldLabelTextStyle}" Text="Total Debit:" />
                                <TextBlock Margin="8,0,16,0" FontWeight="SemiBold" Foreground="{DynamicResource Brush.TextPrimary}" Text="{Binding GeneralLedgerTotalDebit, StringFormat=N2}" />
                                <TextBlock Style="{StaticResource FieldLabelTextStyle}" Text="Total Kredit:" />
                                <TextBlock Margin="8,0,16,0" FontWeight="SemiBold" Foreground="{DynamicResource Brush.TextPrimary}" Text="{Binding GeneralLedgerTotalCredit, StringFormat=N2}" />
                                <TextBlock Style="{StaticResource FieldLabelTextStyle}" Text="Neto:" />
                                <TextBlock Margin="8,0,0,0" FontWeight="SemiBold" Foreground="{DynamicResource Brush.TextPrimary}" Text="{Binding GeneralLedgerNetBalance, StringFormat=N2}" />
                            </StackPanel>
                        </Border>

                        <Border Grid.Row="1" Margin="0,8,0,0" Padding="10,6" CornerRadius="8" Background="{DynamicResource Brush.SurfaceMuted}">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsSubLedgerMode}" Value="True">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Style="{StaticResource FieldLabelTextStyle}" Text="Total Debit:" />
                                <TextBlock Margin="8,0,16,0" FontWeight="SemiBold" Foreground="{DynamicResource Brush.TextPrimary}" Text="{Binding SubLedgerTotalDebit, StringFormat=N2}" />
                                <TextBlock Style="{StaticResource FieldLabelTextStyle}" Text="Total Kredit:" />
                                <TextBlock Margin="8,0,16,0" FontWeight="SemiBold" Foreground="{DynamicResource Brush.TextPrimary}" Text="{Binding SubLedgerTotalCredit, StringFormat=N2}" />
                                <TextBlock Style="{StaticResource FieldLabelTextStyle}" Text="Neto:" />
                                <TextBlock Margin="8,0,0,0" FontWeight="SemiBold" Foreground="{DynamicResource Brush.TextPrimary}" Text="{Binding SubLedgerNetBalance, StringFormat=N2}" />
                            </StackPanel>
                        </Border>

                        <Border Grid.Row="1" Margin="0,8,0,0" Padding="10,6" CornerRadius="8" Background="{DynamicResource Brush.SurfaceMuted}">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsAccountMutationMode}" Value="True">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Style="{StaticResource FieldLabelTextStyle}" Text="Total Saldo Awal:" />
                                <TextBlock Margin="8,0,16,0" FontWeight="SemiBold" Foreground="{DynamicResource Brush.TextPrimary}" Text="{Binding AccountMutationTotalOpening, StringFormat=N2}" />
                                <TextBlock Style="{StaticResource FieldLabelTextStyle}" Text="Total Debit Mutasi:" />
                                <TextBlock Margin="8,0,16,0" FontWeight="SemiBold" Foreground="{DynamicResource Brush.TextPrimary}" Text="{Binding AccountMutationTotalDebit, StringFormat=N2}" />
                                <TextBlock Style="{StaticResource FieldLabelTextStyle}" Text="Total Kredit Mutasi:" />
                                <TextBlock Margin="8,0,16,0" FontWeight="SemiBold" Foreground="{DynamicResource Brush.TextPrimary}" Text="{Binding AccountMutationTotalCredit, StringFormat=N2}" />
                                <TextBlock Style="{StaticResource FieldLabelTextStyle}" Text="Total Saldo Akhir:" />
                                <TextBlock Margin="8,0,16,0" FontWeight="SemiBold" Foreground="{DynamicResource Brush.TextPrimary}" Text="{Binding AccountMutationTotalEnding, StringFormat=N2}" />
                                <TextBlock Style="{StaticResource FieldLabelTextStyle}" Text="Neto Mutasi:" />
                                <TextBlock Margin="8,0,0,0" FontWeight="SemiBold" Foreground="{DynamicResource Brush.TextPrimary}" Text="{Binding AccountMutationNetMovement, StringFormat=N2}" />
                            </StackPanel>
                        </Border>
                    </Grid>
                </TabItem>
                <TabItem Header="Laba Rugi">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <DataGrid Style="{StaticResource EnterpriseDataGridStyle}" Grid.Row="0" ItemsSource="{Binding ProfitLossRows}" AutoGenerateColumns="False" IsReadOnly="True">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Kelompok" Binding="{Binding Section}" Width="120" />
                            <DataGridTextColumn Header="Kode Akun" Binding="{Binding AccountCode}" Width="120" />
                            <DataGridTextColumn Header="Nama Akun" Binding="{Binding AccountName}" Width="*" />
                            <DataGridTextColumn Header="Jumlah" Binding="{Binding Amount, StringFormat=N2}" Width="160" />
                        </DataGrid.Columns>
                    </DataGrid>
                    <Border Grid.Row="1" Margin="0,8,0,0" Padding="10,6" CornerRadius="8" Background="{DynamicResource Brush.SurfaceMuted}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Style="{StaticResource FieldLabelTextStyle}" Text="Total Pendapatan:" />
                            <TextBlock Margin="8,0,16,0" FontWeight="SemiBold" Foreground="{DynamicResource Brush.TextPrimary}" Text="{Binding TotalRevenue, StringFormat=N2}" />
                            <TextBlock Style="{StaticResource FieldLabelTextStyle}" Text="Total Beban:" />
                            <TextBlock Margin="8,0,16,0" FontWeight="SemiBold" Foreground="{DynamicResource Brush.TextPrimary}" Text="{Binding TotalExpense, StringFormat=N2}" />
                            <TextBlock Style="{StaticResource FieldLabelTextStyle}" Text="Laba Bersih:" />
                            <TextBlock Margin="8,0,0,0" FontWeight="SemiBold" Foreground="{DynamicResource Brush.Success}" Text="{Binding NetIncome, StringFormat=N2}" />
                        </StackPanel>
                    </Border>
                </Grid>
                </TabItem>
                <TabItem Header="Neraca">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid Grid.Row="0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <Border Grid.Row="0" Margin="0,0,0,6" Padding="10,6" CornerRadius="8" Background="{DynamicResource Brush.SurfaceMuted}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120" />
                                    <ColumnDefinition Width="130" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="170" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Style="{StaticResource FieldLabelTextStyle}" Text="Kelompok" />
                                <TextBlock Grid.Column="1" Style="{StaticResource FieldLabelTextStyle}" Text="Kode Akun" />
                                <TextBlock Grid.Column="2" Style="{StaticResource FieldLabelTextStyle}" Text="Nama Akun" />
                                <TextBlock Grid.Column="3" Style="{StaticResource FieldLabelTextStyle}" Text="Saldo" />
                            </Grid>
                        </Border>
                        <Border Grid.Row="1" BorderBrush="{DynamicResource Brush.Border}" BorderThickness="1" CornerRadius="8" Padding="6">
                            <TreeView ItemsSource="{Binding BalanceSheetTreeRoots}">
                                <TreeView.ItemTemplate>
                                    <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="120" />
                                                <ColumnDefinition Width="130" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="170" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="{Binding Section}" Foreground="{DynamicResource Brush.TextSecondary}" />
                                            <TextBlock Grid.Column="1" Text="{Binding AccountCode}" Foreground="{DynamicResource Brush.TextPrimary}" />
                                            <TextBlock Grid.Column="2" Text="{Binding AccountName}" Foreground="{DynamicResource Brush.TextPrimary}" />
                                            <TextBlock Grid.Column="3" Text="{Binding Amount, StringFormat=N2}" HorizontalAlignment="Right" FontWeight="SemiBold" Foreground="{DynamicResource Brush.TextPrimary}" />
                                        </Grid>
                                    </HierarchicalDataTemplate>
                                </TreeView.ItemTemplate>
                            </TreeView>
                        </Border>
                    </Grid>
                    <Border Grid.Row="1" Margin="0,8,0,0" Padding="10,6" CornerRadius="8" Background="{DynamicResource Brush.SurfaceMuted}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Style="{StaticResource FieldLabelTextStyle}" Text="Total Aset:" />
                            <TextBlock Margin="8,0,16,0" FontWeight="SemiBold" Foreground="{DynamicResource Brush.TextPrimary}" Text="{Binding TotalAssets, StringFormat=N2}" />
                            <TextBlock Style="{StaticResource FieldLabelTextStyle}" Text="Total Kewajiban:" />
                            <TextBlock Margin="8,0,16,0" FontWeight="SemiBold" Foreground="{DynamicResource Brush.TextPrimary}" Text="{Binding TotalLiabilities, StringFormat=N2}" />
                            <TextBlock Style="{StaticResource FieldLabelTextStyle}" Text="Total Ekuitas:" />
                            <TextBlock Margin="8,0,16,0" FontWeight="SemiBold" Foreground="{DynamicResource Brush.TextPrimary}" Text="{Binding TotalEquity, StringFormat=N2}" />
                            <TextBlock Style="{StaticResource FieldLabelTextStyle}" Text="Selisih A-(K+E):" />
                            <TextBlock Margin="8,0,0,0" FontWeight="SemiBold" Foreground="{DynamicResource Brush.Error}" Text="{Binding BalanceSheetDifference, StringFormat=N2}" />
                        </StackPanel>
                    </Border>
                </Grid>
                </TabItem>
                <TabItem Header="Arus Kas">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <DataGrid Style="{StaticResource EnterpriseDataGridStyle}" Grid.Row="0" ItemsSource="{Binding CashFlowRows}" AutoGenerateColumns="False" IsReadOnly="True">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Kode Akun" Binding="{Binding AccountCode}" Width="120" />
                            <DataGridTextColumn Header="Nama Akun" Binding="{Binding AccountName}" Width="*" />
                            <DataGridTextColumn Header="Saldo Awal" Binding="{Binding OpeningBalance, StringFormat=N2}" Width="150" />
                            <DataGridTextColumn Header="Kas Masuk" Binding="{Binding CashIn, StringFormat=N2}" Width="140" />
                            <DataGridTextColumn Header="Kas Keluar" Binding="{Binding CashOut, StringFormat=N2}" Width="140" />
                            <DataGridTextColumn Header="Saldo Akhir" Binding="{Binding EndingBalance, StringFormat=N2}" Width="150" />
                        </DataGrid.Columns>
                    </DataGrid>
                    <Border Grid.Row="1" Margin="0,8,0,0" Padding="10,6" CornerRadius="8" Background="{DynamicResource Brush.SurfaceMuted}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Style="{StaticResource FieldLabelTextStyle}" Text="Total Saldo Awal:" />
                            <TextBlock Margin="8,0,16,0" FontWeight="SemiBold" Foreground="{DynamicResource Brush.TextPrimary}" Text="{Binding CashFlowTotalOpening, StringFormat=N2}" />
                            <TextBlock Style="{StaticResource FieldLabelTextStyle}" Text="Total Kas Masuk:" />
                            <TextBlock Margin="8,0,16,0" FontWeight="SemiBold" Foreground="{DynamicResource Brush.TextPrimary}" Text="{Binding CashFlowTotalIn, StringFormat=N2}" />
                            <TextBlock Style="{StaticResource FieldLabelTextStyle}" Text="Total Kas Keluar:" />
                            <TextBlock Margin="8,0,16,0" FontWeight="SemiBold" Foreground="{DynamicResource Brush.TextPrimary}" Text="{Binding CashFlowTotalOut, StringFormat=N2}" />
                            <TextBlock Style="{StaticResource FieldLabelTextStyle}" Text="Kenaikan/Penurunan:" />
                            <TextBlock Margin="8,0,16,0" FontWeight="SemiBold" Foreground="{DynamicResource Brush.TextPrimary}" Text="{Binding CashFlowNetChange, StringFormat=N2}" />
                            <TextBlock Style="{StaticResource FieldLabelTextStyle}" Text="Total Saldo Akhir:" />
                            <TextBlock Margin="8,0,0,0" FontWeight="SemiBold" Foreground="{DynamicResource Brush.TextPrimary}" Text="{Binding CashFlowTotalEnding, StringFormat=N2}" />
                        </StackPanel>
                    </Border>
                </Grid>
                </TabItem>
                <TabItem Header="Kustom">
                <Border Margin="10"
                        Padding="14"
                        CornerRadius="{DynamicResource Radius.Card}"
                        BorderThickness="1"
                        Background="{DynamicResource Brush.SurfaceMuted}"
                        BorderBrush="{DynamicResource Brush.Border}">
                    <StackPanel>
                        <TextBlock Text="{Binding ReportPlaceholderTitle}"
                                   Style="{StaticResource SettingsSectionTitleTextStyle}" />
                        <TextBlock Margin="0,8,0,0"
                                   TextWrapping="Wrap"
                                   Foreground="{DynamicResource Brush.TextSecondary}"
                                   Text="{Binding ReportPlaceholderDescription}" />
                    </StackPanel>
                </Border>
                </TabItem>
            </TabControl>

            <Border Margin="12"
                    Padding="14"
                    CornerRadius="{DynamicResource Radius.Card}"
                    BorderThickness="1"
                    Background="{DynamicResource Brush.SurfaceMuted}"
                    BorderBrush="{DynamicResource Brush.Border}"
                    VerticalAlignment="Top"
                    Visibility="{Binding IsReportPlaceholderSelected, Converter={StaticResource BoolToVisibilityConverter}}">
                <StackPanel>
                    <TextBlock Text="{Binding ReportPlaceholderTitle}"
                               Style="{StaticResource SettingsSectionTitleTextStyle}" />
                    <TextBlock Margin="0,8,0,0"
                               TextWrapping="Wrap"
                               Foreground="{DynamicResource Brush.TextSecondary}"
                               Text="{Binding ReportPlaceholderDescription}" />
                </StackPanel>
            </Border>
        </Grid>
        <ContentControl Grid.Row="3" Content="{Binding}" ContentTemplate="{StaticResource WorkspaceStatusMessageTemplate}" />
    </Grid>
</UserControl>
