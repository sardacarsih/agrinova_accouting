<UserControl x:Class="Accounting.Views.Components.SettingsOrganizationControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             UseLayoutRounding="True"
             SnapsToDevicePixels="True">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="10">
            <Border Style="{StaticResource SummaryCardStyle}">
                <StackPanel>
                    <TextBlock Style="{StaticResource SectionHeaderTextStyle}" Text="Pengaturan Perusahaan dan Lokasi" />
                    <TextBlock Margin="0,4,0,0"
                               Style="{StaticResource MetaCaptionTextStyle}"
                               Text="Kelola master perusahaan terlebih dahulu, lalu kelola lokasi berdasarkan perusahaan yang dipilih." />
                </StackPanel>
            </Border>

            <Border Style="{StaticResource SettingsSectionCardStyle}">
                <StackPanel>
                    <TextBlock Style="{StaticResource SettingsSectionTitleTextStyle}" Text="Master Perusahaan" />
                    <TextBlock Style="{StaticResource SettingsSectionSubtitleTextStyle}"
                               Text="Daftar ini menjadi sumber utama untuk seluruh konfigurasi perusahaan." />

                    <WrapPanel Style="{StaticResource SettingsActionWrapPanelStyle}">
                        <Button Command="{Binding NewCompanyCommand}"
                                Style="{StaticResource SecondaryPillButtonStyle}"
                                Content="Perusahaan Baru" />
                        <Button Margin="8,0,0,0"
                                Command="{Binding SaveCompanyCommand}"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Content="Simpan Perusahaan" />
                        <Button Margin="8,0,0,0"
                                Command="{Binding DeleteCompanyCommand}"
                                IsEnabled="{Binding HasSelectedCompany}"
                                Style="{StaticResource SecondaryPillButtonStyle}"
                                Content="Nonaktifkan" />
                    </WrapPanel>

                    <Grid Margin="0,10,0,0">
                        <DataGrid Style="{StaticResource EnterpriseDataGridStyle}"
                                  ItemsSource="{Binding Companies}"
                                  SelectedItem="{Binding SelectedCompany, Mode=TwoWay}"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  MinHeight="220">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Kode" Binding="{Binding Code}" Width="110" />
                                <DataGridTextColumn Header="Nama" Binding="{Binding Name}" Width="*" />
                                <DataGridCheckBoxColumn Header="Aktif" Binding="{Binding IsActive}" Width="70" />
                            </DataGrid.Columns>
                        </DataGrid>
                        <Border IsHitTestVisible="False">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Companies.Count}" Value="0">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <TextBlock Text="Belum ada data perusahaan."
                                       FontSize="13"
                                       Foreground="{DynamicResource Brush.TextMuted}"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center" />
                        </Border>
                    </Grid>

                    <Border Style="{StaticResource SettingsHintCardStyle}">
                        <StackPanel>
                            <TextBlock Style="{StaticResource FieldLabelTextStyle}" Text="Editor Perusahaan" />
                            <TextBlock Margin="0,6,0,0" Style="{StaticResource FieldLabelTextStyle}" Text="Kode" />
                            <TextBox Margin="0,6,0,0"
                                     Text="{Binding SelectedCompany.Code, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource InputTextBoxStyle}" />
                            <TextBlock Margin="0,8,0,0" Style="{StaticResource FieldLabelTextStyle}" Text="Nama" />
                            <TextBox Margin="0,6,0,0"
                                     Text="{Binding SelectedCompany.Name, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource InputTextBoxStyle}" />
                            <CheckBox Margin="0,8,0,0"
                                      IsChecked="{Binding SelectedCompany.IsActive}"
                                      Style="{StaticResource CompactCheckBoxStyle}"
                                      Content="Aktif" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource SettingsSectionCardStyle}">
                <StackPanel>
                    <TextBlock Style="{StaticResource SettingsSectionTitleTextStyle}" Text="Master Lokasi per Perusahaan" />
                    <TextBlock Style="{StaticResource SettingsSectionSubtitleTextStyle}">
                        <Run Text="Perusahaan dipilih: " />
                        <Run Text="{Binding SelectedCompany.Code}" />
                        <Run Text=" - " />
                        <Run Text="{Binding SelectedCompany.Name}" />
                    </TextBlock>

                    <WrapPanel Style="{StaticResource SettingsActionWrapPanelStyle}">
                        <Button Command="{Binding NewLocationCommand}"
                                Style="{StaticResource SecondaryPillButtonStyle}"
                                Content="Lokasi Baru" />
                        <Button Margin="8,0,0,0"
                                Command="{Binding SaveLocationCommand}"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Content="Simpan Lokasi" />
                        <Button Margin="8,0,0,0"
                                Command="{Binding DeleteLocationCommand}"
                                IsEnabled="{Binding HasSelectedLocation}"
                                Style="{StaticResource SecondaryPillButtonStyle}"
                                Content="Nonaktifkan" />
                    </WrapPanel>

                    <Grid Margin="0,10,0,0">
                        <DataGrid Style="{StaticResource EnterpriseDataGridStyle}"
                                  ItemsSource="{Binding FilteredLocations}"
                                  SelectedItem="{Binding SelectedLocation, Mode=TwoWay}"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  MinHeight="220">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Perusahaan" Binding="{Binding CompanyCode}" Width="110" />
                                <DataGridTextColumn Header="Kode" Binding="{Binding Code}" Width="100" />
                                <DataGridTextColumn Header="Nama" Binding="{Binding Name}" Width="*" />
                                <DataGridCheckBoxColumn Header="Aktif" Binding="{Binding IsActive}" Width="70" />
                            </DataGrid.Columns>
                        </DataGrid>

                        <Border IsHitTestVisible="False">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding FilteredLocations.Count}" Value="0">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <TextBlock Text="Belum ada lokasi untuk perusahaan terpilih."
                                       FontSize="13"
                                       Foreground="{DynamicResource Brush.TextMuted}"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center" />
                        </Border>
                    </Grid>

                    <Border Style="{StaticResource SettingsHintCardStyle}">
                        <StackPanel>
                            <TextBlock Style="{StaticResource FieldLabelTextStyle}" Text="Editor Lokasi" />
                            <TextBlock Margin="0,6,0,0" Style="{StaticResource FieldLabelTextStyle}" Text="Perusahaan" />
                            <ComboBox Margin="0,6,0,0"
                                      Style="{StaticResource InputComboBoxStyle}"
                                      ItemsSource="{Binding ActiveCompanyOptions}"
                                      SelectedValuePath="Id"
                                      SelectedValue="{Binding SelectedLocation.CompanyId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock>
                                            <Run Text="{Binding Code}" />
                                            <Run Text=" - " />
                                            <Run Text="{Binding Name}" />
                                        </TextBlock>
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                            <TextBlock Margin="0,8,0,0" Style="{StaticResource FieldLabelTextStyle}" Text="Kode" />
                            <TextBox Margin="0,6,0,0"
                                     Text="{Binding SelectedLocation.Code, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource InputTextBoxStyle}" />
                            <TextBlock Margin="0,8,0,0" Style="{StaticResource FieldLabelTextStyle}" Text="Nama" />
                            <TextBox Margin="0,6,0,0"
                                     Text="{Binding SelectedLocation.Name, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource InputTextBoxStyle}" />
                            <CheckBox Margin="0,8,0,0"
                                      IsChecked="{Binding SelectedLocation.IsActive}"
                                      Style="{StaticResource CompactCheckBoxStyle}"
                                      Content="Aktif" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
