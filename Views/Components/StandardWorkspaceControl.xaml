<UserControl x:Class="Accounting.Views.Components.StandardWorkspaceControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             UseLayoutRounding="True"
             SnapsToDevicePixels="True">
    <Border Padding="18"
            VerticalAlignment="Top"
            Background="{DynamicResource Brush.SurfaceMuted}"
            CornerRadius="12">
        <StackPanel>
            <TextBlock Text="{Binding CurrentScopePlaceholderTitle}"
                       FontSize="24"
                       FontWeight="SemiBold"
                       Foreground="{DynamicResource Brush.TextPrimary}" />
            <TextBlock Margin="0,12,0,0"
                       FontSize="14"
                       Text="{Binding CurrentScopePlaceholderDescription}"
                       TextWrapping="Wrap"
                       Foreground="{DynamicResource Brush.TextSecondary}" />
            <TextBlock Margin="0,18,0,0"
                       FontSize="12"
                       Text="Workspace ini sudah terproteksi akses dan siap digunakan."
                       Foreground="{DynamicResource Brush.TextMuted}" />
        </StackPanel>
    </Border>
</UserControl>
