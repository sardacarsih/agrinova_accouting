<UserControl x:Class="Accounting.Views.Components.UserManagementRolesTabControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             UseLayoutRounding="True"
             SnapsToDevicePixels="True">
    <UserControl.Resources>
        <DataTemplate x:Key="RoleActionOptionTemplate">
            <CheckBox Margin="0,0,0,4"
                      IsChecked="{Binding IsSelected}"
                      IsEnabled="{Binding IsEnabled}"
                      Style="{StaticResource CompactCheckBoxStyle}">
                <TextBlock Text="{Binding Label}" TextTrimming="CharacterEllipsis" ToolTip="{Binding Label}" />
            </CheckBox>
        </DataTemplate>

        <DataTemplate x:Key="RoleEditorTemplate">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Style="{StaticResource SettingsSectionCardStyle}" Margin="0,0,0,10">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel>
                            <TextBlock Text="Editor Role" Style="{StaticResource SettingsSectionTitleTextStyle}" />
                            <TextBlock Margin="0,4,0,0"
                                       Style="{StaticResource SettingsSectionSubtitleTextStyle}"
                                       Text="Kelola identitas role dan permission aksi per modul." />
                        </StackPanel>

                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                            <Border Style="{StaticResource ScopeBadgeStyle}">
                                <TextBlock FontSize="11" Foreground="{DynamicResource Brush.TextSecondary}">
                                    <Run Text="Dipilih: " />
                                    <Run Text="{Binding SelectedRolePermissionCount}" />
                                </TextBlock>
                            </Border>
                            <Border Style="{StaticResource ScopeBadgeStyle}" Margin="4,0,0,0">
                                <TextBlock FontSize="11" Foreground="{DynamicResource Brush.TextSecondary}">
                                    <Run Text="Tampil: " />
                                    <Run Text="{Binding VisibleRolePermissionCount}" />
                                </TextBlock>
                            </Border>
                            <Border Style="{StaticResource ScopeBadgeStyle}" Margin="4,0,0,0">
                                <TextBlock FontSize="11" Foreground="{DynamicResource Brush.TextSecondary}">
                                    <Run Text="Pengguna: " />
                                    <Run Text="{Binding SelectedRoleAssignedUserCount}" />
                                </TextBlock>
                            </Border>
                        </StackPanel>
                    </Grid>
                </Border>

                <Grid Grid.Row="1" Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Style="{StaticResource FieldLabelTextStyle}" Text="Kode Role" />
                        <TextBox Margin="0,6,0,0"
                                 Text="{Binding SelectedRole.Code, UpdateSourceTrigger=PropertyChanged}"
                                 IsEnabled="{Binding IsSelectedRoleProtected, Converter={StaticResource InverseBooleanConverter}}"
                                 Style="{StaticResource InputTextBoxStyle}" />
                    </StackPanel>

                    <StackPanel Grid.Column="2">
                        <TextBlock Style="{StaticResource FieldLabelTextStyle}" Text="Nama Role" />
                        <TextBox Margin="0,6,0,0"
                                 Text="{Binding SelectedRole.Name, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource InputTextBoxStyle}" />
                    </StackPanel>
                </Grid>

                <Grid Grid.Row="2">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Orientation="Horizontal">
                        <CheckBox IsChecked="{Binding SelectedRole.IsSuperRole}"
                                  IsEnabled="{Binding IsSelectedRoleProtected, Converter={StaticResource InverseBooleanConverter}}"
                                  Style="{StaticResource CompactCheckBoxStyle}"
                                  Content="Super role" />
                        <CheckBox Margin="14,0,0,0"
                                  IsChecked="{Binding SelectedRole.IsActive}"
                                  IsEnabled="{Binding IsSelectedRoleProtected, Converter={StaticResource InverseBooleanConverter}}"
                                  Style="{StaticResource CompactCheckBoxStyle}"
                                  Content="Aktif" />
                    </StackPanel>

                    <Border Grid.Row="1" Style="{StaticResource SettingsSectionCardStyle}" Margin="0,10,0,0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <WrapPanel Grid.Row="0">
                                <TextBox Width="240"
                                         Text="{Binding RolePermissionSearchText, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource InputTextBoxStyle}" />
                                <CheckBox Margin="10,0,0,0"
                                          VerticalAlignment="Center"
                                          IsChecked="{Binding ShowSelectedRolePermissionsOnly}"
                                          Style="{StaticResource CompactCheckBoxStyle}"
                                          Content="Hanya terpilih" />
                                <Button Margin="10,0,0,0"
                                        Command="{Binding ExpandAllRolePermissionsCommand}"
                                        Style="{StaticResource SelectAllLinkStyle}"
                                        Content="Expand" />
                                <Button Margin="6,0,0,0"
                                        Command="{Binding CollapseAllRolePermissionsCommand}"
                                        Style="{StaticResource SelectAllLinkStyle}"
                                        Content="Collapse" />
                                <Button Margin="6,0,0,0"
                                        Command="{Binding SelectAllScopesCommand}"
                                        Style="{StaticResource SelectAllLinkStyle}"
                                        Content="Semua" />
                                <Button Margin="6,0,0,0"
                                        Command="{Binding DeselectAllScopesCommand}"
                                        Style="{StaticResource SelectAllLinkStyle}"
                                        Content="Kosongkan" />
                                <Button Margin="6,0,0,0"
                                        Command="{Binding ClearRolePermissionFilterCommand}"
                                        IsEnabled="{Binding HasRolePermissionFilter}"
                                        Style="{StaticResource SelectAllLinkStyle}"
                                        Content="Reset Filter" />
                            </WrapPanel>

                            <TextBlock Grid.Row="1"
                                       Margin="0,6,0,0"
                                       Style="{StaticResource SettingsSectionSubtitleTextStyle}"
                                       Text="Cari berdasarkan modul, submodul, nama aksi, atau kode." />

                            <Border Grid.Row="2"
                                    Margin="0,10,0,0"
                                    Padding="10,8"
                                    CornerRadius="8"
                                    Background="{DynamicResource Brush.SurfaceMuted}"
                                    BorderBrush="{DynamicResource Brush.BorderSoft}"
                                    BorderThickness="1">
                                <TextBlock Foreground="{DynamicResource Brush.TextMuted}" TextWrapping="Wrap">
                                    <Run Text="Catatan: " />
                                    <Run Text="submodul API Inv berisi permission sinkronisasi, import template/data, dan integrasi jurnal." />
                                    <LineBreak />
                                    <Run Text="Permission ini terpisah dari CRUD master inventory seperti Item, Kategori, Satuan, dan Gudang." />
                                </TextBlock>
                            </Border>
                        </Grid>
                    </Border>

                    <Border Grid.Row="2" Margin="0,10,0,0" Style="{StaticResource CardBorderStyle}" Padding="10">
                        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                            <ItemsControl ItemsSource="{Binding RolePermissionModules}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Expander IsExpanded="{Binding IsExpanded, Mode=TwoWay}" Margin="0,0,0,8">
                                            <Expander.Header>
                                                <DockPanel>
                                                    <TextBlock FontWeight="SemiBold" Foreground="{DynamicResource Brush.TextPrimary}">
                                                        <Run Text="{Binding ModuleName}" />
                                                        <Run Text=" (" />
                                                        <Run Text="{Binding SelectedActionsCount}" />
                                                        <Run Text=" dipilih)" />
                                                    </TextBlock>
                                                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                                                        <Button Content="Semua"
                                                                Command="{Binding DataContext.SelectAllModuleActionsCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                CommandParameter="{Binding}"
                                                                Style="{StaticResource SelectAllLinkStyle}" />
                                                        <Button Margin="6,0,0,0"
                                                                Content="Kosongkan"
                                                                Command="{Binding DataContext.DeselectAllModuleActionsCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                CommandParameter="{Binding}"
                                                                Style="{StaticResource SelectAllLinkStyle}" />
                                                    </StackPanel>
                                                </DockPanel>
                                            </Expander.Header>

                                            <ItemsControl Margin="0,8,0,0" ItemsSource="{Binding Submodules}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Expander IsExpanded="{Binding IsExpanded, Mode=TwoWay}" Margin="0,0,0,6">
                                                            <Expander.Header>
                                                                <DockPanel>
                                                                    <TextBlock FontWeight="SemiBold" Foreground="{DynamicResource Brush.TextPrimary}">
                                                                        <Run Text="{Binding SubmoduleName}" />
                                                                        <Run Text=" (" />
                                                                        <Run Text="{Binding SelectedActionsCount}" />
                                                                        <Run Text=" dipilih)" />
                                                                    </TextBlock>
                                                                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                                                                        <Button Content="Semua"
                                                                                Command="{Binding DataContext.SelectAllSubmoduleActionsCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                                CommandParameter="{Binding}"
                                                                                Style="{StaticResource SelectAllLinkStyle}" />
                                                                        <Button Margin="6,0,0,0"
                                                                                Content="Kosongkan"
                                                                                Command="{Binding DataContext.DeselectAllSubmoduleActionsCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                                CommandParameter="{Binding}"
                                                                                Style="{StaticResource SelectAllLinkStyle}" />
                                                                    </StackPanel>
                                                                </DockPanel>
                                                            </Expander.Header>

                                                            <ItemsControl Margin="0,8,0,0"
                                                                          ItemsSource="{Binding Actions}"
                                                                          ItemTemplate="{StaticResource RoleActionOptionTemplate}" />
                                                        </Expander>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </Expander>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Border>
                </Grid>

                <Border Grid.Row="3"
                        Margin="0,10,0,0"
                        Padding="10"
                        CornerRadius="10"
                        BorderThickness="1"
                        Background="{DynamicResource Brush.SurfaceMuted}"
                        BorderBrush="{DynamicResource Brush.Border}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="8" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="8" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource Brush.TextSecondary}"
                                   FontWeight="SemiBold"
                                   Text="{Binding RoleEditorDirtyMessage}" />

                        <Button Grid.Column="1"
                                Command="{Binding DiscardRoleChangesCommand}"
                                IsEnabled="{Binding IsRoleEditorDirty}"
                                Style="{StaticResource SecondaryPillButtonStyle}"
                                Content="Batalkan" />
                        <Button Grid.Column="3"
                                Command="{Binding SaveRoleCommand}"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Content="Simpan Role" />
                        <Button Grid.Column="5"
                                Command="{Binding DeleteRoleCommand}"
                                IsEnabled="{Binding IsSelectedRoleProtected, Converter={StaticResource InverseBooleanConverter}}"
                                Style="{StaticResource SecondaryPillButtonStyle}"
                                Content="Hapus Role" />
                    </Grid>
                </Border>
            </Grid>
        </DataTemplate>
    </UserControl.Resources>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <UniformGrid Grid.Row="0" Columns="4" Margin="0,0,0,12">
            <Border Style="{StaticResource SummaryCardStyle}" Margin="0,0,6,0">
                <StackPanel>
                    <TextBlock Text="Total Role" FontSize="11" Foreground="{DynamicResource Brush.TextMuted}" />
                    <TextBlock Text="{Binding TotalRolesCount}" FontSize="22" FontWeight="SemiBold"
                               Foreground="{DynamicResource Brush.TextPrimary}" Margin="0,4,0,0" />
                </StackPanel>
            </Border>
            <Border Style="{StaticResource SummaryCardStyle}" Margin="3,0,3,0">
                <StackPanel>
                    <TextBlock Text="Role Aktif" FontSize="11" Foreground="{DynamicResource Brush.TextMuted}" />
                    <TextBlock Text="{Binding ActiveRolesCount}" FontSize="22" FontWeight="SemiBold"
                               Foreground="{DynamicResource Brush.Success}" Margin="0,4,0,0" />
                </StackPanel>
            </Border>
            <Border Style="{StaticResource SummaryCardStyle}" Margin="3,0,3,0">
                <StackPanel>
                    <TextBlock Text="Aksi Permission" FontSize="11" Foreground="{DynamicResource Brush.TextMuted}" />
                    <TextBlock Text="{Binding TotalScopesCount}" FontSize="22" FontWeight="SemiBold"
                               Foreground="{DynamicResource Brush.TextPrimary}" Margin="0,4,0,0" />
                </StackPanel>
            </Border>
            <Border Style="{StaticResource SummaryCardStyle}" Margin="6,0,0,0">
                <StackPanel>
                    <TextBlock Text="Total Pengguna" FontSize="11" Foreground="{DynamicResource Brush.TextMuted}" />
                    <TextBlock Text="{Binding TotalUsersCount}" FontSize="22" FontWeight="SemiBold"
                               Foreground="{DynamicResource Brush.TextPrimary}" Margin="0,4,0,0" />
                </StackPanel>
            </Border>
        </UniformGrid>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300" MinWidth="260" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource CardBorderStyle}" Padding="10">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="Daftar Role" Style="{StaticResource SettingsSectionTitleTextStyle}" />
                    <TextBox Grid.Row="1"
                             Margin="0,8,0,0"
                             Text="{Binding RoleSearchText, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource InputTextBoxStyle}" />

                    <ListBox Grid.Row="2"
                             Margin="0,8,0,0"
                             ItemsSource="{Binding FilteredRoles}"
                             SelectedItem="{Binding SelectedRole, Mode=TwoWay}"
                             BorderThickness="0"
                             Background="Transparent"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="8,7" CornerRadius="8" Margin="0,2" BorderThickness="1" BorderBrush="{DynamicResource Brush.Border}">
                                    <StackPanel>
                                        <DockPanel>
                                            <TextBlock Text="{Binding Code}"
                                                       FontSize="13"
                                                       FontWeight="SemiBold"
                                                       Foreground="{DynamicResource Brush.TextPrimary}"
                                                       TextTrimming="CharacterEllipsis" />
                                            <Ellipse DockPanel.Dock="Right"
                                                     Width="8" Height="8"
                                                     VerticalAlignment="Center"
                                                     Margin="6,0,0,0">
                                                <Ellipse.Style>
                                                    <Style TargetType="Ellipse">
                                                        <Setter Property="Fill" Value="{DynamicResource Brush.TextMuted}" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                                <Setter Property="Fill" Value="{DynamicResource Brush.Success}" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Ellipse.Style>
                                            </Ellipse>
                                        </DockPanel>
                                        <TextBlock Text="{Binding Name}"
                                                   Margin="0,2,0,0"
                                                   FontSize="11"
                                                   Foreground="{DynamicResource Brush.TextMuted}"
                                                   TextTrimming="CharacterEllipsis" />
                                        <WrapPanel Margin="0,6,0,0">
                                            <Border Style="{StaticResource ScopeBadgeStyle}">
                                                <TextBlock FontSize="11" Foreground="{DynamicResource Brush.TextSecondary}">
                                                    <Run Text="Pengguna: " />
                                                    <Run Text="{Binding AssignedUserCount}" />
                                                </TextBlock>
                                            </Border>
                                            <Border Style="{StaticResource ScopeBadgeStyle}">
                                                <TextBlock FontSize="11" Foreground="{DynamicResource Brush.TextSecondary}">
                                                    <Run Text="Izin: " />
                                                    <Run Text="{Binding PermissionCount}" />
                                                </TextBlock>
                                            </Border>
                                        </WrapPanel>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <Grid Grid.Row="3" Margin="0,8,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="8" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0"
                                Command="{Binding NewRoleCommand}"
                                Style="{StaticResource SecondaryPillButtonStyle}"
                                Content="Role Baru" />
                        <Button Grid.Column="2"
                                Command="{Binding CloneRoleCommand}"
                                IsEnabled="{Binding CanCloneSelectedRole}"
                                Style="{StaticResource SecondaryPillButtonStyle}"
                                Content="Duplikasi" />
                    </Grid>
                </Grid>
            </Border>

            <ContentControl Grid.Column="2" Content="{Binding}" ContentTemplate="{StaticResource RoleEditorTemplate}" />
        </Grid>
    </Grid>
</UserControl>
