<UserControl x:Class="Accounting.Views.Components.UserManagementUsersTabControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             UseLayoutRounding="True"
             SnapsToDevicePixels="True">
    <UserControl.Resources>
        <Style x:Key="CenteredCellTextStyle" TargetType="TextBlock">
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="TextAlignment" Value="Center" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
        <DataTemplate x:Key="AccessAuditMatrixSubmoduleTemplate">
            <StackPanel Margin="0,2">
                <TextBlock Text="{Binding SubmoduleName}" FontWeight="SemiBold" />
                <TextBlock Margin="0,2,0,0"
                           FontSize="10"
                           Foreground="{DynamicResource Brush.TextMuted}"
                           Text="{Binding AccessSummary}" />
            </StackPanel>
        </DataTemplate>
    </UserControl.Resources>
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <UniformGrid Grid.Row="0" Columns="4" Margin="0,0,0,12">
            <Border Style="{StaticResource SummaryCardStyle}" Margin="0,0,6,0">
                <StackPanel>
                    <TextBlock Text="Total Pengguna" FontSize="11" Foreground="{DynamicResource Brush.TextMuted}" />
                    <TextBlock Text="{Binding TotalUsersCount}" FontSize="22" FontWeight="SemiBold" Margin="0,4,0,0" />
                </StackPanel>
            </Border>
            <Border Style="{StaticResource SummaryCardStyle}" Margin="3,0,3,0">
                <StackPanel>
                    <TextBlock Text="Role Aktif" FontSize="11" Foreground="{DynamicResource Brush.TextMuted}" />
                    <TextBlock Text="{Binding ActiveRolesCount}" FontSize="22" FontWeight="SemiBold" Margin="0,4,0,0" />
                </StackPanel>
            </Border>
            <Border Style="{StaticResource SummaryCardStyle}" Margin="3,0,3,0">
                <StackPanel>
                    <TextBlock Text="Company Aktif" FontSize="11" Foreground="{DynamicResource Brush.TextMuted}" />
                    <TextBlock Text="{Binding ActiveCompanyOptions.Count}" FontSize="22" FontWeight="SemiBold" Margin="0,4,0,0" />
                </StackPanel>
            </Border>
            <Border Style="{StaticResource SummaryCardStyle}" Margin="6,0,0,0">
                <StackPanel>
                    <TextBlock Text="Aksi RBAC" FontSize="11" Foreground="{DynamicResource Brush.TextMuted}" />
                    <TextBlock Text="{Binding TotalScopesCount}" FontSize="22" FontWeight="SemiBold" Margin="0,4,0,0" />
                </StackPanel>
            </Border>
        </UniformGrid>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="360" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="360" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource CardBorderStyle}" Padding="10">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <TextBlock Text="Audit Akses Pengguna" Style="{StaticResource SettingsSectionTitleTextStyle}" />
                    <TextBlock Grid.Row="1" Margin="0,4,0,0" Style="{StaticResource SettingsSectionSubtitleTextStyle}"
                               Text="Pilih user untuk melihat role, cakupan organisasi, dan permission efektif." />
                    <TextBox Grid.Row="1" Margin="0,34,0,0" Text="{Binding UserSearchText, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource InputTextBoxStyle}" />
                    <Grid Grid.Row="2" Margin="0,10,0,0">
                        <DataGrid Style="{StaticResource EnterpriseDataGridStyle}"
                                  ItemsSource="{Binding FilteredUsers}"
                                  SelectedItem="{Binding SelectedUser, Mode=TwoWay}"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  CanUserAddRows="False"
                                  CanUserDeleteRows="False"
                                  CanUserResizeRows="False"
                                  MinHeight="220">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Username" Binding="{Binding Username}" Width="106" />
                                <DataGridTextColumn Header="Nama" Binding="{Binding FullName}" Width="*" />
                                <DataGridTemplateColumn Header="Status" Width="92">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Border Padding="8,2" CornerRadius="8" BorderThickness="1">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background" Value="{DynamicResource Brush.ErrorSubtle}" />
                                                        <Setter Property="BorderBrush" Value="{DynamicResource Brush.Error}" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                                <Setter Property="Background" Value="{DynamicResource Brush.InfoSubtle}" />
                                                                <Setter Property="BorderBrush" Value="{DynamicResource Brush.Info}" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <TextBlock HorizontalAlignment="Center" FontSize="11" FontWeight="SemiBold">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Text" Value="Nonaktif" />
                                                            <Setter Property="Foreground" Value="{DynamicResource Brush.Error}" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                                    <Setter Property="Text" Value="Aktif" />
                                                                    <Setter Property="Foreground" Value="{DynamicResource Brush.Info}" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </Border>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTextColumn Header="Role" Binding="{Binding RoleDisplay}" Width="122" />
                            </DataGrid.Columns>
                        </DataGrid>

                        <Border IsHitTestVisible="False">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding FilteredUsers.Count}" Value="0">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <TextBlock Text="Tidak ada pengguna yang cocok dengan pencarian saat ini."
                                       FontSize="13"
                                       Foreground="{DynamicResource Brush.TextMuted}"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center" />
                        </Border>
                    </Grid>
                    <Grid Grid.Row="3" Margin="0,8,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="8" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" Command="{Binding NewUserCommand}" Style="{StaticResource SecondaryPillButtonStyle}" Content="Pengguna Baru" />
                        <Button Grid.Column="2" Command="{Binding RefreshCommand}" Style="{StaticResource SecondaryPillButtonStyle}" Content="Muat Ulang" />
                    </Grid>
                </Grid>
            </Border>

            <Grid Grid.Column="2">
                <Border Style="{StaticResource CardBorderStyle}" Padding="18"
                        Visibility="{Binding HasSelectedUserAudit, Converter={StaticResource InverseBoolToVisibilityConverter}}">
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Pilih pengguna untuk memulai audit akses." Style="{StaticResource SettingsSectionTitleTextStyle}" />
                        <TextBlock Margin="0,6,0,0" Style="{StaticResource SettingsSectionSubtitleTextStyle}"
                                   Text="Panel ini akan menampilkan role efektif, konteks default, dan daftar permission yang diwariskan dari role." />
                    </StackPanel>
                </Border>

                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                              Visibility="{Binding HasSelectedUserAudit, Converter={StaticResource BoolToVisibilityConverter}}">
                    <StackPanel>
                        <Border Style="{StaticResource SettingsSectionCardStyle}" Margin="0">
                            <StackPanel>
                                <TextBlock Text="{Binding SelectedUser.FullName, TargetNullValue=Pilih pengguna}" Style="{StaticResource SettingsSectionTitleTextStyle}" />
                                <TextBlock Margin="0,4,0,0" Foreground="{DynamicResource Brush.TextMuted}">
                                    <Run Text="{Binding SelectedUser.Username, Mode=OneWay, TargetNullValue=-}" />
                                    <Run Text=" • " />
                                    <Run Text="{Binding SelectedUser.Email, Mode=OneWay, TargetNullValue=-}" />
                                </TextBlock>
                                <WrapPanel Margin="0,10,0,0">
                                    <Border Style="{StaticResource InlineMetricBadgeStyle}"><TextBlock FontSize="11"><Run Text="Role: " /><Run Text="{Binding SelectedUserRoleAuditLabel, Mode=OneWay}" /></TextBlock></Border>
                                    <Border Style="{StaticResource InlineMetricBadgeStyle}"><TextBlock FontSize="11"><Run Text="Company: " /><Run Text="{Binding SelectedUserCompanyAccessCount, Mode=OneWay}" /></TextBlock></Border>
                                    <Border Style="{StaticResource InlineMetricBadgeStyle}"><TextBlock FontSize="11"><Run Text="Lokasi: " /><Run Text="{Binding SelectedUserLocationAccessCount, Mode=OneWay}" /></TextBlock></Border>
                                    <Border Style="{StaticResource InlineMetricBadgeStyle}"><TextBlock FontSize="11"><Run Text="Aksi: " /><Run Text="{Binding SelectedUserEffectivePermissionCount, Mode=OneWay}" /></TextBlock></Border>
                                </WrapPanel>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource SettingsSectionCardStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="16" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Konteks Default" Style="{StaticResource SettingsSectionTitleTextStyle}" />
                                    <TextBlock Margin="0,6,0,0" Style="{StaticResource SettingsSectionSubtitleTextStyle}" Text="{Binding SelectedUserDefaultContextSummary, Mode=OneWay}" />
                                    <Border Style="{StaticResource SettingsHintCardStyle}">
                                        <TextBlock Text="{Binding SelectedUserAccessGovernanceMessage, Mode=OneWay}" TextWrapping="Wrap"
                                                   Foreground="{DynamicResource Brush.TextMuted}" />
                                    </Border>
                                    <TextBlock Margin="0,10,0,0" Style="{StaticResource FieldLabelTextStyle}" Text="Company Terpilih" />
                                    <ItemsControl Margin="0,6,0,0" ItemsSource="{Binding UserAuditCompanyAccessItems}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate><TextBlock Margin="0,0,0,4" Text="{Binding}" /></DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Lokasi Terpilih" Style="{StaticResource SettingsSectionTitleTextStyle}" />
                                    <TextBlock Margin="0,6,0,0" Style="{StaticResource SettingsSectionSubtitleTextStyle}" Text="Cakupan ini ikut berubah saat role atau company/location diganti." />
                                    <ScrollViewer Margin="0,10,0,0" MaxHeight="220" VerticalScrollBarVisibility="Auto">
                                        <ItemsControl ItemsSource="{Binding UserAuditLocationAccessItems}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate><TextBlock Margin="0,0,0,4" Text="{Binding}" /></DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </ScrollViewer>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <Border Style="{StaticResource SettingsSectionCardStyle}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>
                                <DockPanel>
                                    <TextBlock Text="Permission Efektif" Style="{StaticResource SettingsSectionTitleTextStyle}" />
                                    <Border DockPanel.Dock="Right" Style="{StaticResource ScopeBadgeStyle}">
                                        <TextBlock FontSize="11"><Run Text="Modul: " /><Run Text="{Binding SelectedUserEffectiveModuleCount, Mode=OneWay}" /></TextBlock>
                                    </Border>
                                </DockPanel>
                                <StackPanel Grid.Row="1" Margin="0,10,0,0">
                                    <TextBox Text="{Binding UserAuditPermissionSearchText, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource InputTextBoxStyle}" />
                                    <WrapPanel Margin="0,8,0,0">
                                        <Border Style="{StaticResource InlineMetricBadgeStyle}">
                                            <TextBlock FontSize="11">✓ = izin efektif aktif</TextBlock>
                                        </Border>
                                        <Border Style="{StaticResource InlineMetricBadgeStyle}">
                                            <TextBlock FontSize="11">- = action tidak tersedia</TextBlock>
                                        </Border>
                                        <Border Style="{StaticResource InlineMetricBadgeStyle}">
                                            <TextBlock FontSize="11">Hover sel untuk lihat sumber role</TextBlock>
                                        </Border>
                                        <Border Style="{StaticResource InlineMetricBadgeStyle}">
                                            <TextBlock FontSize="11">Header action otomatis compact saat kolom banyak</TextBlock>
                                        </Border>
                                        <Border Style="{StaticResource InlineMetricBadgeStyle}">
                                            <TextBlock FontSize="11">Warna kolom menandai keluarga action</TextBlock>
                                        </Border>
                                    </WrapPanel>
                                </StackPanel>
                                <ScrollViewer Grid.Row="2" Margin="0,10,0,0" VerticalScrollBarVisibility="Auto">
                                    <Grid>
                                        <ItemsControl ItemsSource="{Binding UserAuditPermissionModules}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Expander Margin="0,0,0,8" IsExpanded="{Binding IsExpanded, Mode=TwoWay}">
                                                        <Expander.Header>
                                                            <DockPanel LastChildFill="False">
                                                                <TextBlock FontWeight="SemiBold">
                                                                    <Run Text="{Binding ModuleName, Mode=OneWay}" />
                                                                    <Run Text=" (" />
                                                                    <Run Text="{Binding ActionCount, Mode=OneWay}" />
                                                                    <Run Text=" aksi)" />
                                                                </TextBlock>
                                                                <Border DockPanel.Dock="Right"
                                                                        Margin="10,0,0,0"
                                                                        Style="{StaticResource ScopeBadgeStyle}">
                                                                    <TextBlock FontSize="10">
                                                                        <Run Text="{Binding MatrixRows.Count, Mode=OneWay}" />
                                                                        <Run Text=" submodul" />
                                                                    </TextBlock>
                                                                </Border>
                                                            </DockPanel>
                                                        </Expander.Header>
                                                        <Grid Margin="0,10,0,0">
                                                            <Grid.RowDefinitions>
                                                                <RowDefinition Height="Auto" />
                                                                <RowDefinition Height="*" />
                                                            </Grid.RowDefinitions>

                                                            <DockPanel Grid.Row="0" Margin="0,0,0,6">
                                                                <TextBlock FontSize="10"
                                                                           Foreground="{DynamicResource Brush.TextMuted}"
                                                                           Text="Submodul tetap dibekukan di kiri." />
                                                                <TextBlock DockPanel.Dock="Right"
                                                                           FontSize="10"
                                                                           Foreground="{DynamicResource Brush.TextMuted}"
                                                                           Text="Geser horizontal untuk action lainnya." />
                                                            </DockPanel>

                                                            <Grid Grid.Row="1">
                                                                <DataGrid Margin="0"
                                                                          Tag="{Binding}"
                                                                          Style="{StaticResource EnterpriseDataGridStyle}"
                                                                          ItemsSource="{Binding MatrixRows}"
                                                                          AutoGenerateColumns="False"
                                                                          IsReadOnly="True"
                                                                          CanUserAddRows="False"
                                                                          CanUserDeleteRows="False"
                                                                          CanUserResizeRows="False"
                                                                          FrozenColumnCount="1"
                                                                          MaxHeight="320"
                                                                          Loaded="AccessAuditMatrixGrid_OnLoaded"
                                                                          DataContextChanged="AccessAuditMatrixGrid_OnDataContextChanged">
                                                                    <DataGrid.Columns>
                                                                        <DataGridTemplateColumn Header="Submodul"
                                                                                                CellTemplate="{StaticResource AccessAuditMatrixSubmoduleTemplate}"
                                                                                                Width="220" />
                                                                    </DataGrid.Columns>
                                                                </DataGrid>

                                                                <Border IsHitTestVisible="False">
                                                                    <Border.Style>
                                                                        <Style TargetType="Border">
                                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                                            <Style.Triggers>
                                                                                <DataTrigger Binding="{Binding MatrixRows.Count}" Value="0">
                                                                                    <Setter Property="Visibility" Value="Visible" />
                                                                                </DataTrigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </Border.Style>
                                                                    <TextBlock Text="Tidak ada permission efektif yang cocok untuk matrix ini."
                                                                               FontSize="12"
                                                                               Foreground="{DynamicResource Brush.TextMuted}"
                                                                               HorizontalAlignment="Center"
                                                                               VerticalAlignment="Center" />
                                                                </Border>
                                                            </Grid>
                                                        </Grid>
                                                    </Expander>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>

                                        <Border IsHitTestVisible="False">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding UserAuditPermissionModules.Count}" Value="0">
                                                            <Setter Property="Visibility" Value="Visible" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <TextBlock Text="Tidak ada permission efektif yang cocok dengan filter saat ini."
                                                       FontSize="13"
                                                       Foreground="{DynamicResource Brush.TextMuted}"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center" />
                                        </Border>
                                    </Grid>
                                </ScrollViewer>
                            </Grid>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </Grid>

            <ScrollViewer Grid.Column="4" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <StackPanel>
                    <Border Style="{StaticResource SettingsSectionCardStyle}" Margin="0">
                        <StackPanel>
                            <TextBlock Text="Editor Pengguna" Style="{StaticResource SettingsSectionTitleTextStyle}" />
                            <TextBlock Margin="0,4,0,0" Style="{StaticResource SettingsSectionSubtitleTextStyle}"
                                       Text="Role, company, dan lokasi diubah di sini. Permission aksi tetap dikelola di panel role." />
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource SettingsSectionCardStyle}">
                        <StackPanel IsEnabled="{Binding HasSelectedUser}">
                            <TextBlock Style="{StaticResource FieldLabelTextStyle}" Text="Username" />
                            <TextBox Margin="0,6,0,0" Text="{Binding SelectedUser.Username, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource InputTextBoxStyle}" />
                            <TextBlock Margin="0,10,0,0" Style="{StaticResource FieldLabelTextStyle}" Text="Nama Lengkap" />
                            <TextBox Margin="0,6,0,0" Text="{Binding SelectedUser.FullName, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource InputTextBoxStyle}" />
                            <TextBlock Margin="0,10,0,0" Style="{StaticResource FieldLabelTextStyle}" Text="Email" />
                            <TextBox Margin="0,6,0,0" Text="{Binding SelectedUser.Email, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource InputTextBoxStyle}" />
                            <TextBlock Margin="0,10,0,0" Style="{StaticResource FieldLabelTextStyle}" Text="Password Baru" />
                            <TextBox Margin="0,6,0,0" Text="{Binding NewUserPassword, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource InputTextBoxStyle}" />
                            <CheckBox Margin="0,10,0,0" IsChecked="{Binding SelectedUser.IsActive}" Style="{StaticResource CompactCheckBoxStyle}" Content="Aktif" />
                            <TextBlock Margin="0,10,0,0" Style="{StaticResource FieldLabelTextStyle}" Text="Role" />
                            <ComboBox Margin="0,6,0,0" Style="{StaticResource InputComboBoxStyle}" ItemsSource="{Binding UserRoleOptions}"
                                      SelectedValuePath="Id" SelectedValue="{Binding SelectedUserRoleId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                                <ComboBox.ItemTemplate><DataTemplate><TextBlock Text="{Binding Label}" /></DataTemplate></ComboBox.ItemTemplate>
                            </ComboBox>
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource SettingsSectionCardStyle}">
                        <StackPanel IsEnabled="{Binding HasSelectedUser}">
                            <TextBlock Text="Cakupan Organisasi" Style="{StaticResource SettingsSectionTitleTextStyle}" />
                            <TextBlock Margin="0,10,0,0" Style="{StaticResource FieldLabelTextStyle}" Text="Akses Company" />
                            <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                <Button Content="Semua" Command="{Binding SelectAllUserCompaniesCommand}" Style="{StaticResource SelectAllLinkStyle}" />
                                <TextBlock Text=" / " FontSize="11" VerticalAlignment="Center" />
                                <Button Content="Kosongkan" Command="{Binding DeselectAllUserCompaniesCommand}" Style="{StaticResource SelectAllLinkStyle}" />
                            </StackPanel>
                            <ScrollViewer MaxHeight="120" Margin="0,6,0,0" VerticalScrollBarVisibility="Auto">
                                <ItemsControl ItemsSource="{Binding UserCompanyOptions}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate><CheckBox Margin="0,0,0,4" Style="{StaticResource CompactCheckBoxStyle}" IsChecked="{Binding IsSelected}" Content="{Binding Label}" /></DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                            <TextBlock Margin="0,10,0,0" Style="{StaticResource FieldLabelTextStyle}" Text="Akses Lokasi" />
                            <TextBlock Margin="0,6,0,0"
                                       Style="{StaticResource SettingsSectionSubtitleTextStyle}"
                                       Text="{Binding UserLocationSelectionHint}" />
                            <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                <Button Content="Semua"
                                        Command="{Binding SelectAllUserLocationsCommand}"
                                        IsEnabled="{Binding CanBulkEditUserLocations}"
                                        Style="{StaticResource SelectAllLinkStyle}" />
                                <TextBlock Text=" / " FontSize="11" VerticalAlignment="Center" />
                                <Button Content="Kosongkan"
                                        Command="{Binding DeselectAllUserLocationsCommand}"
                                        IsEnabled="{Binding CanBulkEditUserLocations}"
                                        Style="{StaticResource SelectAllLinkStyle}" />
                            </StackPanel>
                            <ScrollViewer MaxHeight="140" Margin="0,6,0,0" VerticalScrollBarVisibility="Auto">
                                <ItemsControl ItemsSource="{Binding UserLocationOptions}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <CheckBox Margin="0,0,0,4"
                                                      Style="{StaticResource CompactCheckBoxStyle}"
                                                      IsChecked="{Binding IsSelected}"
                                                      IsEnabled="{Binding IsEnabled}"
                                                      Visibility="{Binding IsEnabled, Converter={StaticResource BoolToVisibilityConverter}}"
                                                      Content="{Binding Label}" />
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                            <TextBlock Margin="0,6,0,0"
                                       Style="{StaticResource SettingsSectionSubtitleTextStyle}"
                                       Visibility="{Binding HasVisibleUserLocations, Converter={StaticResource InverseBoolToVisibilityConverter}}"
                                       Text="Belum ada lokasi yang bisa dipilih untuk kombinasi company saat ini." />
                            <TextBlock Margin="0,10,0,0" Style="{StaticResource FieldLabelTextStyle}" Text="Company Default" />
                            <ComboBox Margin="0,6,0,0" Style="{StaticResource InputComboBoxStyle}" ItemsSource="{Binding UserDefaultCompanyOptions}"
                                      SelectedValuePath="Id" SelectedValue="{Binding SelectedUserDefaultCompanyId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                      IsEnabled="{Binding IsSelectedUserSuperRole, Converter={StaticResource InverseBooleanConverter}}" />
                            <TextBlock Margin="0,10,0,0" Style="{StaticResource FieldLabelTextStyle}" Text="Lokasi Default" />
                            <ComboBox Margin="0,6,0,0" Style="{StaticResource InputComboBoxStyle}" ItemsSource="{Binding UserDefaultLocationOptions}"
                                      SelectedValuePath="Id" SelectedValue="{Binding SelectedUserDefaultLocationId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                      IsEnabled="{Binding IsSelectedUserSuperRole, Converter={StaticResource InverseBooleanConverter}}" />
                            <TextBlock Margin="0,8,0,0" FontSize="11" Foreground="{DynamicResource Brush.TextMuted}"
                                       Text="SUPER_ADMIN selalu mendapatkan akses semua company/location aktif."
                                       Visibility="{Binding IsSelectedUserSuperRole, Converter={StaticResource BoolToVisibilityConverter}}" />
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource StickyActionBarStyle}">
                        <StackPanel IsEnabled="{Binding HasSelectedUser}">
                            <TextBlock Text="{Binding SelectedUserAccessGovernanceMessage, Mode=OneWay}" Foreground="{DynamicResource Brush.TextSecondary}" TextWrapping="Wrap" />
                            <Button Margin="0,10,0,0" Command="{Binding SaveUserCommand}" Style="{StaticResource PrimaryButtonStyle}" Content="Simpan Pengguna" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Grid>
</UserControl>
