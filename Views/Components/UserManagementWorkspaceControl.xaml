<UserControl x:Class="Accounting.Views.Components.UserManagementWorkspaceControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:comp="clr-namespace:Accounting.Views.Components"
             UseLayoutRounding="True"
             SnapsToDevicePixels="True">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Style="{StaticResource AdminWorkspaceHeaderCardStyle}" Margin="0,0,0,6">
            <StackPanel>
                <TextBlock Text="Manajemen Pengguna" Style="{StaticResource SettingsSectionTitleTextStyle}" />
                <TextBlock Text="Kelola pengguna, role, permission, serta struktur organisasi."
                           Style="{StaticResource SettingsSectionSubtitleTextStyle}" />
            </StackPanel>
        </Border>

        <TabControl x:Name="UserManagementTabControl"
                    Grid.Row="1"
                    SelectionChanged="UserManagementTabControl_OnSelectionChanged">
            <TabItem Header="Pengguna">
                <comp:UserManagementUsersTabControl />
            </TabItem>
            <TabItem Header="Role &amp; Akses">
                <comp:UserManagementRolesTabControl />
            </TabItem>
            <TabItem Header="Organisasi">
                <comp:UserManagementOrganizationTabControl />
            </TabItem>
        </TabControl>

        <ContentControl Grid.Row="2"
                        Content="{Binding}"
                        ContentTemplate="{StaticResource WorkspaceStatusMessageTemplate}" />
    </Grid>
</UserControl>
