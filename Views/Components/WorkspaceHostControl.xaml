<UserControl x:Class="Accounting.Views.Components.WorkspaceHostControl" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:comp="clr-namespace:Accounting.Views.Components" UseLayoutRounding="True" SnapsToDevicePixels="True">
    <Grid>
        <Border Style="{StaticResource CardBorderStyle}"
                Padding="{Binding ContentPadding}"
                MaxWidth="{Binding ContentMaxWidth}">
            <Grid>
                <comp:StandardWorkspaceControl DataContext="{Binding}" Visibility="{Binding IsStandardWorkspaceSelected, Converter={StaticResource BoolToVisibilityConverter}}" />
                <comp:MasterDataWorkspaceControl DataContext="{Binding MasterData}" Visibility="{Binding DataContext.IsMasterDataSelected, RelativeSource={RelativeSource AncestorType=Grid}, Converter={StaticResource BoolToVisibilityConverter}}" />
                <comp:InventoryWorkspaceControl DataContext="{Binding Inventory}" Visibility="{Binding DataContext.IsInventorySelected, RelativeSource={RelativeSource AncestorType=Grid}, Converter={StaticResource BoolToVisibilityConverter}}" />
                <comp:JournalWorkspaceControl DataContext="{Binding JournalManagement}" Visibility="{Binding DataContext.IsJournalSelected, RelativeSource={RelativeSource AncestorType=Grid}, Converter={StaticResource BoolToVisibilityConverter}}" />
                <comp:ReportsWorkspaceControl DataContext="{Binding Reports}" Visibility="{Binding DataContext.IsReportsSelected, RelativeSource={RelativeSource AncestorType=Grid}, Converter={StaticResource BoolToVisibilityConverter}}" />
                <comp:SettingsWorkspaceControl DataContext="{Binding}" Visibility="{Binding DataContext.IsSettingsSelected, RelativeSource={RelativeSource AncestorType=Grid}, Converter={StaticResource BoolToVisibilityConverter}}" />
                <comp:UserManagementWorkspaceControl DataContext="{Binding UserManagement}" Visibility="{Binding DataContext.IsUserManagementSelected, RelativeSource={RelativeSource AncestorType=Grid}, Converter={StaticResource BoolToVisibilityConverter}}" />
            </Grid>
        </Border>
    </Grid>
</UserControl>
